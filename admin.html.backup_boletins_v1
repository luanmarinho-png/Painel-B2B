window._bqImpFileSelected = function(file) {
  _bqImportFile = file;
  const icon = $b('bqImpUploadIcon');
  const label = $b('bqImpUploadLabel');
  const info = $b('bqImpFileInfo');
  const zone = $b('bqImpUploadZone');
  icon.textContent = '⏳'; label.textContent = file.name;
  zone.style.borderColor = 'var(--amber)';

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const wb = XLSX.read(e.target.result, { type: 'array' });
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws, { defval: '' });
      if (!rows.length) { info.innerHTML='<span style="color:var(--accent)">Planilha vazia.</span>'; info.style.display=''; return; }

      const norm = s => (s||'').toString().trim().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,'_');
      _bqImportParsed = rows.map(r => {
        const n = {}; for(const[k,v] of Object.entries(r)) n[norm(k)] = v; return n;
      }).map(r => {
        // Map prioridade: Alta→vermelho, Média→amarelo, Baixa→verde
        let prio = (r.prioridade||'verde').toString().toLowerCase();
        if (prio==='alta') prio='vermelho'; else if (prio.includes('dia')||prio.includes('med')) prio='amarelo'; else if (prio==='baixa') prio='verde';
        // Map dificuldade
        let dif = (r.dificuldade||'media').toString().toLowerCase();
        if (dif.includes('cil')||dif==='facil'||dif.includes('fác')) dif='facil';
        else if (dif.includes('dio')||dif.includes('méd')||dif==='medio') dif='media';
        else if (dif.includes('ici')||dif==='dificil'||dif.includes('difí')) dif='dificil';
        else dif='media';
        return {
          codigo_questao: (r.codigo_da_questao||r.codigo_questao||r.codigo||r.id||'').toString(),
          grande_area: r.grande_area||r.area||'',
          tema: r.tema||r.subtema||'',
          enunciado: r.enunciado||r.questao||r.pergunta||'',
          gabarito: (r.gabarito||r.resposta||'').toString().toUpperCase().charAt(0),
          dificuldade: dif,
          taxa_acerto: parseFloat(r['%_acerto']||r.taxa_acerto||r.taxa||r.acerto||0)||0,
          instituicao_questao: r.instituicao||r.instituicao_questao||r.inst||'',
          tipo_prova: r.tipo_de_prova||r.tipo_prova||r.tipo||'R1',
          ano_prova: (r.ano_da_prova||r.ano_prova||r.ano||'').toString(),
          prioridade: prio,
          bloco: (r.bloco||'').toString()
        };
      }).filter(r => r.enunciado && r.gabarito);

      icon.textContent = '✅';
      zone.style.borderColor = 'var(--green)';

      // Stats
      const areas = [...new Set(_bqImportParsed.map(q=>q.grande_area).filter(Boolean))].sort();
      const byArea = {};
      _bqImportParsed.forEach(q => { byArea[q.grande_area] = (byArea[q.grande_area]||0)+1; });

      info.innerHTML = `
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
          <span style="font-size:1rem">✅</span>
          <strong style="color:var(--green);font-size:0.88rem">${_bqImportParsed.length} questões detectadas</strong>
          <span style="font-size:0.72rem;color:var(--text-muted)">(${rows.length} linhas lidas, ${rows.length - _bqImportParsed.length} ignoradas)</span>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          ${areas.map(a => `<span style="font-size:0.72rem;font-weight:600;padding:3px 8px;border-radius:6px;background:var(--bg-elevated);color:var(--text-soft)">${esc(a)} (${byArea[a]})</span>`).join('')}
        </div>`;
      info.style.display = '';

      // Auto-fill areas
      const areasDiv = $b('bqImpAreas');
      if (areasDiv) {
        areasDiv.innerHTML = areas.map(a =>
          `<span style="font-size:0.76rem;font-weight:600;padding:4px 10px;border-radius:7px;background:var(--accent-soft);color:var(--accent);border:1px solid rgba(220,38,38,0.3)">${esc(a)} · ${byArea[a]}</span>`
        ).join('');
      }

      // Auto-fill title from sheet name
      const titInput = $b('bqImpTit');
      if (titInput && !titInput.value) titInput.value = wb.SheetNames[0] || '';

    } catch(err) {
      icon.textContent = '❌'; zone.style.borderColor = 'var(--accent)';
      info.innerHTML = '<span style="color:var(--accent)">Erro ao ler: ' + esc(err.message) + '</span>';
      info.style.display = ''; _bqImportParsed = [];
    }
  };
  reader.readAsArrayBuffer(file);
};

window._bqImportSubmit = async function() {
  const titulo = ($b('bqImpTit')?.value||'').trim();
  if (!titulo) { alert('Informe o título do simulado.'); return; }
  if (!_bqImportParsed.length) { alert('Envie a planilha com as questões primeiro.'); return; }

  const areas = [...new Set(_bqImportParsed.map(q=>q.grande_area).filter(Boolean))];
  if (!areas.length) { alert('Nenhuma grande área detectada nas questões.'); return; }

  const iesDestino = [...document.querySelectorAll('input[name="bqImpDestIES"]:checked')].map(c => c.value);

  const btn = $b('bqImpSubmitBtn');
  if(btn){btn.disabled=true;btn.textContent='⏳ Criando simulado...';}

  try {
    // 1. Create simulado
    const { data: simData, error: simErr } = await _sb.from('simulados_banco').insert({
      titulo,
      edital_num: ($b('bqImpEdt')?.value||'').trim(),
      deadline: $b('bqImpDl')?.value || null,
      questoes_por_area: parseInt($b('bqImpQpa')?.value)||5,
      grandes_areas: areas,
      instituicoes_destino: iesDestino,
      status: 'aberto',
      criado_por: _curEmail
    }).select();
    if (simErr) throw new Error('Erro ao criar simulado: ' + simErr.message);
    const simId = simData[0].id;

    // 2. Bulk-insert questions
    if(btn) btn.textContent = `⏳ Importando ${_bqImportParsed.length} questões...`;
    const questoes = _bqImportParsed.map(q => ({
      simulado_id: simId,
      instituicao: _curInst,
      submetido_por: _curEmail,
      codigo_questao: q.codigo_questao || null,
      grande_area: q.grande_area,
      tema: q.tema,
      enunciado: q.enunciado,
      gabarito: q.gabarito,
      dificuldade: q.dificuldade || 'media',
      taxa_acerto: q.taxa_acerto || 0,
      instituicao_questao: q.instituicao_questao || '',
      tipo_prova: q.tipo_prova || 'R1',
      ano_prova: q.ano_prova || '',
      prioridade: q.prioridade || 'verde',
      status: 'pendente'
    }));

    let imported = 0;
    for (let i = 0; i < questoes.length; i += 50) {
      const batch = questoes.slice(i, i + 50);
      const { error: qErr } = await _sb.from('simulados_questoes').insert(batch);
      if (qErr) throw new Error(`Erro no lote ${i}: ` + qErr.message);
      imported += batch.length;
      if(btn) btn.textContent = `⏳ ${imported}/${questoes.length} questões importadas...`;
    }

    _bqImportParsed = [];
    window.bqCloseModal();
    await bqInit();

    // Success toast
    const toast = document.createElement('div');
    toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;background:#166534;color:#bbf7d0;padding:14px 22px;border-radius:12px;font-size:0.88rem;font-weight:700;box-shadow:0 4px 24px rgba(0,0,0,0.5)';
    toast.textContent = `✅ Simulado criado com ${imported} questões importadas!`;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);

  } catch(err) {
    alert(err.message);
    if(btn){btn.disabled=false;btn.textContent='📊 Criar e importar questões';}
  }
};

// ── Excel import state (create modal) ────────────────────────────
let _bqCrParsedRows = [];

window._bqCrFileSelected = function(input) {
  const file = input.files[0]; if (!file) return;
  const zone = $b('bqCrUploadZone');
  const info = $b('bqCrFileInfo');
  $b('bqCrUploadLabel').textContent = file.name;
  $b('bqCrUploadIcon').textContent = '⏳';
  zone.style.borderColor = 'var(--amber)';

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const wb = XLSX.read(e.target.result, { type: 'array' });
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws, { defval: '' });
      if (!rows.length) { info.style.color='var(--accent)'; info.textContent='Planilha vazia.'; info.style.display=''; return; }

      // Normalize column names (lowercase, trim, remove accents)
      const norm = s => (s||'').toString().trim().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,'_');
      const normalizedRows = rows.map(row => {
        const out = {};
        for (const [k,v] of Object.entries(row)) out[norm(k)] = v;
        return out;
      });

      // Map to question fields
      _bqCrParsedRows = normalizedRows.map(r => ({
        grande_area:        r.grande_area || r.area || r.grandearea || '',
        tema:               r.tema || r.subtema || '',
        enunciado:          r.enunciado || r.questao || r.pergunta || '',
        gabarito:           (r.gabarito || r.resposta || '').toString().toUpperCase().charAt(0),
        dificuldade:        (r.dificuldade || 'media').toString().toLowerCase().replace('fácil','facil').replace('difícil','dificil').replace('média','media'),
        codigo_questao:     (r.codigo_questao || r.codigo || r.id || '').toString(),
        instituicao_questao: r.instituicao_questao || r.instituicao || r.inst || '',
        tipo_prova:         r.tipo_prova || r.tipo || 'R1',
        ano_prova:          (r.ano_prova || r.ano || '').toString(),
        taxa_acerto:        parseFloat(r.taxa_acerto || r.taxa || 0) || 0,
        prioridade:         r.prioridade || 'verde'
      })).filter(r => r.enunciado && r.gabarito);

      $b('bqCrUploadIcon').textContent = '✅';
      zone.style.borderColor = 'var(--green)';
      info.style.color = 'var(--green)';
      info.textContent = `${_bqCrParsedRows.length} questões encontradas de ${rows.length} linhas`;
      info.style.display = '';

      // Auto-select areas from the parsed questions
      const foundAreas = [...new Set(_bqCrParsedRows.map(r => r.grande_area).filter(Boolean))];
      foundAreas.forEach(a => {
        const lbl = $b('bqALbl_' + encodeURIComponent(a));
        if (lbl && !lbl.querySelector('input').checked) window._bqToggleArea(lbl);
      });
    } catch(err) {
      $b('bqCrUploadIcon').textContent = '❌';
      zone.style.borderColor = 'var(--accent)';
      info.style.color = 'var(--accent)';
      info.textContent = 'Erro ao ler planilha: ' + err.message;
      info.style.display = '';
      _bqCrParsedRows = [];
    }
  };
  reader.readAsArrayBuffer(file);
};

window.bqSaveSim = async function() {
  const titulo = ($b('bqCrTit')?.value||'').trim();
  if (!titulo) { alert('Informe o título.'); return; }
  const areas = [...document.querySelectorAll('input[name="bqNewArea"]:checked')].map(c => c.value);
  if (!areas.length) { alert('Selecione ao menos uma grande área.'); return; }
  const iesDestino = [...document.querySelectorAll('input[name="bqDestIES"]:checked')].map(c => c.value);

  // Disable button while saving
  const btn = document.querySelector('.bq-modal-footer .bq-btn-primary');
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Criando...'; }

  const { data: simData, error } = await _sb.from('simulados_banco').insert({
    titulo,
    edital_num: ($b('bqCrEdt')?.value||'').trim(),
    deadline: $b('bqCrDl')?.value || null,
    questoes_por_area: parseInt($b('bqCrQpa')?.value)||5,
    grandes_areas: areas,
    instituicoes_destino: iesDestino,
    status: 'aberto',
    criado_por: _curEmail
  }).select();
  if (error) { alert('Erro ao criar: ' + error.message); if(btn){btn.disabled=false;btn.textContent='Criar simulado';} return; }

  // Bulk-insert questions from Excel if available
  if (_bqCrParsedRows.length > 0 && simData && simData[0]) {
    const simId = simData[0].id;
    if (btn) btn.textContent = `⏳ Importando ${_bqCrParsedRows.length} questões...`;
    const questoes = _bqCrParsedRows.map(q => ({
      simulado_id: simId,
      instituicao: _curInst,
      submetido_por: _curEmail,
      grande_area: q.grande_area,
      tema: q.tema,
      enunciado: q.enunciado,
      gabarito: q.gabarito,
      dificuldade: q.dificuldade || 'media',
      codigo_questao: q.codigo_questao || null,
      instituicao_questao: q.instituicao_questao || '',
      tipo_prova: q.tipo_prova || 'R1',
      ano_prova: q.ano_prova || '',
      taxa_acerto: q.taxa_acerto || 0,
      prioridade: q.prioridade || 'verde',
      status: 'pendente'
    }));
    // Insert in batches of 50
    for (let i = 0; i < questoes.length; i += 50) {
      const batch = questoes.slice(i, i + 50);
      const { error: qErr } = await _sb.from('simulados_questoes').insert(batch);
      if (qErr) { console.error('Erro ao importar questões (batch ' + i + '):', qErr.message); }
    }
    _bqCrParsedRows = [];
  }

  window.bqCloseModal();
  await bqInit();
};

