window.bqOpenComposePanel = function(simId) {
  _composeSimId = simId;
  const sim = _sims.find(s => s.id === simId); if (!sim) return;
  const areas   = parseArr(sim.grandes_areas);
  const approved = _qs.filter(q => q.simulado_id === simId && q.status === 'aprovada');
  const existing = parseArr(sim.composicao_final);
  const qpa = sim.questoes_por_area || 5;

  const areaHtml = areas.map(area => {
    const aqs = approved.filter(q => q.grande_area === area);
    const qItems = aqs.length === 0
      ? '<div style="font-size:0.78rem;color:var(--text-muted);padding:6px 0">Nenhuma questão aprovada nesta área.</div>'
      : `<div class="bq-comp-q-list">${aqs.map(q => {
          const sel = existing.includes(q.id);
          return `<div class="bq-comp-q-item ${sel?'bq-sel':''}" onclick="window.bqToggleCompQ(this,'${q.id}')">
            <input type="checkbox" data-qid="${q.id}" ${sel?'checked':''} onclick="event.stopPropagation()" onchange="event.stopPropagation()">
            <div>
              <div class="bq-comp-q-enunc">${esc(q.tema||'')} — ${esc((q.enunciado||'').substring(0,80))}…</div>
              <div class="bq-comp-q-meta">${esc(q.instituicao_questao||'')} ${esc(q.tipo_prova||'')} ${esc(q.ano_prova||'')} · Gab: ${q.gabarito} · ${esc(q.instituicao)}</div>
            </div>
          </div>`;
        }).join('')}</div>`;
    const selCount = existing.filter(id => aqs.some(q => q.id === id)).length;
    return `<div class="bq-comp-area-block">
      <div class="bq-comp-area-title">${esc(area)}</div>
      <div class="bq-comp-area-sub">${aqs.length} aprovada(s) · Meta: ${qpa} · Selecionadas: <strong id="bqSelCount_${area.replace(/\s/g,'_')}">${selCount}</strong></div>
      ${qItems}
    </div>`;
  }).join('');

  const cp = $b('bqComposeContent');
  if (!cp) return;
  cp.innerHTML = `
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap;padding-bottom:14px;border-bottom:1px solid var(--border)">
