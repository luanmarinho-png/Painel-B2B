  const segZone = $("uploadSeguimento"), segInput = $("fileSeguimento");
  ["dragenter","dragover"].forEach(e => segZone.addEventListener(e, ev => { ev.preventDefault(); segZone.classList.add("dragover"); }));
  ["dragleave","drop"].forEach(e => segZone.addEventListener(e, ev => { ev.preventDefault(); segZone.classList.remove("dragover"); }));
  segZone.addEventListener("drop", ev => { if (ev.dataTransfer.files.length) addSegFiles(ev.dataTransfer.files); });
  segInput.addEventListener("change", () => { if (segInput.files.length) addSegFiles(segInput.files); segInput.value=""; });
  segZone.addEventListener("click", (e) => { if (e.target !== segInput) segInput.click(); });

  $("updateInst").addEventListener("change",updateBtn);

  $("btnProcess").addEventListener("click", async()=>{
    clearLog(); $("previewCard").style.display="none"; $("successBanner").classList.remove("visible");
    const slug=$("updateInst").value;
    if(!slug){log("Selecione uma instituição","err");return;}

    // Coletar slots com arquivo
    const slots = (window._periodSlots || []).filter(s => s.file);
    if(!slots.length){log("Envie pelo menos uma planilha de seguimento","err");return;}

    $("btnProcess").disabled=true;
    const totalSlots = slots.length;
    $("btnProcess").innerHTML='<span style="display:inline-flex;align-items:center;gap:6px"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Processando 0/' + totalSlots + '...</span>';
    try {
      const normN = s => (s||"").trim().toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"").replace(/\s+/g," ");

      // ── Processar cada slot (período) individualmente ──
      let allNewPeriods = [];
      const allOrigLabels = new Set();

      for (let si = 0; si < slots.length; si++) {
        const slot = slots[si];
        const slotIdx = window._periodSlots.indexOf(slot);
        log(`\n📦 Período ${si+1}/${totalSlots}: ${slot.file.name}`, "ok");
        $("btnProcess").innerHTML='<span style="display:inline-flex;align-items:center;gap:6px"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Processando ' + (si+1) + '/' + totalSlots + '...</span>';

        // Parse o arquivo do slot
        const filePeriods = await P.parseSeguimento(slot.file, $("exclusionList").value, null, log);
        await P.integrateTempo(slot.file, filePeriods, log);

        // Mesclar períodos do mesmo arquivo
        const periodMap = new Map();
        filePeriods.forEach(p => {
          if (!periodMap.has(p.periodo)) {
            periodMap.set(p.periodo, { ...p, alunos: [...p.alunos] });
          } else {
            const existing = periodMap.get(p.periodo);
            const knownNames = new Set(existing.alunos.map(a => normN(a.nome)));
            p.alunos.forEach(a => {
              if (!knownNames.has(normN(a.nome))) { existing.alunos.push(a); knownNames.add(normN(a.nome)); }
            });
          }
        });

        let slotPeriods = Array.from(periodMap.values());
        if(!slotPeriods.length){ log(`⚠️ Nenhum período encontrado no arquivo ${si+1}`, "warn"); continue; }

        // Guardar labels originais
        slotPeriods.forEach(p => allOrigLabels.add(p.periodo));

        // ── Dupla checagem de datas para ESTE slot ──
        const excelDates = extractExcelDates(slotPeriods);
        const formStartISO = slot.dateStart || '';
        const formEndISO   = slot.dateEnd || '';
        if (formStartISO && formEndISO) {
          const formStart = isoToDmy(formStartISO);
          const formEnd   = isoToDmy(formEndISO);
          if (formStart === excelDates.start && formEnd === excelDates.end) {
            slotPeriods = mergePeriods(slotPeriods, formStart, formEnd);
            log(`✅ P${si+1} — Datas confirmadas: ${formStart} a ${formEnd} — ${slotPeriods[0].alunos.length} alunos`, "ok");
          } else {
            log(`⚠️ P${si+1} — Divergência: formulário ${formStart}–${formEnd} | planilha ${excelDates.start}–${excelDates.end}`, "warn");
            const choice = await showDateModal(formStart, formEnd, excelDates.start, excelDates.end);
            slotPeriods = applyChosenDates(slotPeriods, choice, formStart, formEnd, excelDates.start, excelDates.end);
            const usedDates = choice === "form" ? `${formStart} a ${formEnd}` : `${excelDates.start} a ${excelDates.end}`;
            log(`${choice === "form" ? "📋" : "📊"} P${si+1} — ${usedDates} — ${slotPeriods[0].alunos.length} alunos`, "ok");
          }
        } else {
          if (excelDates.start) log(`📊 P${si+1} — Datas da planilha: ${excelDates.start} a ${excelDates.end}`, "ok");
        }

        allNewPeriods.push(...slotPeriods);
      }

      let newPeriods = allNewPeriods;
      const origExcelLabels = allOrigLabels;
      if(!newPeriods.length){log("Nenhum período encontrado em nenhum arquivo!","err");return;}
      if(totalSlots > 1) log(`\n✅ Merge de ${totalSlots} slots: ${newPeriods.length} período(s), ${newPeriods.reduce((s,p)=>s+p.alunos.length,0)} alunos`, "ok");

      // Mesclar com períodos existentes da instituição
      // Remove tanto os labels novos quanto os labels originais do Excel (evita duplicatas ao mudar label por datas do formulário)
      const ds = window.INSTITUTION_DATASETS||{};
      const existing = ds[slug];
      if(existing && existing.allData && existing.allData.length > 0) {
        const oldPeriods = existing.allData;
        const newLabels = new Set(newPeriods.map(p=>p.periodo));
        // Normaliza formato legado: converte "data" → "alunos" e "sheet" → "periodo"
        const kept = oldPeriods
          .filter(p => !newLabels.has(p.periodo) && !origExcelLabels.has(p.periodo))
          .map(p => {
            let norm = p.alunos ? p : { ...p, alunos: p.data || [] };
            if (!norm.periodo && norm.sheet) {
              const raw = norm.sheet.replace("Análise de uso - ", "").trim();
              const rm = raw.match(/^(\d{2})(\d{2})\s+a\s+(\d{2})(\d{2})$/);
              norm = { ...norm, periodo: rm ? `${rm[1]}/${rm[2]} a ${rm[3]}/${rm[4]}` : raw };
            }
            return norm;
          });
        parsedPeriods = [...kept, ...newPeriods];
        log(`Períodos existentes mantidos: ${kept.length}, novos: ${newPeriods.length}, total: ${parsedPeriods.length}`,"ok");
      } else {
        parsedPeriods = newPeriods;
      }

      generatedJS = P.generateJS(slug, parsedPeriods, {});
      // Atualizar INSTITUTION_DATASETS em memória — merge para preservar themeClass e demais configs
      window.INSTITUTION_DATASETS = window.INSTITUTION_DATASETS || {};
      window.INSTITUTION_DATASETS[slug] = {
        ...(window.INSTITUTION_DATASETS[slug] || {}),
        allData: parsedPeriods.map(p => ({ periodo: p.periodo, dateStart: p.dateStart, dateEnd: p.dateEnd, alunos: p.alunos }))
      };
      const totalAlunosProcessed = new Set();
      parsedPeriods.forEach(p => (p.alunos||[]).forEach(a => { if(a.nome) totalAlunosProcessed.add(a.nome.trim().toLowerCase()); }));
      const slotsUsed = (window._periodSlots || []).filter(s => s.file).length;
      log(`\n✅ Concluído! ${slotsUsed} período(s) processado(s), ${parsedPeriods.length} período(s) no arquivo final, ${totalAlunosProcessed.size} alunos.`,"ok");
      showToast(`${slotsUsed} período(s) processado(s) — ${totalAlunosProcessed.size} alunos`, 'success');
      renderPreview(parsedPeriods);
      window._refreshInstGrid?.();   // atualiza card do grid imediatamente
    } catch(e) { log("Erro: "+e.message,"err"); console.error(e); }
    finally {
      $("btnProcess").disabled=false;
      $("btnProcess").innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg> Processar e gerar arquivo';
      updateBtn();
    }
  });

  function renderPreview(periods) {
    $("previewCard").style.display="block";
    const uniq=new Set(); let tQ=0,tM=0;
    periods.forEach(p=>(p.alunos||p.data||[]).forEach(a=>{uniq.add(a.nome.trim().toLowerCase());tQ+=a.questoes||0;tM+=a.tempo_min||0;}));
    $("previewStats").innerHTML=`
      <div class="preview-stat"><div class="preview-stat-num">${periods.length}</div><div class="preview-stat-label">Períodos</div></div>
      <div class="preview-stat"><div class="preview-stat-num">${uniq.size}</div><div class="preview-stat-label">Alunos</div></div>
      <div class="preview-stat"><div class="preview-stat-num">${tQ.toLocaleString("pt-BR")}</div><div class="preview-stat-label">Questões</div></div>
      <div class="preview-stat"><div class="preview-stat-num">${Math.round(tM/60).toLocaleString("pt-BR")}h</div><div class="preview-stat-label">Tempo</div></div>`;
    $("previewSheets").innerHTML=periods.map(p=>`<span class="preview-sheet-tag">${p.periodo} <span class="sheet-count">(${(p.alunos||p.data||[]).length})</span></span>`).join("");
    const latest=periods[periods.length-1]||periods[0]; const sample=(latest?(latest.alunos||latest.data||[]):[]).slice(0,15);
    const ht=sample.some(a=>a.turma);
    $("previewThead").innerHTML=`<tr><th>#</th><th>Nome</th>${ht?'<th>Turma</th>':''}<th>Questões</th><th>Aulas</th><th>Flashcards</th><th>Logins</th><th>Tempo</th></tr>`;
    $("previewTbody").innerHTML=sample.map((a,i)=>`<tr><td>${i+1}</td><td>${a.nome}</td>${ht?`<td>${a.turma||'—'}</td>`:''}<td>${a.questoes}</td><td>${a.aulas}</td><td>${a.flashcards}</td><td>${a.logins}</td><td>${a.tempo_min?Math.round(a.tempo_min/60)+'h':'—'}</td></tr>`).join("");
  }

  $("btnDownload").addEventListener("click", async()=>{
    if(!generatedJS) return;
    const slug=$("updateInst").value;
    $("btnDownload").disabled=true; $("btnDownload").textContent="Gerando ZIP...";
    try {
      const zip = new JSZip();
      zip.file(slug+"/dashboard-data.js", generatedJS);
      const blob = await zip.generateAsync({type:"blob"});
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a"); a.href=url; a.download=slug+"_atualização.zip"; a.click();
      URL.revokeObjectURL(url);
      $("successBanner").classList.add("visible");
      $("successText").innerHTML=`
        <strong>ZIP baixado!</strong> Contém <code>${slug}/dashboard-data.js</code> atualizado.
        <div class="deploy-steps">
          <div class="deploy-step"><span class="deploy-step-num">1</span><span>Extraia o ZIP na raiz da pasta do deploy (vai sobrescrever o arquivo antigo)</span></div>
          <div class="deploy-step"><span class="deploy-step-num">2</span><span>Faça deploy no Netlify (arraste a pasta ou <code>netlify deploy --prod</code>)</span></div>
        </div>
      `;
    } catch(e) { alert("Erro ao gerar ZIP: "+e.message); }
    finally {
      $("btnDownload").disabled=false;
      $("btnDownload").innerHTML='<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Baixar ZIP (fallback)';
    }
  });

  // ── Auto Deploy — envia dashboard-data.js diretamente para o Netlify ──────
  $("btnAutoDeploy").addEventListener("click", async () => {
    if (!generatedJS) return;
    const slug = $("updateInst").value;
    const btn  = $("btnAutoDeploy");

    // ── Confirmação pré-deploy ──
    const uniqAlunos = new Set();
    (parsedPeriods || []).forEach(p => (p.alunos || []).forEach(a => { if (a.nome) uniqAlunos.add(a.nome.trim().toLowerCase()); }));
    const fileSize = new TextEncoder().encode(generatedJS).length;
    const confirmed = await showDeployConfirm(slug, parsedPeriods || [], uniqAlunos.size, fileSize);
    if (!confirmed) return;

    btn.disabled = true; btn.textContent = "⏳ Fazendo deploy...";
    const prog = $("deployProgress");

    const deployFilesUpd = { [`${slug}/dashboard-data.js`]: generatedJS };
    // Inject card into admin.html if slug not yet present
    try {
      const adminResp = await fetch("/admin.html");
      if (adminResp.ok) {
        const adminText = await adminResp.text();
        if (!adminText.includes(`data-inst="${slug}"`)) {
          const injected = (typeof injectIntoAdminHTML === "function" && lastGenSlug === slug)
            ? injectIntoAdminHTML(adminText)
            : null;
          if (injected) deployFilesUpd["admin.html"] = injected;
        }
      }
    } catch(e) { console.warn("Não foi possível atualizar admin.html:", e); }
    await window._netlifyDeploy(
      deployFilesUpd,
      prog,
      async () => {
        // ── Auto-ativar IES (WIP → Ativo) após deploy bem-sucedido ──
        try {
          const sb = getSupabaseClient();
          await sb.from('instituicoes').update({ wip: false }).eq('slug', slug);
        } catch (_) { /* não bloquear o sucesso se o update falhar */ }

        $("successBanner").classList.add("visible");
        $("successText").innerHTML = `<strong>Deploy concluído!</strong> O arquivo <code>${slug}/dashboard-data.js</code> já está no ar.`;
        showToast('Deploy realizado com sucesso!', 'success');
        // Recarregar grid para refletir possível mudança de WIP → Ativo
        await loadAndRenderInstitutions();
        window._refreshInstGrid?.();
      }
    );
    btn.disabled = false;
    btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg> Deploy automático';
  });
})();
</script>

<!-- ═══════════ NETLIFY AUTO-DEPLOY (direto do navegador) ═══════════ -->
<script>
/* Deploy direto via Netlify API — sem server function.
   Elimina problemas de timeout, preservação de functions, etc.
   Token é pedido uma vez e salvo em localStorage. */

window._netlifyDeploy = async function(filesObj, progressEl, onSuccess) {
  function log(msg, type='info') {
    if (!progressEl) return;
    progressEl.classList.add('visible');
    const line = document.createElement('div');
    line.className = 'deploy-line-' + type;
    line.textContent = msg;
    progressEl.appendChild(line);
    progressEl.scrollTop = progressEl.scrollHeight;
  }

  /* SHA-1 via Web Crypto API */
  async function sha1hex(buf) {
    const hash = await crypto.subtle.digest('SHA-1', buf);
    return Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2,'0')).join('');
  }

  /* Qualquer conteúdo → ArrayBuffer */
  async function toArrayBuffer(content) {
    if (content instanceof ArrayBuffer) return content;
    if (content instanceof Blob) return await content.arrayBuffer();
    return new TextEncoder().encode(content).buffer;
  }

  if (progressEl) { progressEl.innerHTML = ''; progressEl.classList.add('visible'); }

  // ── Verificar credenciais ───────────────────────────────────────
  let token  = localStorage.getItem('netlify_token');
  let siteId = localStorage.getItem('netlify_site_id');
  if (!token || !siteId) {
    log('🔑 Configure suas credenciais Netlify (só precisa fazer uma vez)', 'info');
    token = prompt('Cole seu NETLIFY_TOKEN (Personal Access Token).\nGere em: https://app.netlify.com/user/applications#personal-access-tokens');
    if (!token) { log('❌ Deploy cancelado — token não informado.', 'err'); return; }
    siteId = prompt('Cole seu NETLIFY_SITE_ID.\nEncontre em: Netlify → Site Settings → General → Site ID');
    if (!siteId) { log('❌ Deploy cancelado — Site ID não informado.', 'err'); return; }
    localStorage.setItem('netlify_token', token.trim());
    localStorage.setItem('netlify_site_id', siteId.trim());
    token = token.trim(); siteId = siteId.trim();
  }

  const API = 'https://api.netlify.com/api/v1';
  const auth = { Authorization: `Bearer ${token}` };

  log('⏳ Preparando arquivos...');

  try {
    // ── 1. Converter arquivos → ArrayBuffer + SHA1 ────────────────
    const pathToSha   = {};
    const shaToBuffer = {};
    for (const [rawPath, content] of Object.entries(filesObj)) {
      const p   = rawPath.startsWith('/') ? rawPath : '/' + rawPath;
      const buf = await toArrayBuffer(content);
      const sha = await sha1hex(buf);
      pathToSha[p]     = sha;
      shaToBuffer[sha] = buf;
    }
    log(`📦 ${Object.keys(pathToSha).length} arquivo(s) prontos`, 'ok');

    // ── 2. Buscar deploy atual e arquivos existentes ──────────────
    log('🔗 Conectando à Netlify API...');
    const deploysResp = await fetch(`${API}/sites/${siteId}/deploys?per_page=1`, { headers: auth });
    if (!deploysResp.ok) {
      if (deploysResp.status === 401) { localStorage.removeItem('netlify_token'); throw new Error('Token inválido — recarregue a página e tente novamente.'); }
      throw new Error(`Erro ao buscar deploys: ${deploysResp.status}`);
    }
    const currentDeploy = (await deploysResp.json())[0];

    const mergedFiles = { ...pathToSha };
    if (currentDeploy?.id) {
      log('📂 Mesclando com arquivos existentes...');
      const r = await fetch(`${API}/deploys/${currentDeploy.id}/files`, { headers: auth });
      if (!r.ok) {
        throw new Error(`Não foi possível obter a lista de arquivos do deploy atual (HTTP ${r.status}). Deploy cancelado para evitar perda de arquivos do site.`);
      }
      const existingFiles = await r.json();
      for (const f of existingFiles) {
        const sha = f.sha || f.sha1;
        if (sha && !mergedFiles[f.id]) mergedFiles[f.id] = sha;
      }
    }
    log(`📊 ${Object.keys(mergedFiles).length} arquivo(s) no total`, 'ok');

    // ── 3. Criar novo deploy ──────────────────────────────────────
    log('🚀 Criando deploy...');
    const createResp = await fetch(`${API}/sites/${siteId}/deploys`, {
      method: 'POST',
      headers: { ...auth, 'Content-Type': 'application/json' },
      body: JSON.stringify({ files: mergedFiles, draft: false }),
    });
    if (!createResp.ok) {
      const txt = await createResp.text();
      throw new Error(`Criar deploy: ${createResp.status} — ${txt.slice(0,120)}`);
    }
    const deploy = await createResp.json();

    // ── 4. Upload de arquivos requeridos ──────────────────────────
    const required = deploy.required || [];
    if (required.length > 0) {
      log(`📤 Enviando ${required.length} arquivo(s)...`);
      let uploaded = 0;
      await Promise.all(required.map(async (sha) => {
        const buf = shaToBuffer[sha];
        if (!buf) return;
        const p = Object.keys(pathToSha).find(k => pathToSha[k] === sha);
        if (!p) return;
        const up = await fetch(`${API}/deploys/${deploy.id}/files${p}`, {
          method: 'PUT',
          headers: { ...auth, 'Content-Type': 'application/octet-stream' },
          body: buf,
        });
        if (!up.ok) throw new Error(`Upload falhou ${p}: ${up.status}`);
        uploaded++;
        log(`  ✓ ${p} enviado`, 'ok');
      }));
    } else {
      log('⚡ Todos os arquivos já estavam em cache', 'ok');
    }

    // ── 5. Aguardar deploy ficar "ready" ──────────────────────────
    log('⏳ Aguardando processamento...');
    let state = deploy.state;
    for (let i = 0; i < 30 && state !== 'ready' && state !== 'error'; i++) {
      await new Promise(r => setTimeout(r, 2000));
      const poll = await fetch(`${API}/deploys/${deploy.id}`, { headers: auth });
      if (poll.ok) state = (await poll.json()).state;
    }

    if (state === 'error') throw new Error('Deploy falhou no processamento do Netlify.');
    if (state !== 'ready') throw new Error(`Deploy não finalizou (estado: ${state}). Tente novamente.`);

    log(`✅ Deploy publicado e no ar!`, 'ok');
    log(`🌐 ${deploy.ssl_url || deploy.url}`, 'ok');
    log(`📊 ${Object.keys(pathToSha).length} novo(s) · ${required.length} enviado(s) · ${Object.keys(mergedFiles).length} total`, 'info');
    if (onSuccess) onSuccess({ url: deploy.ssl_url || deploy.url, deploy_id: deploy.id, files_total: Object.keys(mergedFiles).length });

  } catch (e) {
    log('❌ Erro: ' + e.message, 'err');
  }
};
</script>

