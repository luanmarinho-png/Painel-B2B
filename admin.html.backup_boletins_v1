  // ── Admin.html injection logic ──
  let lastGenSlug="", lastGenCardHTML="", lastGenScriptTag="";
  let injectedAdminBlob=null;

  function injectIntoAdminHTML(htmlContent, silent=false) {
    if(!lastGenSlug||!lastGenCardHTML) {
      if(!silent) alert("Gere os arquivos da IES primeiro.");
      return null;
    }

    // Check if already injected
    if(htmlContent.includes(`data-inst="${lastGenSlug}"`)) {
      if(!silent) alert(`A IES "${lastGenSlug}" já existe neste admin.html!`);
      return null;
    }

    let result = htmlContent;

    // 1. Inject card HTML as last item inside instGrid
    // Strategy: find the instGrid opening, then locate its closing </div>
    // The grid contains only <a> cards (no nested divs at grid level),
    // so we look for the first occurrence of the grid-close pattern after the grid opens.
    const instGridStart = result.indexOf('id="instGrid"');
    if(instGridStart > 0) {
      const gridContentStart = result.indexOf('>', instGridStart) + 1;
      // The instGrid closes with a line that has exactly 6 spaces + </div>
      // We find the FIRST such closing tag after the grid opens — that is the grid's own </div>
      const gridClosePattern = '\n      </div>';
      const gridCloseIdx = result.indexOf(gridClosePattern, gridContentStart);
      if(gridCloseIdx > gridContentStart) {
        // Insert the new card right before the grid's closing </div>
        result = result.slice(0, gridCloseIdx) + '\n        ' + lastGenCardHTML + result.slice(gridCloseIdx);
      }
    }

    // 2. Inject script tag after the last dashboard-data.js script
    const closeTag = '<' + '/script>';
    const searchStr = 'dashboard-data.js">' + closeTag;
    const lastScriptMatch = result.lastIndexOf(searchStr);
    if(lastScriptMatch > 0) {
      const insertPos = lastScriptMatch + searchStr.length;
      result = result.slice(0, insertPos) + "\n" + lastGenScriptTag.replace("<\\/script>", closeTag) + result.slice(insertPos);
    }

    // 3. Add slug to mainKeys array in stats computation
    const mainKeysMatch = result.match(/const mainKeys\s*=\s*\[([^\]]+)\]/);
    if(mainKeysMatch && !mainKeysMatch[1].includes(`"${lastGenSlug}"`)) {
      const oldKeys = mainKeysMatch[0];
      const newKeys = oldKeys.replace("]", `,"${lastGenSlug}"]`);
      result = result.replace(oldKeys, newKeys);
    }

    return result;
  }

  function showInjectResult(adminContent) {
    injectedAdminBlob = new Blob([adminContent], {type:"text/html"});
    $("injectResult").style.display="block";
    $("injectFileSize").textContent=Math.round(injectedAdminBlob.size/1024)+" KB — com card da nova IES";
    $("btnDownloadAdmin").onclick=()=>{
      const u=URL.createObjectURL(injectedAdminBlob);
      const a=document.createElement("a"); a.href=u; a.download="admin.html"; a.click();
      URL.revokeObjectURL(u);
    };
  }

  // Upload admin.html and inject
  const adminZone=$("uploadAdminHTML"), adminInput=$("fileAdminHTML");
  ["dragenter","dragover"].forEach(e=>adminZone.addEventListener(e,ev=>{ev.preventDefault();adminZone.classList.add("dragover");}));
  ["dragleave","drop"].forEach(e=>adminZone.addEventListener(e,ev=>{ev.preventDefault();adminZone.classList.remove("dragover");}));
  adminZone.addEventListener("drop",ev=>{ if(ev.dataTransfer.files[0]) processAdminUpload(ev.dataTransfer.files[0]); });
  adminInput.addEventListener("change",()=>{ if(adminInput.files[0]) processAdminUpload(adminInput.files[0]); });

  async function processAdminUpload(file) {
    if(!lastGenSlug) { alert("Gere os arquivos da IES primeiro."); return; }
    adminZone.classList.add("has-file");
    adminZone.querySelector(".upload-zone-icon").textContent="✅";
    adminZone.querySelector(".upload-zone-title").textContent=file.name;
    adminZone.querySelector(".upload-zone-hint").textContent=(file.size/1024).toFixed(0)+" KB";

    const text = await file.text();
    const injected = injectIntoAdminHTML(text);
    if(injected) showInjectResult(injected);
  }
})();
</script>

