      // Incluir logo da IES no ZIP se enviado
      if(regLogoFile) {
        const logoData = await new Promise((res,rej)=>{ const r=new FileReader(); r.onload=e=>res(e.target.result); r.onerror=rej; r.readAsArrayBuffer(regLogoFile); });
        const ext = regLogoFile.name.split('.').pop().toLowerCase();
        folder.file(logo, logoData);
        log(`Logo incluída: ${logo}`,"ok");
      }

      const zipBlob = await zip.generateAsync({type:"blob"});
      const zipSizeKB = Math.round(zipBlob.size/1024);

      log(`✅ ZIP pronto: ${slug}.zip (${zipSizeKB} KB)`,"ok");
      log(`\nApós baixar:`,"ok");
