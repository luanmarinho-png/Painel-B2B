<!-- Stats + populate selectors -->
<script>
(() => {
  const $ = (id) => document.getElementById(id);
  const fmt = n => n.toLocaleString("pt-BR");
  const datasets = window.INSTITUTION_DATASETS || {};
  window._adminMainKeys = window._instData.filter(i => !i.wip).map(i => i.slug);
  const mainKeys = window._adminMainKeys.length > 0
    ? window._adminMainKeys
    : ["facene","unicet","unisc","univassouras","unifeso","famene","unichristus","uninassau-cacoal","uninassau-vilhena","uninassau-recife","uninassau-barreiras","unifaa","faminas","cesmac","unifip","faminas-muria"];

  function computeStats() {
    const uniq = new Set(); let tQ = 0, tM = 0;
    Object.values(datasets).forEach(inst => {
      if (inst.parentKey) return;
      (inst.allData||[]).forEach(p => {
        (p.alunos||p.data||[]).forEach(a => { if(a.nome) uniq.add(a.nome.trim().toLowerCase()); tQ += a.questoes||0; tM += a.tempo_min||0; });
      });
    });
    if($("statAlunos")) $("statAlunos").textContent = fmt(uniq.size);
    if($("statQuestoes")) $("statQuestoes").textContent = fmt(tQ);
    if($("statHoras")) $("statHoras").textContent = fmt(Math.round(tM/60));
    if($("statMedia")) $("statMedia").textContent = document.querySelectorAll('#instGrid .inst-card').length;

    // Processar TODOS os slugs com dados (incluindo WIP com upload recente)
    Object.keys(datasets).forEach(key => {
      const inst = datasets[key]; if(!inst || inst.parentKey) return;
      const names = new Set();
      (inst.allData||[]).forEach(p => (p.alunos||p.data||[]).forEach(a => { if(a.nome) names.add(a.nome.trim().toLowerCase()); }));
      const el = document.querySelector(`.inst-card[data-inst="${key}"] .inst-alunos`);
      if(el) el.textContent = fmt(names.size);

      // Preencher data da última atualização (dateEnd do último período)
      const dateEl = document.querySelector(`.inst-card[data-inst="${key}"] .inst-last-update`);
      if(dateEl && inst.allData && inst.allData.length > 0) {
        const _months = {janeiro:0,fevereiro:1,'março':2,abril:3,maio:4,junho:5,julho:6,agosto:7,setembro:8,outubro:9,novembro:10,dezembro:11};
        const getEndMs = p => {
          if(p.dateEnd) { const [dd,mm,yy] = p.dateEnd.split("/").map(Number); return new Date(yy,mm-1,dd).getTime(); }
          if(p.sheet) {
            const rm = p.sheet.replace("Análise de uso - ","").trim().match(/(\d{2})(\d{2})\s+a\s+(\d{2})(\d{2})$/);
            if(rm) return new Date(2026, Number(rm[4])-1, Number(rm[3])).getTime();
            const mm = p.sheet.replace("Análise de uso - ","").trim().match(/^([A-Za-zÀ-ÿ]+)(\d{4})$/);
            if(mm) { const mi = _months[mm[1].toLowerCase()]; if(mi!==undefined) return new Date(Number(mm[2]),mi+1,0).getTime(); }
          }
          if(p.periodo && p.periodo.includes(' a ')) {
            const end = p.periodo.split(' a ').pop().trim();
            const [dd,mm] = end.split("/").map(Number);
            if(dd && mm) return new Date(2026,mm-1,dd).getTime();
          }
          return 0;
        };
        const lastPeriodo = inst.allData.reduce((latest, p) => getEndMs(p) > getEndMs(latest) ? p : latest, inst.allData[0]);
        let display = '';

        if(lastPeriodo.dateEnd) {
          display = lastPeriodo.dateEnd;
        } else if(lastPeriodo.sheet) {
          const rangeMatch = lastPeriodo.sheet.replace("Análise de uso - ", "").trim().match(/(\d{2})(\d{2})\s+a\s+(\d{2})(\d{2})$/);
          if(rangeMatch) {
            display = rangeMatch[3] + '/' + rangeMatch[4] + '/2026';
          } else {
            const monthMatch = lastPeriodo.sheet.replace("Análise de uso - ", "").trim().match(/^([A-Za-zÀ-ÿ]+)(\d{4})$/);
            if(monthMatch) display = monthMatch[1] + '/' + monthMatch[2];
          }
        } else if(lastPeriodo.periodo && lastPeriodo.periodo.includes(' a ')) {
          display = lastPeriodo.periodo.split(' a ').pop().trim() + '/2026';
        }

        if(display) {
          dateEl.textContent = 'Atualizado até ' + display;
          dateEl.style.display = '';
        }
      }
    });

    // Simulado Tendências badge — verde se resultsData preenchido, amarelo se vazio
    Object.keys(datasets).forEach(key => {
      const inst = datasets[key]; if(!inst || inst.parentKey) return;
      const badge = document.querySelector(`.inst-card[data-inst="${key}"] .inst-sim-badge`);
      if (!badge) return;
      const hasSim = inst.resultsData && inst.resultsData.length > 0;
      badge.className = 'inst-sim-badge ' + (hasSim ? 'inst-sim-ok' : 'inst-sim-pending');
      badge.innerHTML = hasSim
        ? '<span style="display:flex;flex-direction:column;gap:1px"><span style="font-size:0.62rem;opacity:0.7;font-weight:600;text-transform:uppercase;letter-spacing:0.06em">Simulado Tendências</span><span>✅ Resultado cadastrado</span></span>'
        : '<span style="display:flex;flex-direction:column;gap:1px"><span style="font-size:0.62rem;opacity:0.7;font-weight:600;text-transform:uppercase;letter-spacing:0.06em">Simulado Tendências</span><span>⚠️ Resultado não cadastrado</span></span>';
    });

    // updateInst é populado por populateInstSelects() com todas as IES do Supabase

    // ── Ordenar grid: mais antigo primeiro (mais urgente) ─────────────
    const instGridEl = document.getElementById('instGrid');
    if (instGridEl) {
      const allCards = [...instGridEl.querySelectorAll(':scope > .inst-card')];
      allCards.forEach(card => {
        const dateEl = card.querySelector('.inst-last-update');
        let ts = Infinity; // sem data → aparece por último
        if (dateEl && dateEl.style.display !== 'none' && dateEl.textContent) {
          const txt = dateEl.textContent.replace('Atualizado até ', '').trim();
          const parts = txt.split('/');
          if (parts.length >= 2) {
            const dd = parseInt(parts[0]), mm = parseInt(parts[1]), yy = parts[2] ? parseInt(parts[2]) : 2026;
            if (!isNaN(dd) && !isNaN(mm)) ts = new Date(yy, mm - 1, dd).getTime();
          }
        }
        card.dataset.updateTs = ts;
      });
      // Ordena: menor timestamp (mais antigo) primeiro, Infinity (sem dados) no fim
      allCards.sort((a, b) => Number(a.dataset.updateTs) - Number(b.dataset.updateTs));
      allCards.forEach(card => instGridEl.appendChild(card));

      // ── Banner de IES desatualizadas há +15 dias ──────────────────
      const banner   = document.getElementById('staleUpdateBanner');
      const listEl   = document.getElementById('staleUpdateList');
      const LIMIT_MS = 15 * 24 * 60 * 60 * 1000; // 15 dias em ms
      const nowMs    = Date.now();
      if (banner && listEl) {
        const stale = allCards.filter(card => {
          const ts = Number(card.dataset.updateTs);
          return ts !== Infinity && !isNaN(ts) && (nowMs - ts) > LIMIT_MS;
        });
        if (stale.length > 0) {
          listEl.innerHTML = stale.map(card => {
            const nameEl  = card.querySelector('.inst-card-name');
            const name    = nameEl ? nameEl.textContent.trim() : card.dataset.inst.toUpperCase();
            const slug    = card.dataset.inst;
            const daysOld = Math.floor((nowMs - Number(card.dataset.updateTs)) / 86400000);
            return `<span onclick="window._goToUpdate('${slug}')" title="Ir para Atualizar Dados" style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:7px;background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.22);font-size:0.72rem;font-weight:700;color:#ef4444;white-space:nowrap;cursor:pointer;transition:background 0.15s" onmouseover="this.style.background='rgba(239,68,68,0.22)'" onmouseout="this.style.background='rgba(239,68,68,0.10)'">
              ${name}
              <span style="font-weight:500;opacity:0.75">${daysOld}d atrás</span>
              <span style="opacity:0.55;font-size:0.68rem;margin-left:1px">→</span>
            </span>`;
          }).join('');
          banner.style.display = 'block';
        } else {
          banner.style.display = 'none';
        }
      }
    }
  }
  if(document.readyState==='complete') computeStats(); else window.addEventListener('load', computeStats);
  // Expõe globalmente para re-chamar após deploys
  window._refreshInstGrid = computeStats;
})();
</script>

<!-- ═══════════ SHARED EXCEL PARSER ENGINE ═══════════ -->
<script>
window.MedCofParser = (() => {
  function safeFloat(v) { if(v==null) return 0; if(typeof v==="number") return v; const s=String(v).trim(); if(s.startsWith("=")||s==="") return 0; const n=parseFloat(s); return isNaN(n)?0:n; }
  function parseHours(v) { if(v==null) return 0; if(typeof v==="number") return v; const m=String(v).trim().match(/(\d+)h\s*(\d+)/); return m ? parseInt(m[1])*60+parseInt(m[2]) : 0; }
  function norm(name) { return name.trim().toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"").replace(/\s+/g," "); }
  function cellVal(ws,r,c) { const a=XLSX.utils.encode_cell({r,c}); const cell=ws[a]; return cell?cell.v:null; }
  const _minorWords = new Set(["de","da","do","das","dos","e","em","a","o","as","os","di","van","von"]);
  function titleCase(str) {
    if(!str) return str;
    return str.toLowerCase().split(/\s+/).map((w,i) => (i!==0 && _minorWords.has(w)) ? w : w.charAt(0).toUpperCase()+w.slice(1)).join(" ");
  }

  function cellDate(ws,r,c) {
    const a=XLSX.utils.encode_cell({r,c}); const cell=ws[a]; if(!cell) return null;
    if(cell.t==="n"&&cell.w&&cell.w.includes("/")) return cell.w;
    if(cell.t==="d") { const d=cell.v; return `${String(d.getDate()).padStart(2,"0")}/${String(d.getMonth()+1).padStart(2,"0")}/${d.getFullYear()}`; }
    if(cell.t==="n") { try { const dt=XLSX.SSF.parse_date_code(cell.v); if(dt&&dt.y) return `${String(dt.d).padStart(2,"0")}/${String(dt.m).padStart(2,"0")}/${dt.y}`; } catch(e){} }
    if(cell.t==="s") { const s=String(cell.v).trim(); if(/^\d{1,2}\/\d{1,2}\/\d{4}$/.test(s)) return s; }
    return null;
  }

  function detectColumns(ws, headerRow) {
    const cols={}, range=XLSX.utils.decode_range(ws["!ref"]||"A1");
    for(let c=range.s.c;c<=range.e.c;c++) {
      const v=cellVal(ws,headerRow,c); if(!v) continue; const l=String(v).trim().toLowerCase();
      if(l.includes("nome")) cols.nome=c;
      else if(l.includes("turma") || l.includes("período") || l.includes("periodo") || l.includes("semestre")) cols.turma=c;
      // Pacote ignorado — turma vem do master-alunos.json
      else if(l.includes("aula")&&!l.includes("média")&&!l.includes("dia")) cols.aulas=c;
      // videos ignorado por decisão do usuário
      else if(l.includes("quest")&&l.includes("acert")) cols.questoes_acertadas=c;
      else if(l.includes("quest")&&!l.includes("média")&&!l.includes("dia")&&!l.includes("acert")) cols.questoes=c;
      else if(l.includes("flash")) cols.flashcards=c;
      else if(l.includes("login")&&!l.includes("último")&&!l.includes("ultimo")&&!l.includes("media")&&!l.includes("média")&&!l.includes("semanal")) cols.logins=c;
      else if((l.includes("média")||l.includes("media"))&&l.includes("quest")) cols.media_q_dia=c;
      else if(l.includes("horas")&&l.includes("dia")) cols.horas_dia=c;
      else if(l.includes("taxa")&&l.includes("acerto")) cols.taxa_acerto=c;
    }
    return cols;
  }

  // Detect if sheet uses B2B format (headers in row 0) or legacy format (headers in row 2)
  function detectFormat(ws) {
    const r0 = cellVal(ws,0,0); // Row 1 (index 0)
    if(r0 && String(r0).trim().toLowerCase()==="id") return { headerRow:0, dataStartRow:1, format:"b2b" };
    const r0nome = cellVal(ws,0,1);
    if(r0nome && String(r0nome).trim().toLowerCase()==="nome") return { headerRow:0, dataStartRow:1, format:"b2b" };
    return { headerRow:2, dataStartRow:4, format:"legacy" };
  }

  // Parse "Horas por Dia" text to extract total minutes and date range
  function parseHorasDia(text) {
    if(!text) return { totalMin:0, dates:[] };
    const s = String(text);
    const matches = [...s.matchAll(/Dia:\s*(\d{2}\/\d{2}\/\d{4}):\s*([\d.]+)\s*horas/g)];
    let totalH = 0;
    const dates = [];
    for(const m of matches) {
      dates.push(m[1]);
      totalH += parseFloat(m[2]) || 0;
    }
    return { totalMin: Math.round(totalH * 60), dates };
  }

  // Cache do master-alunos.json
  let masterAlunosCache = null;
  async function loadMasterAlunos() {
    if(masterAlunosCache) return masterAlunosCache;
    try {
      const resp = await fetch("master-alunos.json");
      if(!resp.ok) throw new Error("HTTP "+resp.status);
      const json = await resp.json();
      masterAlunosCache = json.alunos || {};
      return masterAlunosCache;
    } catch(e) {
      console.warn("master-alunos.json não encontrado:", e);
      return {};
    }
  }

  function lookupTurma(nome, masterAlunos) {
    if(!masterAlunos || !nome) return "";
    const key = String(nome).trim().toUpperCase();
    const entry = masterAlunos[key];
    return entry ? (entry.turma || "") : "";
  }

  function buildExclusionSet(text) {
    const s=new Set(); if(!text) return s;
    text.split("\n").forEach(l=>{ l=l.trim(); if(l&&!l.startsWith("#")) s.add(norm(l)); }); return s;
  }
  function isExcluded(name,excSet) {
    const nw=new Set(norm(name).split(" "));
    for(const e of excSet) { if(e.split(" ").every(w=>nw.has(w))) return true; } return false;
  }

  async function readFile(file) {
    return new Promise((res,rej)=>{ const r=new FileReader(); r.onload=e=>res(e.target.result); r.onerror=rej; r.readAsArrayBuffer(file); });
  }

  function dateInputToLabel(startISO, endISO) {
    if(!startISO||!endISO) return null;
    const [sy,sm,sd]=startISO.split("-"); const [ey,em,ed]=endISO.split("-");
    return {
      dateStart: `${sd}/${sm}/${sy}`,
      dateEnd: `${ed}/${em}/${ey}`,
      label: `${sd}/${sm} a ${ed}/${em}`
    };
  }

  async function parseSeguimento(file, excText, manualDates, logFn) {
    const log = logFn || (()=>{});
    log("Lendo: "+file.name, "ok");
    const masterAlunos = await loadMasterAlunos();
    const masterCount = Object.keys(masterAlunos).length;
    log(`master-alunos.json: ${masterCount} alunos carregados`, masterCount>0?"ok":"warn");
    const data = await readFile(file);
    const wb = XLSX.read(data, {type:"array", cellStyles:true, cellDates:true});
    let sheets = wb.SheetNames.filter(s=>/^s\d+$/i.test(s));
    if(!sheets.length) sheets = wb.SheetNames.filter(s=>!["dados","template","resumo"].includes(s.toLowerCase()));
    log("Sheets: "+sheets.join(", "), "ok");

    const excSet = buildExclusionSet(excText);
    if(excSet.size) log(`Exclusões: ${excSet.size} nomes`);
    const periods = [];

    for(const sname of sheets) {
      const ws=wb.Sheets[sname];
      const fmt = detectFormat(ws);
      const cols=detectColumns(ws, fmt.headerRow);
      if(cols.nome==null) { log(`'${sname}': sem coluna nome, pulando`,"warn"); continue; }
      log(`  Formato: ${fmt.format} (headers row ${fmt.headerRow+1}, dados row ${fmt.dataStartRow+1})`);

      // Datas: tentar C2/D2 (legacy), senão "Horas por Dia" (B2B), senão manual
      const dateC=cellDate(ws,1,2), dateD=cellDate(ws,1,3);
      let dateStart, dateEnd, periodLabel;
      let allDatesFromHoras = []; // collect from B2B format

      if(dateC&&dateD) {
        dateStart=dateC; dateEnd=dateD;
        const pc=dateC.split("/").map(Number), pd=dateD.split("/").map(Number);
        periodLabel=`${String(pc[0]).padStart(2,"0")}/${String(pc[1]).padStart(2,"0")} a ${String(pd[0]).padStart(2,"0")}/${String(pd[1]).padStart(2,"0")}`;
      }

      const range=XLSX.utils.decode_range(ws["!ref"]||"A1"); const alunos=[];
      for(let r=fmt.dataStartRow;r<=range.e.r;r++) {
        const nv=cellVal(ws,r,cols.nome); if(!nv) continue;
        const nomeStr=String(nv).trim(); if(isExcluded(nomeStr,excSet)) continue;

        // Parse "Horas por Dia" if available (B2B format)
        let tempoMin = 0;
        if(cols.horas_dia!=null) {
          const hd = parseHorasDia(cellVal(ws,r,cols.horas_dia));
          tempoMin = hd.totalMin;
          allDatesFromHoras.push(...hd.dates);
        }

        const h = Math.floor(tempoMin/60), m = tempoMin%60;
        const al={
          nome:titleCase(nomeStr), tempo_min:tempoMin, tempo_str:`${h}h ${m}min`,
          questoes:Math.round(safeFloat(cols.questoes!=null?cellVal(ws,r,cols.questoes):0)),
          flashcards:Math.round(safeFloat(cols.flashcards!=null?cellVal(ws,r,cols.flashcards):0)),
          aulas:Math.round(safeFloat(cols.aulas!=null?cellVal(ws,r,cols.aulas):0)),
          videos:0,
          logins:Math.round(safeFloat(cols.logins!=null?cellVal(ws,r,cols.logins):0)),
          media_q_dia:parseFloat(safeFloat(cols.media_q_dia!=null?cellVal(ws,r,cols.media_q_dia):0).toFixed(1)),
        };
        // Turma: primeiro tenta master-alunos.json, senão coluna da planilha
        const turmaFromMaster = lookupTurma(nomeStr, masterAlunos);
        if(turmaFromMaster) {
          al.turma = turmaFromMaster;
        } else if(cols.turma!=null) {
          const t=cellVal(ws,r,cols.turma);
          if(t) al.turma = String(t).trim();
        }
        alunos.push(al);
      }

      // If dates not found from C2/D2, try to derive from "Horas por Dia"
      if(!dateStart && allDatesFromHoras.length > 0) {
        const parseDMY = d => { const p=d.split("/"); return new Date(+p[2],+p[1]-1,+p[0]); };
        const sorted = [...new Set(allDatesFromHoras)].sort((a,b)=>parseDMY(a)-parseDMY(b));
        dateStart = sorted[0];
        dateEnd = sorted[sorted.length-1];
        const ps=dateStart.split("/"), pe=dateEnd.split("/");
        periodLabel=`${ps[0]}/${ps[1]} a ${pe[0]}/${pe[1]}`;
        log(`  Datas extraídas da coluna "Horas por Dia": ${dateStart} a ${dateEnd}`,"ok");
      } else if(!dateStart && manualDates) {
        dateStart=manualDates.dateStart; dateEnd=manualDates.dateEnd; periodLabel=manualDates.label;
      } else if(!dateStart) {
        dateStart=""; dateEnd=""; periodLabel=sname;
      }

      alunos.sort((a,b)=>b.questoes-a.questoes);
      periods.push({ periodo:periodLabel, dateStart, dateEnd, alunos });
      log(`  ${sname} (${periodLabel}): ${alunos.length} alunos, tempo ${cols.horas_dia!=null?'integrado':'pendente'}`,"ok");
    }
    return periods;
  }

  async function integrateTempo(file, periods, logFn) {
    const log = logFn || (()=>{});
    // Se o tempo já foi integrado pela coluna "Horas por Dia", pular
    const tempoJaIntegrado = periods.length>0 && periods[0].alunos.length>0 && periods[0].alunos.some(a=>a.tempo_min>0);
    if(tempoJaIntegrado) {
      log("Tempo já integrado da planilha B2B.","ok");
      return periods;
    }
    if(!file) { log("Tempo de uso não disponível","warn"); return periods; }
    log("Lendo tempo de uso: "+file.name,"ok");
    const data = await readFile(file); const wb=XLSX.read(data,{type:"array"});
    const valid=new Set(); periods.forEach(p=>p.alunos.forEach(a=>valid.add(norm(a.nome))));
    const tSheets=[];
    for(const sn of wb.SheetNames) {
      const ws=wb.Sheets[sn]; const range=XLSX.utils.decode_range(ws["!ref"]||"A1"); const stu={};
      for(let r=1;r<=range.e.r;r++) {
        const nv=cellVal(ws,r,0); if(!nv) continue; const n=norm(String(nv)); if(!valid.has(n)) continue;
        const tv=cellVal(ws,r,1); stu[n]=typeof tv==="number"?tv:parseHours(tv);
      }
      tSheets.push({name:sn,students:stu}); log(`  '${sn}': ${Object.keys(stu).length} matched`,"ok");
    }
    if(!tSheets.length) return periods;
    const np=periods.length, spp=Math.max(1,Math.floor(tSheets.length/np));
    for(let i=0;i<np;i++) {
      const s=i*spp, e=i<np-1?s+spp:tSheets.length; const agg={};
      for(let j=s;j<e;j++) for(const[n,m] of Object.entries(tSheets[j].students)) agg[n]=(agg[n]||0)+m;
      for(const al of periods[i].alunos) al.tempo_min=Math.round(agg[norm(al.nome)]||0);
    }
    return periods;
  }

  function generateJS(slug, periods, config) {
    const ds=window.INSTITUTION_DATASETS||{}, ex=ds[slug]||{};
    const prefix=slug.toUpperCase().replace(/-/g,"_");
    const name=config.name||ex.institutionName||slug.toUpperCase();
    const pw=config.password||ex.accessPassword||name+"2026";
    const brand=config.brand||ex.brandTitle||name+" × MedCof";
    const ini=config.initials||ex.institutionInitials||name.slice(0,2);
    const logo=config.logo||ex.institutionLogoSrc||"logo_"+slug+".png";
    const theme=config.themeClass||ex.themeClass||"theme-"+slug;
    // Buscar themeHex e logoUrl do Supabase (via _instData) para aplicação síncrona
    const supaInst = (window._instData||[]).find(i => i.slug === slug) || {};
    const themeHex=config.themeHex||ex.themeHex||supaInst.theme_hex||'';
    const logoUrl=config.logoUrl||ex.logoUrl||supaInst.logo_url||'';
    // Preservar dados de simulado existentes (resultsData, benchmark, etc.)
    const results = ex.resultsData&&ex.resultsData.length ? JSON.stringify(ex.resultsData,null,2) : '[]';
    const bench   = ex.benchmark&&Object.keys(ex.benchmark).length ? JSON.stringify(ex.benchmark,null,2) : '{}';
    const areas   = ex.areasData&&ex.areasData.length ? JSON.stringify(ex.areasData,null,2) : '[]';
    const scores  = ex.allSimuladoScores&&ex.allSimuladoScores.length ? JSON.stringify(ex.allSimuladoScores) : '[]';
    const sp      = ex.simuladoPersonalizado||null;
    const lines = [
      `/* === ${name} — dashboard-data.js === */`,
      `/* Gerado via Painel Admin — NÃO editar manualmente */\n`,
      `const ${prefix}_ALL_DATA = ${JSON.stringify(periods,null,2)};\n`,
      `const ${prefix}_RESULTS = ${results};`,
      `const ${prefix}_BENCHMARK = ${bench};`,
      `const ${prefix}_AREAS_DATA = ${areas};`,
      `const ${prefix}_ALL_SCORES = ${scores};\n`,
      `window.INSTITUTION_DATASETS = window.INSTITUTION_DATASETS || {};`,
      `window.DEFAULT_INSTITUTION_KEY = "${slug}";`,
      `window.INSTITUTION_DATASETS["${slug}"] = {`,
      `  key: "${slug}",`,`  accessPassword: "${pw}",`,`  institutionName: "${name}",`,
      `  brandTitle: "${brand}",`,`  institutionInitials: "${ini}",`,
      `  institutionLogoSrc: "${logo}",`,`  themeClass: "${theme}",`,
      `  themeHex: "${themeHex}",`,`  logoUrl: "${logoUrl}",`,
      `  allData: ${prefix}_ALL_DATA,`,`  resultsData: ${prefix}_RESULTS,`,
      `  benchmark: ${prefix}_BENCHMARK,`,`  areasData: ${prefix}_AREAS_DATA,`,
      `  allSimuladoScores: ${prefix}_ALL_SCORES`+(sp?",":""),
    ];
    if(sp) lines.push(`  simuladoPersonalizado: ${JSON.stringify(sp,null,2)}`);
    lines.push("};");
    return lines.join("\n");
  }

  function downloadFile(content,filename,type="text/javascript") {
    const b=new Blob([content],{type}); const u=URL.createObjectURL(b);
    const a=document.createElement("a"); a.href=u; a.download=filename; a.click(); URL.revokeObjectURL(u);
  }

  return { parseSeguimento, integrateTempo, generateJS, downloadFile, dateInputToLabel };
})();
</script>

