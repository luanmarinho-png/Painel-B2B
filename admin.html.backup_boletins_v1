// ── Cálculos estatísticos ──────────────────────────────────────────
window._boletimStats = {
  /** Alfa de Cronbach: α = (k/(k-1)) × (1 - Σσ²ᵢ / σ²total) */
  cronbach: function(allRespostas) {
    if(!allRespostas.length) return null;
    const k = allRespostas[0].length; // nº de questões
    if(k < 2) return null;
    // Matriz binária: cada aluno → array de 0/1
    const matrix = allRespostas.map(r => r.map(q => q.correct ? 1 : 0));
    const n = matrix.length;
    // Variância de cada item
    let sumItemVar = 0;
    for(let j=0; j<k; j++){
      const col = matrix.map(row => row[j]);
      const mean = col.reduce((s,v)=>s+v,0)/n;
      const variance = col.reduce((s,v)=>s+(v-mean)**2,0)/n;
      sumItemVar += variance;
    }
    // Variância do total (soma de acertos por aluno)
    const totals = matrix.map(row => row.reduce((s,v)=>s+v,0));
    const totalMean = totals.reduce((s,v)=>s+v,0)/n;
    const totalVar = totals.reduce((s,v)=>s+(v-totalMean)**2,0)/n;
    if(totalVar === 0) return null;
    return (k/(k-1)) * (1 - sumItemVar/totalVar);
  },

  /** Percentil do aluno na distribuição */
  percentil: function(alunoNota, todasNotas) {
    const sorted = [...todasNotas].sort((a,b)=>a-b);
    const below = sorted.filter(n => n < alunoNota).length;
    return Math.round((below / sorted.length) * 100);
  },

  /** Z-Score */
  zscore: function(alunoNota, media, dp) {
    if(!dp || dp === 0) return 0;
    return (alunoNota - media) / dp;
  },

  /** Quartil (1-4) */
  quartil: function(percentil) {
    if(percentil >= 75) return 4;
    if(percentil >= 50) return 3;
    if(percentil >= 25) return 2;
    return 1;
  },

  /** Índice de discriminação por questão */
  discriminacao: function(allRespostas, qIndex) {
    if(allRespostas.length < 4) return null;
    // Ordenar alunos por nota total (desc)
    const withTotals = allRespostas.map(r => ({
      respostas: r,
      total: r.filter(q=>q.correct).length
    })).sort((a,b) => b.total - a.total);
    const n = withTotals.length;
    const q4Size = Math.max(1, Math.floor(n * 0.27)); // grupo superior ~27%
    const upper = withTotals.slice(0, q4Size);
    const lower = withTotals.slice(n - q4Size);
    const upperPct = upper.filter(a => a.respostas[qIndex]?.correct).length / upper.length;
    const lowerPct = lower.filter(a => a.respostas[qIndex]?.correct).length / lower.length;
    return upperPct - lowerPct; // > 0.3 = boa, > 0.4 = excelente
  },

  /** Label de dificuldade */
  dificuldade: function(mediaPct) {
    if(mediaPct == null) return '—';
    if(mediaPct >= 75) return 'Fácil';
    if(mediaPct >= 50) return 'Média';
    return 'Difícil';
  },

  /** Label de discriminação */
  discLabel: function(disc) {
    if(disc == null) return '—';
    if(disc >= 0.4) return 'Alta';
    if(disc >= 0.2) return 'Média';
    return 'Baixa';
  },

  /** Média e DP de um array */
  mediaDP: function(arr) {
    if(!arr.length) return { media: 0, dp: 0 };
    const media = arr.reduce((s,v)=>s+v,0) / arr.length;
    const dp = Math.sqrt(arr.reduce((s,v)=>s+(v-media)**2,0) / arr.length);
    return { media, dp };
  }
};

// ── Geração de PDF individual ──────────────────────────────────────
window._gerarBoletimPDF = async function(alunoData, allAlunosData, questionsMeta, iesInfo) {
  // Carregar jsPDF se necessário
  const ls = src => new Promise((res,rej)=>{const s=document.createElement('script');s.src=src;s.onload=res;s.onerror=rej;document.head.appendChild(s);});
  if(typeof window.jspdf==='undefined') {
    await ls('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');
    await ls('https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js');
  }
  const jsPDF = window.jspdf?.jsPDF;
  if(!jsPDF) throw new Error('jsPDF não carregado');

  const Stats = window._boletimStats;
  const themeHex = iesInfo.themeHex || '#1B6D85';
  const r = parseInt(themeHex.slice(1,3),16), g = parseInt(themeHex.slice(3,5),16), b = parseInt(themeHex.slice(5,7),16);

  // ── Preparar dados estatísticos ──
  const allRespostas = allAlunosData.map(a => a.respostas);
  const todasNotas = allAlunosData.map(a => a.nota_pct);
  const { media: mediaTurma, dp: dpTurma } = Stats.mediaDP(todasNotas);
  const cronbach = Stats.cronbach(allRespostas);
  const percentil = Stats.percentil(alunoData.nota_pct, todasNotas);
  const zscore = Stats.zscore(alunoData.nota_pct, mediaTurma, dpTurma);
  const quartil = Stats.quartil(percentil);

  // Discriminação por questão
  const discByQ = questionsMeta.map((_, i) => Stats.discriminacao(allRespostas, i));

  // Áreas presentes
  const areaSet = new Set(questionsMeta.map(q=>q.area).filter(Boolean));
  const areas = [...areaSet];

  // % acerto por área (turma)
  const turmaAreaPct = {};
  areas.forEach(area => {
    const qs = questionsMeta.map((q,i)=>({...q,idx:i})).filter(q=>q.area===area);
    if(!qs.length) return;
    const pcts = qs.map(q => {
      const acertos = allRespostas.filter(r => r[q.idx]?.correct).length;
      return (acertos / allRespostas.length) * 100;
    });
    turmaAreaPct[area] = pcts.reduce((s,v)=>s+v,0) / pcts.length;
  });

  // % acerto por área (aluno)
  const alunoAreaPct = alunoData.nota_por_area || {};

  // ══════════════════════════════════════════════════════════════
  // ── GERAR PDF (landscape A4) ──
  // ══════════════════════════════════════════════════════════════
  const doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });
  const W = 297, H = 210;
  const margin = 15;

  // ── Helper: cores ──
  const setTheme = () => doc.setTextColor(r, g, b);
  const setBlack = () => doc.setTextColor(40, 40, 40);
  const setGray  = () => doc.setTextColor(120, 120, 120);

  // ══════ PÁGINA 1: DASHBOARD RESUMO ══════════════════════════════
  // Header
  doc.setFillColor(r, g, b);
  doc.rect(0, 0, W, 2, 'F');

  // Logo MedCof text (simples)
  doc.setFontSize(10); setGray();
  doc.text(iesInfo.nome || 'Instituição', margin, 14);
  doc.setFontSize(8);
  doc.text('× MedCof', margin + doc.getTextWidth((iesInfo.nome||'Instituição')+' '), 14);

  // Título
  doc.setFontSize(16); setTheme(); doc.setFont('helvetica','bold');
  doc.text('Boletim Individual de Desempenho', W/2, 28, { align: 'center' });

  // Dados do aluno
  doc.setFontSize(10); setBlack(); doc.setFont('helvetica','normal');
  const startY = 38;
  doc.text(`Aluno(a): ${alunoData.aluno_nome}`, margin, startY);
  doc.text(`CPF: ${alunoData.aluno_cpf || '—'}`, margin, startY + 6);

  // ── Cards de métricas ──
  const cardY = startY + 14;
  const cardH = 22;
  const cards = [
    { label: 'Média da Turma', value: `${mediaTurma.toFixed(1)}% (±${dpTurma.toFixed(1)})` },
    { label: 'Média do Aluno', value: `${alunoData.nota_pct.toFixed(1)}%` },
    { label: 'Percentil', value: `P${percentil}` },
    { label: 'Alfa de Cronbach', value: cronbach != null ? `α = ${cronbach.toFixed(3)}` : '—' },
    { label: 'Quartil', value: `Q${quartil}` },
  ];
  const cardW = (W - 2*margin - (cards.length-1)*4) / cards.length;
  cards.forEach((c, i) => {
    const cx = margin + i*(cardW+4);
    doc.setFillColor(245, 245, 245);
    doc.roundedRect(cx, cardY, cardW, cardH, 2, 2, 'F');
    doc.setFontSize(7); setGray(); doc.setFont('helvetica','bold');
    doc.text(c.label, cx+3, cardY+7);
    doc.setFontSize(11); setBlack(); doc.setFont('helvetica','bold');
    doc.text(c.value, cx+3, cardY+16);
  });

  // ── Gráfico de barras por área ──
  if(areas.length > 0) {
    const chartY = cardY + cardH + 12;
    doc.setFontSize(10); setTheme(); doc.setFont('helvetica','bold');
    doc.text('% de Acerto por Grande Área: Turma vs Aluno', margin, chartY);

    const barY = chartY + 6;
    const barMaxH = H - barY - 30;
    const groupW = (W - 2*margin) / areas.length;

    areas.forEach((area, i) => {
      const gx = margin + i*groupW + groupW/2;
      const vt = turmaAreaPct[area] || 0;
      const va = alunoAreaPct[area] || 0;
      const barW = Math.min(12, groupW * 0.25);

      // Turma (cinza)
      const ht = (vt/100) * barMaxH;
      doc.setFillColor(150, 150, 150);
      doc.rect(gx - barW - 1, barY + barMaxH - ht, barW, ht, 'F');
      doc.setFontSize(6); setGray();
      doc.text(`${Math.round(vt)}%`, gx - barW, barY + barMaxH - ht - 2, { align: 'center' });

      // Aluno (tema)
      const ha = (va/100) * barMaxH;
      doc.setFillColor(r, g, b);
      doc.rect(gx + 1, barY + barMaxH - ha, barW, ha, 'F');
      doc.setFontSize(6); setTheme();
      doc.text(`${Math.round(va)}%`, gx + barW/2 + 1, barY + barMaxH - ha - 2, { align: 'center' });

      // Label de área
      doc.setFontSize(6); setBlack();
      const short = area.length > 16 ? area.slice(0,15)+'…' : area;
      doc.text(short, gx, barY + barMaxH + 5, { align: 'center' });
    });

    // Legenda
    const legY = H - 12;
    doc.setFillColor(150,150,150); doc.rect(margin, legY, 6, 3, 'F');
    doc.setFontSize(7); setGray(); doc.text('Turma', margin+8, legY+3);
    doc.setFillColor(r,g,b); doc.rect(margin+30, legY, 6, 3, 'F');
    doc.setFontSize(7); setTheme(); doc.text('Aluno', margin+38, legY+3);
  }

  // ══════ PÁGINA 2: TABELA QUESTÃO-A-QUESTÃO ══════════════════════
  doc.addPage('a4','landscape');
  doc.setFillColor(r, g, b); doc.rect(0, 0, W, 2, 'F');

  doc.setFontSize(12); setTheme(); doc.setFont('helvetica','bold');
  doc.text(`Tabela de Respostas — ${alunoData.aluno_nome}`, margin, 14);

  const respostas = alunoData.respostas || [];
  const tableData = respostas.map((q, i) => {
    const disc = discByQ[i];
    return [
      q.q || String(i+1),
      q.area || '—',
      q.tema || '—',
      Stats.dificuldade(q.mediaPct),
      Stats.discLabel(disc),
      q.gab || '—',
      q.resp || '—'
    ];
  });

  const totalCorrect = respostas.filter(q=>q.correct).length;
  const totalPct = respostas.length > 0 ? ((totalCorrect/respostas.length)*100).toFixed(1) : '0';

  doc.autoTable({
    startY: 20,
    head: [['Questão', 'Grande Área', 'Tema', 'Dificuldade', 'Discriminação', 'Gabarito', 'Resposta']],
    body: tableData,
    foot: [['Total', `${respostas.length} questões`, '', '', '', `${totalCorrect} acertos`, `${totalPct}%`]],
    theme: 'grid',
    headStyles: { fillColor: [r,g,b], textColor: 255, fontStyle: 'bold', fontSize: 7 },
    footStyles: { fillColor: [240,240,240], textColor: [40,40,40], fontStyle: 'bold', fontSize: 7 },
    bodyStyles: { fontSize: 6.5 },
    columnStyles: {
      0: { cellWidth: 18 },
      1: { cellWidth: 36 },
      2: { cellWidth: 52 },
      3: { cellWidth: 22 },
      4: { cellWidth: 24 },
      5: { cellWidth: 18 },
      6: { cellWidth: 18 },
    },
    didParseCell: function(data) {
      if(data.section !== 'body') return;
      const qIdx = data.row.index;
      if(qIdx >= 0 && qIdx < respostas.length) {
        if(respostas[qIdx].correct) {
          data.cell.styles.fillColor = [204, 255, 204]; // verde claro
        } else {
          data.cell.styles.fillColor = [255, 204, 204]; // vermelho claro
        }
      }
    },
    margin: { left: margin, right: margin },
  });

  // ══════ PÁGINA 3: RADAR CHART (simplificado como tabela visual) ═
  if(areas.length >= 3) {
    doc.addPage('a4','landscape');
    doc.setFillColor(r,g,b); doc.rect(0,0,W,2,'F');

    doc.setFontSize(12); setTheme(); doc.setFont('helvetica','bold');
    doc.text('Comparativo por Área: Aluno vs Turma', margin, 14);

    const radarData = areas.map(a => [
      a,
      `${(alunoAreaPct[a]||0).toFixed(1)}%`,
      `${(turmaAreaPct[a]||0).toFixed(1)}%`,
      `${((alunoAreaPct[a]||0) - (turmaAreaPct[a]||0)).toFixed(1)}%`
    ]);

    doc.autoTable({
      startY: 22,
      head: [['Grande Área', 'Aluno (%)', 'Turma (%)', 'Diferença']],
      body: radarData,
      theme: 'striped',
      headStyles: { fillColor: [r,g,b], textColor: 255, fontStyle: 'bold', fontSize: 9 },
      bodyStyles: { fontSize: 9 },
      columnStyles: {
        0: { cellWidth: 80 },
        1: { cellWidth: 40, halign: 'center' },
        2: { cellWidth: 40, halign: 'center' },
        3: { cellWidth: 40, halign: 'center' },
      },
      didParseCell: function(data) {
        if(data.section !== 'body' || data.column.index !== 3) return;
        const diff = parseFloat(data.cell.raw);
        if(diff > 0) data.cell.styles.textColor = [34,197,94];
        else if(diff < 0) data.cell.styles.textColor = [220,38,38];
      },
      margin: { left: margin, right: margin },
    });

    // Z-Score e interpretação
    const zy = doc.lastAutoTable.finalY + 15;
    doc.setFontSize(10); setTheme(); doc.setFont('helvetica','bold');
    doc.text('Análise Estatística', margin, zy);

    doc.setFontSize(9); setBlack(); doc.setFont('helvetica','normal');
    const zLabel = zscore > 1 ? 'Muito acima da média' : zscore > 0 ? 'Acima da média' : zscore > -1 ? 'Abaixo da média' : 'Muito abaixo da média';
    doc.text(`Z-Score: ${zscore.toFixed(2)} — ${zLabel}`, margin, zy + 8);
    doc.text(`Percentil: P${percentil} — O aluno teve desempenho superior a ${percentil}% dos colegas`, margin, zy + 16);
    if(cronbach != null) {
      const cLabel = cronbach >= 0.9 ? 'Excelente' : cronbach >= 0.7 ? 'Boa' : cronbach >= 0.5 ? 'Moderada' : 'Baixa';
      doc.text(`Alfa de Cronbach: α = ${cronbach.toFixed(3)} — Confiabilidade ${cLabel} do instrumento`, margin, zy + 24);
    }
    doc.text(`Quartil: Q${quartil} — Classificação no ${quartil}º quartil da distribuição`, margin, zy + 32);
  }

  return doc.output('blob');
};

/**
 * Descompacta registros META + BATCH em dados por aluno para o motor de PDF.
 * @param {Array} records — todos os registros do simulado_respostas para este simRef+ies
 * Retorna { allAlunosData, questionsMeta } prontos para _gerarBoletimPDF.
 */
window._expandBoletimData = function(records) {
  // Encontrar META (questões compartilhadas)
  const metaRec = records.find(r => r.aluno_nome === '__META__');
  const questions = metaRec?.respostas?.questions || [];

  // Juntar todos os BATCH (alunos)
  const allCompact = [];
  records.filter(r => r.aluno_nome?.startsWith('__BATCH_')).forEach(r => {
    const batch = r.respostas?.alunos || [];
    allCompact.push(...batch);
  });

  const allAlunosData = allCompact.map(a => {
    const resps = (a.resps || '').split('');
    const respostas = questions.map((q, i) => {
      const resp = resps[i] || '-';
      const correct = (q.gab && resp === q.gab);
      return { q: q.q, area: q.area, tema: q.tema, gab: q.gab, resp, correct, mediaPct: q.mediaPct };
    });
    return {
      aluno_nome: a.nome,
      aluno_cpf: a.cpf || '',
      respostas,
      nota_pct: a.nota,
      nota_por_area: a.areas || {}
    };
  });

  return { allAlunosData, questionsMeta: questions };
};

// ── Gerar boletim individual (click no botão 📄 da tabela) ──
window._gerarBoletimIndividual = async function(nome, instituicao) {
  try {
    showToast('Gerando boletim...', 'info');
    const sb = getSupabaseClient();
    const inst = (window._instData||[]).find(i => (i.nome||'').toLowerCase() === instituicao.toLowerCase() || i.slug === instituicao.toLowerCase());
    const slug = inst?.slug || instituicao.toLowerCase().replace(/\s+/g,'-');

    // Buscar todos os registros META + BATCH para esta IES
    const { data: allRefs } = await sb.from('simulado_respostas').select('simulado_ref').eq('ies_slug', slug).eq('aluno_nome', '__META__').limit(1);
    if(!allRefs?.length) { showToast('Nenhum simulado com respostas cadastradas para esta IES', 'error'); return; }
    const simRef = allRefs[0].simulado_ref;
    const { data: records } = await sb.from('simulado_respostas').select('*').eq('simulado_ref', simRef).eq('ies_slug', slug);
    if(!records?.length) { showToast('Dados não encontrados', 'error'); return; }

    const { allAlunosData, questionsMeta } = window._expandBoletimData(records);
    const alunoData = allAlunosData.find(a => a.aluno_nome.toLowerCase().trim() === nome.toLowerCase().trim());
    if(!alunoData) { showToast('Aluno não encontrado nos dados do simulado', 'error'); return; }

    const iesInfo = { nome: inst?.nome || slug.toUpperCase(), themeHex: inst?.theme_hex || '#1B6D85', logoUrl: inst?.logo_url || '' };
    const blob = await window._gerarBoletimPDF(alunoData, allAlunosData, questionsMeta, iesInfo);

    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `Boletim_${nome.replace(/[^a-zA-ZÀ-ÿ0-9 ]/g,'_')}.pdf`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('Boletim gerado!', 'success');
  } catch(e) {
    showToast('Erro: ' + e.message, 'error');
    console.error(e);
  }
};

// ── Geração em lote (ZIP) ──
window._generateBoletinsLote = async function() {
  const slug = document.getElementById('boletimIES').value;
  const simRef = document.getElementById('boletimSim').value;
  if(!slug || !simRef) return;

  const btn = document.getElementById('boletimGenBtn');
  const prog = document.getElementById('boletimProgress');
  const bar = document.getElementById('boletimProgressBar');
  const txt = document.getElementById('boletimProgressText');
  btn.disabled = true; btn.textContent = '⏳ Gerando...';
  prog.style.display = 'block'; bar.style.width = '0%';

  try {
    const sb = getSupabaseClient();
    // Buscar todos os registros META + BATCH
    const { data: records, error } = await sb.from('simulado_respostas').select('*').eq('simulado_ref', simRef).eq('ies_slug', slug);
    if(error) throw new Error(error.message);
    if(!records?.length) throw new Error('Nenhum dado encontrado');

    const { allAlunosData, questionsMeta } = window._expandBoletimData(records);
    const inst = (window._instData||[]).find(i => i.slug === slug);
    const iesInfo = { nome: inst?.nome || slug.toUpperCase(), themeHex: inst?.theme_hex || '#1B6D85', logoUrl: inst?.logo_url || '' };

    const zip = new JSZip();
    const total = allAlunosData.length;

    for(let i=0; i<total; i++) {
      const a = allAlunosData[i];
      txt.textContent = `Gerando ${i+1}/${total}: ${a.aluno_nome}`;
      bar.style.width = ((i+1)/total*100).toFixed(0) + '%';

      const blob = await window._gerarBoletimPDF(a, allAlunosData, questionsMeta, iesInfo);
      const safeName = a.aluno_nome.replace(/[^a-zA-ZÀ-ÿ0-9 ]/g,'_').trim();
      zip.file(`${safeName}.pdf`, blob);

      // Yield ao browser a cada 5 PDFs
      if(i % 5 === 0) await new Promise(r => setTimeout(r, 10));
    }

    txt.textContent = '📦 Compactando ZIP...';
    const zipBlob = await zip.generateAsync({ type: 'blob' });
    const url = URL.createObjectURL(zipBlob);
    const a = document.createElement('a');
    a.href = url; a.download = `Boletins_${iesInfo.nome}_${simRef}.zip`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);

    txt.textContent = `✅ ${total} boletins gerados!`;
    bar.style.width = '100%';
    showToast(`${total} boletins gerados e baixados!`, 'success');

  } catch(e) {
    txt.textContent = '❌ Erro: ' + e.message;
    showToast('Erro: ' + e.message, 'error');
    console.error(e);
  } finally {
    btn.disabled = false; btn.innerHTML = '📦 Gerar todos (ZIP)';
  }
};
</script>

<script>
// ── Importação em massa de alunos ────────────────────────────────
window._alunoImportRows = [];

window._openAlunoImportModal = function() {
  window._alunoImportRows = [];
  document.getElementById('alunoImportPreview').style.display = 'none';
  document.getElementById('alunoImportResult').style.display = 'none';
  document.getElementById('alunoImportBtn').disabled = true;
  document.getElementById('alunoImportBtn').style.opacity = '0.5';
  document.getElementById('alunoImportZoneIcon').textContent = '📄';
  document.getElementById('alunoImportZoneTitle').textContent = 'Arraste ou clique para selecionar';
  document.getElementById('alunoImportZoneHint').textContent = 'Colunas esperadas: nome, email, telefone, instituicao (opcional)';
  document.getElementById('alunoImportFile').value = '';
  // Populate IES select
  const sel = document.getElementById('alunoImportIES');
  const opts = (window._instData || []).map(i => `<option value="${i.slug}">${i.nome || i.slug.toUpperCase()}</option>`).join('');
  sel.innerHTML = '<option value="">Selecione a IES...</option>' + opts;
  // Auto-select for non-superadmin
  if (window._curInst) sel.value = window._curInst;
  const modal = document.getElementById('alunoImportModal');
  modal.style.display = 'flex';
  modal.onclick = (e) => { if (e.target === modal) modal.style.display = 'none'; };
};

// Drag-drop support for import zone
(function() {
  const zone = document.getElementById('alunoImportZone');
  if (!zone) return;
  ['dragenter','dragover'].forEach(e => zone.addEventListener(e, ev => { ev.preventDefault(); zone.style.borderColor = 'var(--accent)'; }));
  ['dragleave','drop'].forEach(e => zone.addEventListener(e, ev => { ev.preventDefault(); zone.style.borderColor = 'var(--border)'; }));
  zone.addEventListener('drop', ev => { if (ev.dataTransfer.files[0]) window._handleAlunoImportFile(ev.dataTransfer.files[0]); });
})();

window._handleAlunoImportFile = function(file) {
  if (!file) return;
  document.getElementById('alunoImportZoneIcon').textContent = '✅';
  document.getElementById('alunoImportZoneTitle').textContent = file.name;
  document.getElementById('alunoImportZoneHint').textContent = (file.size / 1024).toFixed(0) + ' KB';
  document.getElementById('alunoImportResult').style.display = 'none';

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      let rows = [];
      if (file.name.endsWith('.csv')) {
        const text = e.target.result;
        const lines = text.split(/\r?\n/).filter(l => l.trim());
        if (lines.length < 2) throw new Error('Planilha vazia');
        const headers = lines[0].split(/[,;\t]/).map(h => h.trim().toLowerCase().replace(/['"]/g,''));
        const colMap = _mapAlunoColumns(headers);
        for (let i = 1; i < lines.length; i++) {
          const cols = lines[i].split(/[,;\t]/).map(c => c.trim().replace(/^["']|["']$/g,''));
          rows.push(_extractAlunoRow(cols, colMap));
        }
      } else {
        const wb = XLSX.read(e.target.result, { type: 'array' });
        const ws = wb.Sheets[wb.SheetNames[0]];
        const json = XLSX.utils.sheet_to_json(ws, { defval: '' });
        if (!json.length) throw new Error('Planilha vazia');
        const headers = Object.keys(json[0]).map(h => h.trim().toLowerCase());
        const colMap = _mapAlunoColumns(headers);
        const origKeys = Object.keys(json[0]);
        json.forEach(row => {
          const vals = origKeys.map(k => String(row[k] || '').trim());
          rows.push(_extractAlunoRow(vals, colMap));
        });
      }
      // Filter invalid (no email)
      rows = rows.filter(r => r.email && r.email.includes('@'));
      window._alunoImportRows = rows;
      _renderAlunoImportPreview(rows);
    } catch(err) {
      document.getElementById('alunoImportResult').style.display = 'block';
      document.getElementById('alunoImportResult').style.background = 'rgba(220,38,38,0.1)';
      document.getElementById('alunoImportResult').style.color = 'var(--accent)';
      document.getElementById('alunoImportResult').textContent = 'Erro ao ler planilha: ' + err.message;
    }
  };
  if (file.name.endsWith('.csv')) reader.readAsText(file);
  else reader.readAsArrayBuffer(file);
};

function _mapAlunoColumns(headers) {
  const map = { nome: -1, email: -1, telefone: -1, instituicao: -1 };
  headers.forEach((h, i) => {
    const l = h.normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase();
    if (l.includes('nome') || l === 'name') map.nome = i;
    else if (l.includes('mail') || l.includes('e-mail')) map.email = i;
    else if (l.includes('tel') || l.includes('phone') || l.includes('celular') || l.includes('whats')) map.telefone = i;
    else if (l.includes('inst') || l.includes('ies') || l.includes('faculdade')) map.instituicao = i;
  });
  return map;
}

function _extractAlunoRow(cols, colMap) {
  return {
    nome: colMap.nome >= 0 ? cols[colMap.nome] || '' : '',
    email: colMap.email >= 0 ? (cols[colMap.email] || '').toLowerCase().trim() : '',
    telefone: colMap.telefone >= 0 ? cols[colMap.telefone] || '' : '',
    instituicao: colMap.instituicao >= 0 ? cols[colMap.instituicao] || '' : '',
  };
}

function _renderAlunoImportPreview(rows) {
  const preview = document.getElementById('alunoImportPreview');
  const tbody = document.getElementById('alunoImportPreviewBody');
  const stats = document.getElementById('alunoImportStats');
  const esc = s => (s||'').replace(/</g,'&lt;');
  preview.style.display = 'block';
  tbody.innerHTML = rows.slice(0, 5).map(r =>
    `<tr><td style="padding:6px 10px">${esc(r.nome)}</td><td style="padding:6px 10px">${esc(r.email)}</td><td style="padding:6px 10px">${esc(r.telefone)}</td><td style="padding:6px 10px">${esc(r.instituicao)}</td></tr>`
  ).join('');
  stats.textContent = `${rows.length} registro(s) encontrado(s) com email válido` + (rows.length > 5 ? ` (mostrando 5)` : '');
  document.getElementById('alunoImportBtn').disabled = rows.length === 0;
  document.getElementById('alunoImportBtn').style.opacity = rows.length === 0 ? '0.5' : '1';
}

window._executeAlunoImport = async function() {
  const rows = window._alunoImportRows;
  if (!rows.length) return;
  const iesOverride = document.getElementById('alunoImportIES').value;
  const btn = document.getElementById('alunoImportBtn');
  const resultEl = document.getElementById('alunoImportResult');
  btn.disabled = true;
  btn.textContent = 'Importando...';
  resultEl.style.display = 'none';

  try {
    const sb = getSupabaseClient();
    // Buscar emails existentes
    const { data: existing } = await sb.from('alunos_master').select('email');
    const existingEmails = new Set((existing || []).map(e => e.email.toLowerCase().trim()));

    let added = 0, dupes = 0, errors = 0;
    const toInsert = [];

    for (const r of rows) {
      const email = r.email.toLowerCase().trim();
      if (existingEmails.has(email)) { dupes++; continue; }
      toInsert.push({
        nome: r.nome || '',
        email: email,
        telefone: r.telefone || '',
        instituicao: iesOverride || r.instituicao || '',
      });
      existingEmails.add(email); // avoid self-duplicates in batch
    }

    if (toInsert.length > 0) {
      // Insert in batches of 500
      for (let i = 0; i < toInsert.length; i += 500) {
        const batch = toInsert.slice(i, i + 500);
        const { error } = await sb.from('alunos_master').insert(batch);
        if (error) { errors += batch.length; console.error('Import error:', error); }
        else added += batch.length;
      }
    }

    const msg = `✅ ${added} adicionado(s), ${dupes} duplicado(s), ${errors} erro(s)`;
    resultEl.style.display = 'block';
    resultEl.style.background = errors > 0 ? 'rgba(245,158,11,0.1)' : 'rgba(34,197,94,0.1)';
    resultEl.style.color = errors > 0 ? 'var(--amber)' : 'var(--green)';
    resultEl.textContent = msg;
    showToast(msg, errors > 0 ? 'info' : 'success');

    // Reload alunos list
    window._alunosLoaded = false;
    if (typeof window._loadAlunosMaster === 'function') window._loadAlunosMaster();

  } catch(e) {
    resultEl.style.display = 'block';
    resultEl.style.background = 'rgba(220,38,38,0.1)';
    resultEl.style.color = 'var(--accent)';
    resultEl.textContent = 'Erro: ' + e.message;
    showToast('Erro na importação: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Importar';
  }
};
</script>

