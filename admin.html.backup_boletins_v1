            }));

            // 1. Limpar registros anteriores (DELETE via REST)
            simLog(logId,`💾 Limpando dados anteriores...`);
            await fetch(`${_SUPA}/simulado_respostas?simulado_ref=eq.${encodeURIComponent(simRef)}&ies_slug=eq.${slug}`, { method: 'DELETE', headers: _hdrs });

            // 2. Inserir META (questões compartilhadas)
            simLog(logId,`💾 Salvando metadados (${compactQuestions.length} questões)...`);
            const metaResp = await fetch(`${_SUPA}/simulado_respostas`, {
              method: 'POST', headers: _hdrs,
              body: JSON.stringify({ simulado_ref: simRef, ies_slug: slug, aluno_nome: '__META__', respostas: { questions: compactQuestions } })
            });
            if(!metaResp.ok) simLog(logId,`⚠️ Erro META: ${metaResp.status}`,"err");

            // 3. Inserir alunos em blocos de BATCH_SIZE
            const totalBatches = Math.ceil(compactAlunos.length / BATCH_SIZE);
            let savedCount = 0;
            for(let i=0; i<totalBatches; i++){
              const batch = compactAlunos.slice(i*BATCH_SIZE, (i+1)*BATCH_SIZE);
              simLog(logId,`💾 Bloco ${i+1}/${totalBatches} (${batch.length} alunos)...`);
              const bResp = await fetch(`${_SUPA}/simulado_respostas`, {
                method: 'POST', headers: _hdrs,
                body: JSON.stringify({ simulado_ref: simRef, ies_slug: slug, aluno_nome: `__BATCH_${i}__`, respostas: { alunos: batch } })
              });
              if(!bResp.ok) simLog(logId,`⚠️ Erro bloco ${i+1}: ${bResp.status}`,"err");
              else savedCount += batch.length;
            }
            simLog(logId,`✅ ${savedCount} boletins salvos em ${totalBatches} blocos — disponíveis na aba Alunos`,"ok");
            if(typeof window._loadBoletimAvailability === 'function') window._loadBoletimAvailability();
          } else {
            simLog(logId,"⚠️ Nenhum aluno com respostas item-a-item detectado","err");
          }
        } else {
          simLog(logId,"ℹ️ Gabarito não encontrado na planilha — boletins item-a-item não gerados");
        }
      } catch(boletimErr) {
        simLog(logId,"⚠️ Extração de boletins falhou (não impede deploy): " + boletimErr.message,"err");
        console.warn("Boletim extraction error:", boletimErr);
      }
      // ══════════════════════════════════════════════════════════════════

      const js=_buildSimTendJS(slug,results,benchmark,allScores,areasData);
      simLog(logId,"✅ Arquivo gerado com sucesso!","ok");

      dlArea.style.display="flex";
      $("btnSimTendDownload").onclick=()=>_downloadZip(slug+"_simulado-tend.zip",slug+"/dashboard-data.js",js);
      $("btnSimTendDeploy").onclick=async()=>{
        const btn=$("btnSimTendDeploy");
        btn.disabled=true; btn.textContent="⏳ Publicando...";
        await window._netlifyDeploy({[`${slug}/dashboard-data.js`]:js},$("simDeployProgTend"),()=>{
          btn.innerHTML="✅ Publicado!"; btn.style.background="var(--green)";
          window._refreshInstGrid?.();
        });
        if(btn.textContent==="⏳ Publicando..."){ btn.disabled=false; btn.innerHTML="🚀 Tentar novamente"; }
      };

    } catch(e){ simLog(logId,"❌ "+e.message,"err"); console.error(e); }
    finally{ $("btnSimTend").disabled=false; }
  });

  // ── Personalizado handler ─────────────────────────────────────
  $("btnSimPers").addEventListener("click", async()=>{
    const logId="simLogPers", dlArea=$("simDownloadPers");
    dlArea.style.display="none"; $("simLogPers").innerHTML="";
    $("btnSimPers").disabled=true;
    try {
      const slug=$("simInst").value;
      simLog(logId,"📂 Lendo planilha do simulado personalizado...");
      const wb=await readExcelFile(simPersFile);
      const ws=wb.Sheets[wb.SheetNames[0]];
      simLog(logId,`📊 Aba: "${wb.SheetNames[0]}"`);

      const rows=wsToRows(ws);
      if(!rows.length) throw new Error("Planilha vazia");
      const hIdx=findHeaderRow(rows,["nome"]);
      const hdr=rows[hIdx];
      simLog(logId,`📋 Cabeçalho: ${hdr.filter(Boolean).slice(0,8).join(" | ")}`);

      const nomeC=findCol(hdr,["nome","aluno"]);
      const notaC=findCol(hdr,["nota","resultado","total","score","% acertos","acertos"]);
      const turmaC=findCol(hdr,["turma","período","semestre"]);
      if(nomeC<0) throw new Error("Coluna 'Nome' não encontrada.");
      if(notaC<0) throw new Error("Coluna de nota não encontrada.");

      // Detect area columns
      const skipCols=new Set([nomeC,notaC,turmaC]);
      const genericKws=["id","#","cpf","email","matrícula","data","rank","ranking","total","acerto","nota","nome","aluno","turma","semestre","período"];
      const areaCols=[];
      hdr.forEach((cell,idx)=>{
        if(skipCols.has(idx)||!cell) return;
        const cl=String(cell).toLowerCase();
        if(cl.length<=2) return;
        if(genericKws.some(g=>cl===g||cl.startsWith(g+":"))) return;
        areaCols.push({idx,label:String(cell).trim()});
      });

      const alunos=[];
      for(let i=hIdx+1;i<rows.length;i++){
        const row=rows[i];
        const nome=String(row[nomeC]||"").trim();
        if(!nome||/^(total|média|media|---)/i.test(nome)) continue;
        const nota=parseFloat(String(row[notaC]||"0").replace(",",".").replace(/[^0-9.]/g,""))||0;
        const turma=turmaC>=0?String(row[turmaC]||"").trim():null;
        const areas={};
        areaCols.forEach(ac=>{
          areas[ac.label]=parseFloat(String(row[ac.idx]||"0").replace(",",".").replace(/[^0-9.]/g,""))||0;
        });
        alunos.push({nome:tc(nome),nota,turma,areas});
      }
      if(!alunos.length) throw new Error("Nenhum aluno encontrado.");
      alunos.sort((a,b)=>b.nota-a.nota);

      const n=alunos.length;
      const mediaIES=alunos.reduce((s,a)=>s+a.nota,0)/n;
      simLog(logId,`👥 ${n} alunos | Média IES: ${mediaIES.toFixed(2)}`,"ok");

      // Distribution
      const bins=["0–9","10–19","20–29","30–39","40–49","50–59","60–69","70–79","80–89","90–100"];
      const bc=new Array(10).fill(0);
      alunos.forEach(a=>{bc[Math.min(Math.floor(a.nota/10),9)]++;});
      const distribuicao=bins.map((faixa,i)=>({faixa,count:bc[i]})).filter(d=>d.count>0);

      // Periodos by turma
      const periodos=[];
      if(turmaC>=0){
        const tm=new Map();
        alunos.forEach(a=>{if(!a.turma)return;if(!tm.has(a.turma))tm.set(a.turma,[]);tm.get(a.turma).push(a.nota);});
        tm.forEach((ns,label)=>{
          const med=ns.reduce((s,v)=>s+v,0)/ns.length;
          periodos.push({label,n:ns.length,media:Math.round(med*10)/10,min:Math.min(...ns),max:Math.max(...ns)});
        });
        periodos.sort((a,b)=>a.label.localeCompare(b.label,"pt-BR"));
      }

      // Areas summary
      const areasTot={};
      areaCols.forEach(ac=>{areasTot[ac.label]=[];});
      alunos.forEach(a=>Object.entries(a.areas||{}).forEach(([label,pct])=>{if(areasTot[label])areasTot[label].push(pct);}));
      const areas=Object.entries(areasTot).map(([label,vals])=>({
        label, pct_unisc:vals.length?Math.round(vals.reduce((s,v)=>s+v,0)/vals.length*10)/10:0
      })).filter(a=>a.pct_unisc>0);

      const ranking=alunos.map((a,i)=>({rank:i+1,nome:a.nome,nota:a.nota,...(a.turma?{turma:a.turma}:{})}));
      const ds=window.INSTITUTION_DATASETS||{}, ex=ds[slug]||{};
      const simPers={
        titulo:`Simulado Personalizado — ${ex.institutionName||slug.toUpperCase()}`,
        subtitulo:`${ex.brandTitle||slug+" × MedCof"} | ${n} alunos`,
        totalAlunos:n, totalQuestoes:0,
        mediaUnisc:Math.round(mediaIES*100)/100, mediaMedcof:0,
        periodos, areas, distribuicao, ranking
      };

      if(areaCols.length) simLog(logId,`📊 ${areaCols.length} áreas: ${areaCols.map(a=>a.label).join(", ")}`,"ok");
      simLog(logId,"✅ Simulado Personalizado gerado!","ok");

      const js=_buildSimPersJS(slug,simPers);
      dlArea.style.display="flex";
      $("btnSimPersDownload").onclick=()=>_downloadZip(slug+"_simulado-pers.zip",slug+"/dashboard-data.js",js);
      $("btnSimPersDeploy").onclick=async()=>{
        const btn=$("btnSimPersDeploy");
        btn.disabled=true; btn.textContent="⏳ Publicando...";
        await window._netlifyDeploy({[`${slug}/dashboard-data.js`]:js},$("simDeployProgPers"),()=>{
          btn.innerHTML="✅ Publicado!"; btn.style.background="var(--green)";
          window._refreshInstGrid?.();
        });
        if(btn.textContent==="⏳ Publicando..."){ btn.disabled=false; btn.innerHTML="🚀 Tentar novamente"; }
      };

    } catch(e){ simLog(logId,"❌ "+e.message,"err"); console.error(e); }
    finally{ $("btnSimPers").disabled=false; }
  });

  // ── JS generators ─────────────────────────────────────────────
  function _instMeta(slug) {
    const ds=window.INSTITUTION_DATASETS||{}, ex=ds[slug]||{};
    const prefix=slug.toUpperCase().replace(/-/g,"_");
    return {ex,prefix,
      name:ex.institutionName||slug.toUpperCase(),
      pw:ex.accessPassword||(ex.institutionName||slug.toUpperCase())+"2026",
      brand:ex.brandTitle||slug+" × MedCof",
      ini:ex.institutionInitials||(ex.institutionName||slug.toUpperCase()).slice(0,2),
      logo:ex.institutionLogoSrc||"logo_"+slug+".png",
      theme:ex.themeClass||"theme-"+slug,
      allData:ex.allData||[]
    };
  }

  function _buildSimTendJS(slug,results,benchmark,allScores,areasData) {
    const {ex,prefix,name,pw,brand,ini,logo,theme,allData}=_instMeta(slug);
    const sp=ex.simuladoPersonalizado||null;
    const areas=areasData&&areasData.length?areasData:[];
    const lines=[
      `/* === ${name} — dashboard-data.js === */`,
      `/* Gerado via Painel Admin — NÃO editar manualmente */\n`,
      `const ${prefix}_ALL_DATA = ${JSON.stringify(allData,null,2)};\n`,
      `const ${prefix}_RESULTS = ${JSON.stringify(results,null,2)};\n`,
      `const ${prefix}_BENCHMARK = ${JSON.stringify(benchmark,null,2)};\n`,
      `const ${prefix}_AREAS_DATA = ${JSON.stringify(areas,null,2)};\n`,
      `const ${prefix}_ALL_SCORES = ${JSON.stringify(allScores)};\n`,
      `window.INSTITUTION_DATASETS = window.INSTITUTION_DATASETS || {};`,
      `window.DEFAULT_INSTITUTION_KEY = "${slug}";`,
      `window.INSTITUTION_DATASETS["${slug}"] = {`,
      `  key: "${slug}",`, `  accessPassword: "${pw}",`, `  institutionName: "${name}",`,
      `  brandTitle: "${brand}",`, `  institutionInitials: "${ini}",`,
      `  institutionLogoSrc: "${logo}",`, `  themeClass: "${theme}",`,
      `  allData: ${prefix}_ALL_DATA,`, `  resultsData: ${prefix}_RESULTS,`,
      `  benchmark: ${prefix}_BENCHMARK,`, `  areasData: ${prefix}_AREAS_DATA,`,
      `  allSimuladoScores: ${prefix}_ALL_SCORES`+(sp?",":""),
    ];
    if(sp) lines.push(`  simuladoPersonalizado: ${JSON.stringify(sp,null,2)}`);
    lines.push("};");
    return lines.join("\n");
  }

  function _buildSimPersJS(slug,simPers) {
    const {ex,prefix,name,pw,brand,ini,logo,theme,allData}=_instMeta(slug);
    const results=ex.resultsData||[], bench=ex.benchmark||{}, allScores=ex.allSimuladoScores||[];
    const lines=[
      `/* === ${name} — dashboard-data.js === */`,
      `/* Gerado via Painel Admin — NÃO editar manualmente */\n`,
      `const ${prefix}_ALL_DATA = ${JSON.stringify(allData,null,2)};\n`,
      `const ${prefix}_RESULTS = ${JSON.stringify(results,null,2)};\n`,
      `const ${prefix}_BENCHMARK = ${JSON.stringify(bench,null,2)};\n`,
      `const ${prefix}_AREAS_DATA = [];\n`,
      `const ${prefix}_ALL_SCORES = ${JSON.stringify(allScores)};\n`,
      `const ${prefix}_SIMULADO_PERSONALIZADO = ${JSON.stringify(simPers,null,2)};\n`,
      `window.INSTITUTION_DATASETS = window.INSTITUTION_DATASETS || {};`,
      `window.DEFAULT_INSTITUTION_KEY = "${slug}";`,
      `window.INSTITUTION_DATASETS["${slug}"] = {`,
      `  key: "${slug}",`, `  accessPassword: "${pw}",`, `  institutionName: "${name}",`,
      `  brandTitle: "${brand}",`, `  institutionInitials: "${ini}",`,
      `  institutionLogoSrc: "${logo}",`, `  themeClass: "${theme}",`,
      `  allData: ${prefix}_ALL_DATA,`, `  resultsData: ${prefix}_RESULTS,`,
      `  benchmark: ${prefix}_BENCHMARK,`, `  areasData: ${prefix}_AREAS_DATA,`,
      `  allSimuladoScores: ${prefix}_ALL_SCORES,`,
      `  simuladoPersonalizado: ${prefix}_SIMULADO_PERSONALIZADO`,
      "};",
    ];
    return lines.join("\n");
  }

  // ── ZIP download helper ────────────────────────────────────────
  function _downloadZip(zipName,filePath,content) {
    const zip=new JSZip();
    zip.file(filePath,content);
    zip.generateAsync({type:"blob"}).then(blob=>{
      const url=URL.createObjectURL(blob);
      const a=document.createElement("a"); a.href=url; a.download=zipName; a.click();
      URL.revokeObjectURL(url);
    });
  }
})();
</script>

<!-- ═══════════ BANCO DE QUESTÕES — LÓGICA PRINCIPAL ═══════════ -->
<script>
/* ──────────────────────────────────────────────────────────────────
   Banco de Questões / Composição de Simulados
   Usa Supabase (tabelas: simulados_banco, simulados_questoes)
   Roles: superadmin → gerencia tudo | admin → envia questões
   ────────────────────────────────────────────────────────────────── */
(function() {
'use strict';

const BQ_SQL = `-- Execute no Supabase → SQL Editor (cole e pressione Run)
-- ⚠️  ATENÇÃO: este script dropa e recria as tabelas.
--     Execute apenas na primeira instalação.
--     Para atualizar tabelas existentes, use o script de MIGRAÇÃO abaixo.

-- ── INSTALAÇÃO COMPLETA ──────────────────────────────────────────────
DROP TABLE IF EXISTS simulados_questoes CASCADE;
DROP TABLE IF EXISTS simulados_banco CASCADE;

CREATE TABLE simulados_banco (
  id                  uuid DEFAULT gen_random_uuid() PRIMARY KEY,
  titulo              text NOT NULL,
  edital_num          text DEFAULT '',
  deadline            timestamptz,
