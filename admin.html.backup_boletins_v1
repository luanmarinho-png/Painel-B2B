          <div style="display:flex;gap:8px;align-items:center">
            <input type="color" id="simPdfCorPicker" value="${cor}" style="width:36px;height:32px;border:none;padding:0;cursor:pointer;border-radius:6px" oninput="document.getElementById('simPdfCorHex').value=this.value">
            <input type="text" id="simPdfCorHex" class="bq-finput" value="${cor}" style="width:100px;padding:6px 10px;font-family:monospace;font-size:0.78rem" oninput="if(/^#[0-9a-fA-F]{6}$/.test(this.value)){document.getElementById('simPdfCorPicker').value=this.value;this.style.borderColor=''}else{this.style.borderColor='var(--accent)'}">
          </div>
