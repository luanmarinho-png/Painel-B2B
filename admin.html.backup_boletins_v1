<script>
(() => {
  const $ = (id) => document.getElementById(id);
  const overlay = $("loginOverlay"), dashboard = $("dashboard");

  function showDashboard(email) {
    overlay.classList.add("hidden");
    dashboard.classList.add("visible");
    if (email) $("topbarUser").textContent = email;
  }

  function showLogin() {
    overlay.classList.remove("hidden");
    dashboard.classList.remove("visible");
    $("loginUser").value = ""; $("loginPass").value = ""; $("loginError").textContent = "";
    requestAnimationFrame(() => $("loginUser").focus());
  }

  async function tryLogin() {
    const email = $("loginUser").value.trim();
    const password = $("loginPass").value.trim();
    if (!email || !password) { $("loginError").textContent = "Preencha e-mail e senha."; return; }

    $("loginBtn").disabled = true;
    $("loginBtn").textContent = "Entrando...";
    $("loginError").textContent = "";

    try {
      const sb = getSupabaseClient();
      const { data, error } = await sb.auth.signInWithPassword({ email, password });

      if (error) {
        $("loginError").textContent = "E-mail ou senha incorretos.";
        $("loginPass").select();
        return;
      }

      const role = data.user.user_metadata?.role;
      if (role !== 'admin' && role !== 'superadmin') {
        await sb.auth.signOut();
        $("loginError").textContent = "Acesso não autorizado para este painel.";
        return;
      }

      showDashboard(data.user.email);
    } catch(e) {
      $("loginError").textContent = "Erro ao conectar. Tente novamente.";
    } finally {
      $("loginBtn").disabled = false;
      $("loginBtn").textContent = "Entrar";
    }
  }

  // Se vier com token de recovery no hash, ir para nova-senha.html antes de qualquer coisa
  (function() {
    const hash = window.location.hash.slice(1);
    if (!hash) return;
    const params = new URLSearchParams(hash);
    if (params.get('type') === 'recovery') {
      window.location.replace('/nova-senha.html' + window.location.hash);
    }
  })();

  // Verificar sessão existente ao carregar
  (async () => {
    const sb = getSupabaseClient();
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      const role = session.user.user_metadata?.role;
      if (role === 'admin' || role === 'superadmin') {
        showDashboard(session.user.email);
        return;
      }
    }
    requestAnimationFrame(() => $("loginUser").focus());
  })();

  $("loginBtn").addEventListener("click", tryLogin);
  $("loginPass").addEventListener("keydown", e => { if (e.key === "Enter") tryLogin(); });
  $("loginUser").addEventListener("keydown", e => { if (e.key === "Enter") $("loginPass").focus(); });
  $("logoutBtn").addEventListener("click", () => medcofLogout('/admin.html'));

  document.querySelectorAll(".inst-card").forEach(card => {
    card.addEventListener("click", () => {
      const slug = (card.getAttribute("href") || "").split("/")[0];
      localStorage.setItem("medcof_admin_bypass", "true");
      sessionStorage.setItem("medcof_admin_bypass", "true");
      sessionStorage.setItem("medcof_panel_access", "granted");
      sessionStorage.setItem("medcof_institution_key", slug);
    });
  });

  document.querySelectorAll(".dash-tab").forEach(tab => {
    tab.addEventListener("click", () => {
      document.querySelectorAll(".dash-tab").forEach(t => t.classList.remove("active"));
      document.querySelectorAll(".tab-panel").forEach(p => p.classList.remove("active"));
      tab.classList.add("active");
      $("tab-" + tab.dataset.tab).classList.add("active");
    });
  });
})();
</script>

