        ${a.descricao ? `<div style="font-size:0.82rem;color:var(--text);line-height:1.5">${a.descricao}</div>` : ''}
        ${a.registrado_por ? `<div style="font-size:0.7rem;color:var(--text-muted);margin-top:6px">Registrado por: ${a.registrado_por}</div>` : ''}
      </div>`;
    }).join('');
  } catch(e) {
    listEl.innerHTML = `<div style="text-align:center;padding:20px;color:var(--accent);font-size:0.82rem">Erro: ${e.message}</div>`;
  }
};

window._savePvAtiv = async function() {
  const btn = document.getElementById('pvSaveBtn');
  const errEl = document.getElementById('pvSaveError');
  const tipo = document.getElementById('pvTipo').value;
  const data = document.getElementById('pvData').value;
  const participantes = document.getElementById('pvParticipantes').value.trim();
  const descricao = document.getElementById('pvDescricao').value.trim();
  const proximoContato = document.getElementById('pvProximoContato').value || null;

  errEl.textContent = '';
  if (!data) { errEl.textContent = 'Informe a data.'; return; }

  btn.disabled = true; btn.textContent = 'Registrando...';
  try {
    const sb = getSupabaseClient();
    const { data: { user } } = await sb.auth.getUser();
    const { error } = await sb.from('atividades_contrato').insert({
      ies_slug: window._pvCurrentSlug,
      tipo,
      data,
      participantes,
      descricao,
      proximo_contato: proximoContato,
      registrado_por: user?.email || 'admin',
    });
    if (error) throw new Error(error.message);
    // Reset form
    document.getElementById('pvDescricao').value = '';
    document.getElementById('pvParticipantes').value = '';
    document.getElementById('pvProximoContato').value = '';
    showToast('Atividade registrada!', 'success');
    await window._loadPvAtividades(window._pvCurrentSlug);
    // Atualizar contador no card
    if (window._atividadeCountMap) {
      const slug = window._pvCurrentSlug;
      window._atividadeCountMap[slug] = (window._atividadeCountMap[slug] || 0) + 1;
      if (typeof _populateAtivCount === 'function') _populateAtivCount();
    }
  } catch(e) {
    errEl.textContent = e.message;
  } finally {
    btn.disabled = false; btn.textContent = 'Registrar';
  }
};

window._deletePvAtiv = async function(id) {
  if (!confirm('Remover esta atividade?')) return;
  try {
    const sb = getSupabaseClient();
    const { error } = await sb.from('atividades_contrato').delete().eq('id', id);
    if (error) throw new Error(error.message);
    await window._loadPvAtividades(window._pvCurrentSlug);
    // Atualizar contador no card
    if (window._atividadeCountMap) {
      const slug = window._pvCurrentSlug;
      if (window._atividadeCountMap[slug] > 0) window._atividadeCountMap[slug]--;
      if (typeof _populateAtivCount === 'function') _populateAtivCount();
    }
    showToast('Atividade removida.', 'info');
  } catch(e) {
    showToast('Erro: ' + e.message, 'error');
  }
};
</script>

