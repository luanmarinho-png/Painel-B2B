  pdf_cor            text DEFAULT '',
  criado_por          text DEFAULT '',
  created_at          timestamptz DEFAULT now()
);

CREATE TABLE simulados_questoes (
  id                 uuid DEFAULT gen_random_uuid() PRIMARY KEY,
  simulado_id        uuid REFERENCES simulados_banco(id) ON DELETE CASCADE,
  codigo_questao     text DEFAULT '',
  instituicao        text NOT NULL DEFAULT '',
  submetido_por      text NOT NULL DEFAULT '',
  grande_area        text NOT NULL DEFAULT '',
  enunciado          text NOT NULL DEFAULT '',
  gabarito           char(1) NOT NULL DEFAULT 'A',
  dificuldade        text DEFAULT 'media',
  taxa_acerto        numeric DEFAULT 0,
  tema               text DEFAULT '',
  instituicao_questao text DEFAULT '',
  tipo_prova         text DEFAULT '',
  ano_prova          text DEFAULT '',
  prioridade         text DEFAULT 'verde',
  status             text DEFAULT 'pendente',
  revisor_comentario text DEFAULT '',
  revisado_por       text DEFAULT '',
  revisado_at        timestamptz,
  created_at         timestamptz DEFAULT now()
);

ALTER TABLE simulados_banco   ENABLE ROW LEVEL SECURITY;
ALTER TABLE simulados_questoes ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS bq_all    ON simulados_banco;
DROP POLICY IF EXISTS bq_q_all  ON simulados_questoes;
DROP POLICY IF EXISTS bq_auth   ON simulados_banco;
DROP POLICY IF EXISTS bq_q_auth ON simulados_questoes;
CREATE POLICY bq_all    ON simulados_banco    FOR ALL TO anon          USING (true) WITH CHECK (true);
CREATE POLICY bq_q_all  ON simulados_questoes FOR ALL TO anon          USING (true) WITH CHECK (true);
CREATE POLICY bq_auth   ON simulados_banco    FOR ALL TO authenticated USING (true) WITH CHECK (true);
CREATE POLICY bq_q_auth ON simulados_questoes FOR ALL TO authenticated USING (true) WITH CHECK (true);

-- ── MIGRAÇÃO (tabelas já existem — rode apenas as linhas abaixo) ─────
-- ALTER TABLE simulados_banco    ADD COLUMN IF NOT EXISTS instituicoes_destino jsonb DEFAULT '[]'::jsonb;
-- ALTER TABLE simulados_banco    ADD COLUMN IF NOT EXISTS pdf_instituicao text DEFAULT '';
-- ALTER TABLE simulados_banco    ADD COLUMN IF NOT EXISTS pdf_cor text DEFAULT '';
-- ALTER TABLE simulados_questoes ADD COLUMN IF NOT EXISTS codigo_questao text DEFAULT '';
`;

const GRANDES_AREAS = [
  'Clínica Médica','Cirurgia Geral','Ginecologia e Obstetrícia',
  'Pediatria','Saúde Coletiva','Preventiva e Social','Medicina Legal e Bioética'
];

// Populate SQL box immediately
const sqlEl = document.getElementById('bqSqlCode');
if (sqlEl) sqlEl.textContent = BQ_SQL;

window.bqCopySql = function() {
  navigator.clipboard.writeText(BQ_SQL)
    .then(() => alert('SQL copiado! Cole no Supabase → SQL Editor e clique em Run.'))
    .catch(() => { prompt('Copie o SQL abaixo:', BQ_SQL); });
};

// ── State ──────────────────────────────────────────────────────────
let _sb, _curEmail, _curRole, _curInst, _isSuperadmin;
let _sims = [], _qs = [], _editingQId = null, _composeSimId = null;
let _bqReady = false;

function $b(id) { return document.getElementById(id); }
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function difLabel(d) {
  return d==='facil' ? '<span style="color:var(--green);font-size:0.73rem">▼ Fácil</span>'
       : d==='dificil' ? '<span style="color:var(--accent);font-size:0.73rem">▲ Difícil</span>'
       : '<span style="color:var(--amber);font-size:0.73rem">◆ Média</span>';
}
function badge(status) {
  const m = {
    aberto:   { cls:'bq-badge-aberto',   label:'● Aberto' },
    compondo: { cls:'bq-badge-compondo', label:'◑ Compondo' },
    fechado:  { cls:'bq-badge-fechado',  label:'✓ Fechado' }
  };
  return m[status] || m.aberto;
}
function parseArr(v) {
  if (Array.isArray(v)) return v;
  try { return JSON.parse(v||'[]'); } catch { return []; }
}
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('pt-BR') : '—'; }

// ── Bootstrap (on auth state change) ─────────────────────────────
const sb0 = getSupabaseClient();
sb0.auth.onAuthStateChange(async (event, session) => {
  if (!session) return;
  if (_bqReady) return; // already initialized
  _bqReady = true;
  _sb = getSupabaseClient();
  _curEmail      = session.user.email;
  _curRole       = session.user.user_metadata?.role || 'admin';
  _curInst       = session.user.user_metadata?.instituicao || '';
  _isSuperadmin  = _curRole === 'superadmin';
  await bqInit();
});

// Also try immediately (page already has session)
(async function() {
  const { data: { session } } = await sb0.auth.getSession();
  if (session && !_bqReady) {
    _bqReady = true;
    _sb = getSupabaseClient();
    _curEmail      = session.user.email;
    _curRole       = session.user.user_metadata?.role || 'admin';
    _curInst       = session.user.user_metadata?.instituicao || '';
    _isSuperadmin  = _curRole === 'superadmin';
    await bqInit();
  }
})();

// ── Core init: load data and render ──────────────────────────────
async function bqInit() {
  showEl('bqLoading', true);
  showEl('bqContent', false);
  if ($b('bqSetupAlert')) $b('bqSetupAlert').style.display = 'none';

  if (_isSuperadmin || _curRole === 'admin') {
    showEl('bqPanelSuperadmin', true, 'block');
    showEl('bqPanelCompose', true, 'block');
  }
  if (_isSuperadmin) {
    showEl('bqPanelReview', true, 'block');
    document.body.classList.add('is-superadmin');
  }

  // Load simulados
  const { data: sims, error: simErr } = await _sb
    .from('simulados_banco')
    .select('*')
    .order('created_at', { ascending: false });

  if (simErr) {
    showEl('bqLoading', false);
    const isTableMissing = simErr.message && (
      simErr.message.includes('does not exist') ||
      simErr.message.includes('Could not find') ||
      simErr.message.includes('schema cache') ||
      simErr.code === '42P01' || simErr.code === 'PGRST204'
    );
    if (isTableMissing) {
      if ($b('bqSetupAlert')) $b('bqSetupAlert').style.display = 'block';
      if ($b('bqSqlBox')) $b('bqSqlBox').style.display = 'block';
    } else {
      if ($b('bqLoading')) $b('bqLoading').innerHTML = '❌ Erro ao carregar banco de questões: ' + esc(simErr.message);
      showEl('bqLoading', true);
    }
    return;
  }

  _sims = sims || [];

  // Load questions
  let qq = _sb.from('simulados_questoes').select('*').order('created_at', { ascending: false });
  if (!_isSuperadmin) qq = qq.eq('instituicao', _curInst);
  const { data: qs } = await qq;
  _qs = qs || [];

  showEl('bqLoading', false);
  showEl('bqContent', true, 'block');
  renderAll();
}

function showEl(id, show, displayType) {
  const el = $b(id); if (!el) return;
  el.style.display = show ? (displayType || 'block') : 'none';
}

// ── Render all panels ─────────────────────────────────────────────
function renderAll() {
  populateSelectors();
  renderSimListAdmin();
  renderSimListOpen();
  renderMinhasQ();
  if (_isSuperadmin) renderReview();
}

function populateSelectors() {
  ['bqFilterSimulado','bqRevSimFilter'].forEach(id => {
    const el = $b(id); if (!el) return;
    const cur = el.value;
    el.innerHTML = '<option value="">Todos os simulados</option>';
    _sims.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s.id; opt.textContent = s.titulo;
      if (s.id === cur) opt.selected = true;
      el.appendChild(opt);
    });
  });
  // Populate area filters
  ['bqFilterArea','bqRevAreaFilter'].forEach(id => {
    const el = $b(id); if (!el) return;
    const cur = el.value;
    el.innerHTML = '<option value="">Todas as áreas</option>';
    GRANDES_AREAS.forEach(a => {
      const opt = document.createElement('option');
      opt.value = a; opt.textContent = a;
      if (a === cur) opt.selected = true;
      el.appendChild(opt);
    });
    // Add areas from questions that aren't in GRANDES_AREAS
    const extras = [...new Set(_qs.map(q => q.grande_area).filter(a => a && !GRANDES_AREAS.includes(a)))].sort();
    extras.forEach(a => {
      const opt = document.createElement('option');
      opt.value = a; opt.textContent = a;
      if (a === cur) opt.selected = true;
      el.appendChild(opt);
    });
  });
}

