  window.scrollTo({ top: 0, behavior: 'smooth' });
};

// ── Collapsible sections ─────────────────────────────────────
function toggleCollapse(id, el) {
  const b = document.getElementById(id);
  if (!b) return;
  const isHidden = b.style.display === 'none';
  b.style.display = isHidden ? 'block' : 'none';
  const chev = el.querySelector('.collapse-chev');
  if (chev) chev.textContent = isHidden ? '▲' : '▼';
}

// ── Toast global ─────────────────────────────────────────────
function showToast(msg, type = 'success') {
  const t = document.createElement('div');
  t.className = 'toast toast-' + type;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => { t.classList.add('toast-out'); setTimeout(() => t.remove(), 300); }, 4000);
}

// ── Modal de configuração de IES ─────────────────────────────
let _instSettingsSlug = null;
let _instSettingsLogoFile = null;

// Mapeamento de temas para hex (consistente com THEME_MAP do cadastro)
const SETTINGS_THEME_HEX = {
  neutro: '#6b7280', azul: '#1B6D85', verde: '#22c55e', roxo: '#7c3aed',
  vermelho: '#dc2626', ciano: '#06b6d4', rosa: '#ec4899', laranja: '#f97316', amarelo: '#eab308'
};

function openInstSettings(slug) {
  _instSettingsSlug = slug;
  _instSettingsLogoFile = null;
  const inst = (window._instData || []).find(i => i.slug === slug) || {};
  document.getElementById('instSettingsTitle').textContent = 'Configurações: ' + (inst.nome || slug.toUpperCase());
  document.getElementById('instSettingsNome').value = inst.nome || slug.toUpperCase();
  document.getElementById('instSettingsCidade').value = inst.cidade || '';
  const hex = inst.theme_hex || '#1B6D85';
  document.getElementById('instSettingsColor').value = hex;
  document.getElementById('instSettingsColorHex').value = hex;
  document.getElementById('instSettingsStripePreview').style.background = hex;
  // WIP toggle
  document.getElementById('instSettingsAtivo').checked = !inst.wip;
  // Quick theme buttons active state
  _updateThemeQuickActive(hex);
  const logoUrl = inst.logo_url || slug + '/logo_' + slug + '.png';
  document.getElementById('instSettingsLogoPreview').src = logoUrl;
  document.getElementById('instSettingsLogoFile').value = '';
  document.getElementById('instSettingsError').textContent = '';
  // Reset save button
  const btn = document.getElementById('instSettingsSaveBtn');
  btn.disabled = false; btn.textContent = 'Salvar';
  const modal = document.getElementById('instSettingsModal');
  modal.style.display = 'flex';
  modal.onclick = (e) => { if (e.target === modal) closeInstSettings(); };
}

function _updateThemeQuickActive(hex) {
  document.querySelectorAll('#themeQuickBtns .theme-quick-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.hex.toLowerCase() === hex.toLowerCase());
  });
}

function closeInstSettings() {
  document.getElementById('instSettingsModal').style.display = 'none';
  _instSettingsSlug = null;
  _instSettingsLogoFile = null;
}

function previewInstLogo(input) {
  if (input.files && input.files[0]) {
    _instSettingsLogoFile = input.files[0];
    const reader = new FileReader();
    reader.onload = (e) => { document.getElementById('instSettingsLogoPreview').src = e.target.result; };
    reader.readAsDataURL(input.files[0]);
  }
}

function syncColorFromHex(hex) {
  if (/^#[0-9a-fA-F]{6}$/.test(hex)) {
    document.getElementById('instSettingsColor').value = hex;
    document.getElementById('instSettingsStripePreview').style.background = hex;
    _updateThemeQuickActive(hex);
  }
}

// Color picker → hex input + preview
document.getElementById('instSettingsColor').addEventListener('input', function() {
  document.getElementById('instSettingsColorHex').value = this.value;
  document.getElementById('instSettingsStripePreview').style.background = this.value;
  _updateThemeQuickActive(this.value);
});

// Quick theme buttons
document.getElementById('themeQuickBtns').addEventListener('click', function(e) {
  const btn = e.target.closest('.theme-quick-btn');
  if (!btn) return;
  const hex = btn.dataset.hex;
  document.getElementById('instSettingsColor').value = hex;
  document.getElementById('instSettingsColorHex').value = hex;
  document.getElementById('instSettingsStripePreview').style.background = hex;
  _updateThemeQuickActive(hex);
});

async function saveInstSettings() {
  const slug = _instSettingsSlug;
  if (!slug) return;
  const btn = document.getElementById('instSettingsSaveBtn');
  const errEl = document.getElementById('instSettingsError');
  btn.disabled = true;
  btn.innerHTML = '<span style="display:inline-flex;align-items:center;gap:6px"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Salvando...</span>';
  errEl.textContent = '';

  try {
    const sb = getSupabaseClient();
    const updates = {
      nome: document.getElementById('instSettingsNome').value.trim() || slug.toUpperCase(),
      cidade: document.getElementById('instSettingsCidade').value.trim(),
      theme_hex: document.getElementById('instSettingsColorHex').value.trim() || null,
      wip: !document.getElementById('instSettingsAtivo').checked,
    };

    // Upload logo se selecionado
    if (_instSettingsLogoFile) {
      const ext = _instSettingsLogoFile.name.split('.').pop().toLowerCase() || 'png';
      const filePath = slug + '.' + ext;
      const { data: upData, error: upErr } = await sb.storage
        .from('logos')
        .upload(filePath, _instSettingsLogoFile, { upsert: true, contentType: _instSettingsLogoFile.type });
      if (upErr) throw new Error('Erro ao enviar logo: ' + upErr.message);
      updates.logo_url = 'https://cvwwucxjrpsfoxarsipr.supabase.co/storage/v1/object/public/logos/' + filePath;
    }

    // Update na tabela
    const { error: dbErr } = await sb
      .from('instituicoes')
      .update(updates)
      .eq('slug', slug);
    if (dbErr) throw new Error('Erro ao salvar: ' + dbErr.message);

    closeInstSettings();
    showToast('Configurações salvas com sucesso!', 'success');
    // Recarregar grid
    await loadAndRenderInstitutions();
    if (typeof window._refreshInstGrid === 'function') window._refreshInstGrid();

  } catch (e) {
    errEl.textContent = e.message;
    showToast('Erro: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Salvar';
  }
}

