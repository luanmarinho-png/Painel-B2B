        ${thisMonthTotal > 0 && !isMonthFilter ? `<button onclick="populateSimContratados(true)" style="margin-left:auto;padding:4px 11px;border-radius:6px;border:1px solid rgba(245,158,11,0.35);background:rgba(245,158,11,0.10);color:#f59e0b;font-size:0.71rem;font-weight:700;cursor:pointer;flex-shrink:0">Ver só este mês →</button>` : ''}
