        } catch(e) { console.warn("Não foi possível atualizar admin.html:", e); }
        await window._netlifyDeploy(deployFiles, deployProg, (data) => {
          deployBtn.innerHTML='✅ Publicado com sucesso!';
          deployBtn.style.background='var(--green)';
