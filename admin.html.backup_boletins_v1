  const fmtDate   = d => d ? new Date(d + 'T12:00:00').toLocaleDateString('pt-BR') : '—';
  const chk = (v, label) => v
    ? `<span style="color:var(--green);font-weight:600">☑ ${label}</span>`
    : `<span style="color:var(--text-muted)">☐ ${label}</span>`;
  const isSimThisMonth = (s, iesEnvios) => {
    const env = iesEnvios.find(e => e.simulado_id === s.id);
    if (!env?.data_simulado) return false;
    const d = new Date(env.data_simulado + 'T12:00:00');
    return d.getMonth() === thisMonth && d.getFullYear() === thisYear;
  };

  // Pré-calcular dados por instituição
  const instWithCounts = instData.map(inst => {
    const slug = inst.slug;
    const linked = sims.filter(s => {
      const dest = s.instituicoes_destino;
      if (!dest) return false;
