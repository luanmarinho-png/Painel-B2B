      const deployBtn = document.createElement("button");
      deployBtn.className="btn-deploy"; deployBtn.style.cssText="padding:10px 22px;font-size:0.88rem";
      deployBtn.innerHTML='🚀 Fazer deploy automático';
      deployBtn.addEventListener("click", async () => {
        deployBtn.disabled=true; deployBtn.textContent="⏳ Publicando...";
        // Montar mapa de arquivos para o deploy
        const deployFiles = {};
        files.forEach(f => { deployFiles[f.name] = f.content; });
        if (sharedJS)  deployFiles[`${slug}/shared.js`]            = sharedJS;
        if (sharedCSS) deployFiles[`${slug}/shared.css`]           = sharedCSS;
        if (logoMedcof) deployFiles[`${slug}/logo-novo-medcof.avif`] = logoMedcof;
        if (regLogoFile) {
          const logoAB = await new Promise((res,rej)=>{const r=new FileReader();r.onload=e=>res(e.target.result);r.onerror=rej;r.readAsArrayBuffer(regLogoFile);});
          deployFiles[`${slug}/${logo}`] = logoAB;
        }
        // Inject new card into admin.html automatically
        try {
          const adminResp = await fetch("/admin.html");
          if (adminResp.ok) {
            const adminText = await adminResp.text();
            const injected = injectIntoAdminHTML(adminText, true);
            if (injected) deployFiles["admin.html"] = injected;
