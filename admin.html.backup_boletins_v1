  .settings-toggle input[type="checkbox"] {
    width: 18px; height: 18px; accent-color: var(--green);
    cursor: pointer; flex-shrink: 0;
  }
  .settings-toggle span { font-size: 0.88rem; color: var(--text); }

  /* ── Quick theme buttons ── */
  .theme-quick-btns { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
  .theme-quick-btn {
    padding: 5px 12px; border-radius: 8px; border: 1.5px solid var(--border);
    background: var(--bg-elevated); color: var(--text-soft); font-size: 0.75rem;
    font-weight: 600; cursor: pointer; transition: all 0.2s; text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .theme-quick-btn:hover { border-color: var(--text); color: var(--text); }
  .theme-quick-btn.active { border-color: var(--accent); color: var(--accent); background: var(--accent-soft); }

  /* ── Stripe preview in modal ── */
  .settings-stripe-preview {
    height: 6px; border-radius: 3px; margin-top: 8px; transition: background 0.3s;
  }
</style>
</head>
<body>

<!-- ═══════════ LOGIN ═══════════ -->
<div class="login-overlay" id="loginOverlay">
  <div class="login-bg-grid"></div>
  <div class="login-bg-glow"></div>
  <div class="login-card">
    <img src="facene/logo-novo-medcof.avif" alt="MedCof" class="login-logo" onerror="this.style.display='none'">
    <span class="login-badge">Painel Administrativo B2B</span>
    <h2 class="login-title">Acesso restrito</h2>
    <p class="login-subtitle">Credenciais exclusivas para gestores MedCof.</p>
    <div class="login-field"><label for="loginUser">E-mail</label><input id="loginUser" type="email" placeholder="Seu e-mail" autocomplete="username"></div>
