// ── Embaralhamento por área (round-robin interleave) ─────────────
// Garante que questões de áreas diferentes se alternam no simulado final.
// Ex: CM→CG→GO→CM→CG→GO... em vez de CM×20 depois CG×20.
function _interleaveByArea(selectedIds) {
  // Map each id to its question object
  const qMap = {};
  _qs.forEach(q => { qMap[q.id] = q; });

  // Group by grande_area
  const byArea = {};
  selectedIds.forEach(id => {
    const q = qMap[id];
    if (!q) return;
    const area = q.grande_area || 'Sem área';
    if (!byArea[area]) byArea[area] = [];
    byArea[area].push(id);
  });

  // Shuffle within each area (Fisher-Yates)
  const shuffle = arr => {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  };

  // Build columns and shuffle column order
  const groups = Object.values(byArea).map(shuffle);
  shuffle(groups);

  // Round-robin interleave
  const result = [];
  const maxLen = Math.max(...groups.map(g => g.length), 0);
  for (let i = 0; i < maxLen; i++) {
    for (const g of groups) {
      if (i < g.length) result.push(g[i]);
    }
  }
  return result;
}

window.bqSaveCompose = async function() {
  if (!_composeSimId) return;
  const rawSelected = [...document.querySelectorAll('.bq-comp-q-item.bq-sel input[type=checkbox]')].map(c => c.dataset.qid);
  const interleaved = _interleaveByArea(rawSelected);
  const { error } = await _sb.from('simulados_banco').update({ composicao_final: interleaved }).eq('id', _composeSimId);
  if (error) { alert('Erro ao salvar: ' + error.message); return; }

  // Show breakdown by area
  const qMap = {}; _qs.forEach(q => { qMap[q.id] = q; });
  const areas = [...new Set(interleaved.map(id => qMap[id]?.grande_area).filter(Boolean))];
  const breakdown = areas.map(a => `  • ${a}: ${interleaved.filter(id => qMap[id]?.grande_area === a).length}`).join('\n');
  alert(`✅ Composição salva com embaralhamento por área!\n\n${interleaved.length} questão(ões) no total:\n${breakdown}`);
  await bqInit();
};

// ── Fechar simulado + gerar PDF ───────────────────────────────────
window.bqCloseSim = async function(simId) {
  if (!confirm('Fechar o simulado?\n\nAs questões serão embaralhadas por área e nenhuma nova questão poderá ser enviada após o fechamento.')) return;

  // Tenta pegar seleção do painel de composição (se estiver aberto)
  const rawItems = [...document.querySelectorAll('.bq-comp-q-item.bq-sel input[type=checkbox]')].map(c => c.dataset.qid);
  let interleaved = rawItems.length ? _interleaveByArea(rawItems) : [];

  // Se o painel não está aberto ou nada foi selecionado, usa todas aprovadas do banco
  if (!interleaved.length) {
    const { data: qs } = await _sb.from('simulados_questoes').select('id,grande_area,status').eq('simulado_id', simId);
    const aprovadas = (qs||[]).filter(q => q.status === 'aprovada');
    if (!aprovadas.length) { alert('Nenhuma questão aprovada neste simulado para compor.'); return; }
    interleaved = _interleaveByArea(aprovadas.map(q => q.id));
  }

  const { error } = await _sb.from('simulados_banco').update({ status: 'fechado', composicao_final: interleaved }).eq('id', simId);
  if (error) { alert('Erro: ' + error.message); return; }
  await bqInit();
  window.bqGerarPDF(simId);
};

// ── PDF Report (formato relatório analítico ENAMED) ───────────────
window.bqGerarPDF = async function(simId) {
  const sim = _sims.find(s => s.id === simId);
  if (!sim) { alert('Simulado não encontrado. Recarregue a página.'); return; }

  const { data: qs } = await _sb.from('simulados_questoes').select('*').eq('simulado_id', simId);
  if (!qs || !qs.length) { alert('Nenhuma questão encontrada.'); return; }

  let comp = parseArr(sim.composicao_final);

  // Se composicao_final estiver vazia, usa todas as questões aprovadas (interleaved) e salva
  if (!comp.length) {
    const aprovadas = qs.filter(q => q.status === 'aprovada');
    if (!aprovadas.length) { alert('Nenhuma questão aprovada neste simulado.'); return; }
    comp = _interleaveByArea(aprovadas.map(q => q.id));
    // Salva automaticamente a composição no banco
    await _sb.from('simulados_banco').update({ composicao_final: comp }).eq('id', simId);
    // Atualiza cache local
    const s = _sims.find(x => x.id === simId);
    if (s) s.composicao_final = comp;
  }

  // Build ordered list (composition order = already interleaved)
  const qById = {}; qs.forEach(q => { qById[q.id] = q; });
  const ordQ = comp.map(id => qById[id]).filter(Boolean);
  const totalQ = ordQ.length;
  const areas = [...new Set(ordQ.map(q => q.grande_area).filter(Boolean))];

  if (!totalQ) { alert('Nenhuma questão válida na composição.'); return; }

  if (typeof window.jspdf === 'undefined') {
    await _loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');
    await _loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js');
  }
  const jsPDF = window.jspdf?.jsPDF || window.jsPDF;
  if (!jsPDF) { alert('Erro ao carregar PDF. Tente novamente.'); return; }

  const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
  const W = 210, PL = 18, PR = 18, PW = W - PL - PR;
  let y;

  // ── Paleta profissional (tema claro) — cor customizável ──
  const _hexToRGB = h => { const m = (h||'').match(/^#?([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})$/i); return m ? [parseInt(m[1],16),parseInt(m[2],16),parseInt(m[3],16)] : null; };
  const WH    = [255,255,255];
  const BG    = [247,248,252];
  const TEXT  = [20,22,38];
  const SOFT  = [72,77,102];
  const MUTED = [140,145,168];
  const DARK  = [26,30,52];
  const RED   = (sim.pdf_cor && _hexToRGB(sim.pdf_cor)) || [176,27,27];
  const REDBG = [Math.round(255*0.92+RED[0]*0.08), Math.round(255*0.92+RED[1]*0.08), Math.round(255*0.92+RED[2]*0.08)];
  const CARD  = [237,240,250];
  const BORD  = [198,203,220];
  const GREEN = [22,128,60];

  function _pageBg() { doc.setFillColor(...BG); doc.rect(0,0,W,297,'F'); }
  function checkY(n=20) { if (y+n > 280) { doc.addPage(); _pageBg(); y = 20; } }
  function sectionHeader(num, title) {
    checkY(16);
    doc.setFillColor(...DARK); doc.rect(PL-2, y-5, PW+4, 11, 'F');
    doc.setFont('helvetica','bold'); doc.setFontSize(9.5); doc.setTextColor(...WH);
    doc.text(`${num}. ${title}`, PL+2, y+2); y += 12;
  }
  function pageFooter(pageNum, total) {
    doc.setFont('helvetica','normal'); doc.setFontSize(7); doc.setTextColor(...MUTED);
    doc.text(`MedCof B2B · ${sim.titulo} · Página ${pageNum} de ${total}`, W/2, 291, {align:'center'});
    doc.setFillColor(...RED); doc.rect(0, 293, W, 2, 'F');
  }

  // ── Helpers de estatística ────────────────────────────────
  const prioToLabel = { diamante:'Alta', verde:'Alta', amarelo:'Média', vermelho:'Baixa' };
  const difToLabel  = { facil:'Fácil', media:'Média', dificil:'Difícil' };
  const avgAcerto = q => q.taxa_acerto || 0;
  const pct = (n, tot) => tot ? (n/tot*100).toFixed(0)+'%' : '—';
  const mean = arr => arr.length ? (arr.reduce((a,b)=>a+b,0)/arr.length).toFixed(1)+'%' : '—';

  // Priority groups
  const prioGroups = { Alta:0, Média:0, Baixa:0 };
  ordQ.forEach(q => { const k = prioToLabel[q.prioridade]||'Média'; prioGroups[k]++; });
  const highPct = Math.round(prioGroups.Alta/totalQ*100);

  // ══════════════════════════════════════════════════════════
  // CAPA
  // ══════════════════════════════════════════════════════════
  _pageBg();
  // Cabeçalho escuro
  doc.setFillColor(...DARK); doc.rect(0,0,W,58,'F');
  doc.setFillColor(...RED); doc.rect(0,58,W,3,'F');
  // Resolve IES name for PDF
  const _pdfSlug = sim.pdf_instituicao || '';
  const _pdfIESObj = _pdfSlug ? _getIESList().find(i => i.slug === _pdfSlug) : null;
  const _pdfIESName = _pdfIESObj ? _pdfIESObj.name : (parseArr(sim.instituicoes_destino).join(', ') || '—');

  // Try to load institution logo
  let _logoDataUrl = null;
  if (_pdfSlug) {
    try {
      const img = new Image(); img.crossOrigin = 'anonymous';
      await new Promise((res, rej) => { img.onload = res; img.onerror = rej; img.src = `${_pdfSlug}/logo_${_pdfSlug}.png`; setTimeout(rej, 3000); });
      const cv = document.createElement('canvas'); cv.width = img.naturalWidth; cv.height = img.naturalHeight;
      cv.getContext('2d').drawImage(img, 0, 0);
      _logoDataUrl = cv.toDataURL('image/png');
    } catch(e) { /* logo not available, continue without */ }
  }

  doc.setFont('helvetica','bold'); doc.setFontSize(22); doc.setTextColor(...WH);
  doc.text(sim.titulo.toUpperCase(), _logoDataUrl ? PL : W/2, 22, {align: _logoDataUrl ? 'left' : 'center'});
  doc.setFontSize(10); doc.setTextColor(190,200,225);
  doc.text(`${_pdfIESName} | ${totalQ} questões`, _logoDataUrl ? PL : W/2, 34, {align: _logoDataUrl ? 'left' : 'center'});
  doc.setFontSize(8.5); doc.setTextColor(160,175,200);
  doc.text(`Edital ${sim.edital_num||'—'} · ${new Date().toLocaleDateString('pt-BR')}`, _logoDataUrl ? PL : W/2, 43, {align: _logoDataUrl ? 'left' : 'center'});
  doc.setFontSize(8); doc.setTextColor(120,135,165);
  doc.text('Composição formato ENAMED · MedCof B2B · Uso restrito', _logoDataUrl ? PL : W/2, 51, {align: _logoDataUrl ? 'left' : 'center'});

  // Add logo to cover header
  if (_logoDataUrl) {
    try {
      const logoH = 30, logoW = 30;
      doc.addImage(_logoDataUrl, 'PNG', W - PR - logoW, 12, logoW, logoH);
    } catch(e) { /* skip */ }
  }

  // Stat boxes
  y = 72;
  const statCards = [
    { label:'Total questões',   val: String(totalQ) },
    { label:'% Acerto médio',   val: mean(ordQ.map(avgAcerto)) },
    { label:'Alta prioridade',  val: highPct+'%' },
    { label:'Grandes áreas',    val: String(areas.length) },
  ];
  const cW = PW / statCards.length;
  statCards.forEach((c,i) => {
    const cx = PL + i * cW;
    doc.setFillColor(...DARK); doc.roundedRect(cx+2, y, cW-4, 28, 3,3,'F');
    doc.setFillColor(...RED); doc.rect(cx+2, y+25, cW-4, 3,'F');
    doc.setFont('helvetica','bold'); doc.setFontSize(17); doc.setTextColor(...WH);
    doc.text(c.val, cx+cW/2, y+14, {align:'center'});
    doc.setFont('helvetica','normal'); doc.setFontSize(7); doc.setTextColor(175,185,215);
    doc.text(c.label, cx+cW/2, y+22, {align:'center'});
  });
  y = 110;

  // Intro paragraph
  doc.setFont('helvetica','normal'); doc.setFontSize(8.5); doc.setTextColor(...SOFT);
  const introText = `${highPct}% das questões são de alta prioridade, baseado no índice de incidência histórica do ENAMED/INEP. Todos os eixos de maior cobrança estão contemplados: ${[...new Set(ordQ.filter(q=>prioToLabel[q.prioridade]==='Alta').map(q=>q.tema))].slice(0,8).join(', ')}${[...new Set(ordQ.filter(q=>prioToLabel[q.prioridade]==='Alta').map(q=>q.tema))].length>8?' e outros.':'.'  }`;
  const introLines = doc.splitTextToSize(introText, PW);
  doc.text(introLines, PL, y); y += introLines.length * 5 + 8;

  // Coverage mini-table on cover
  doc.setFont('helvetica','bold'); doc.setFontSize(8.5); doc.setTextColor(...TEXT);
  doc.text('Cobertura temática por área:', PL, y); y += 6;
  areas.forEach(area => {
    const aQs = ordQ.filter(q => q.grande_area === area);
    const temas = [...new Set(aQs.map(q => q.tema).filter(Boolean))];
    checkY(9);
    const aLabel = area.length > 30 ? area.substring(0,28)+'…' : area;
    doc.setFillColor(...CARD); doc.rect(PL-2, y-4.5, PW+4, 8, 'F');
    doc.setFont('helvetica','bold'); doc.setFontSize(8); doc.setTextColor(...RED);
    doc.text(aLabel, PL+1, y);
    doc.setFont('helvetica','normal'); doc.setFontSize(7.5); doc.setTextColor(...SOFT);
    const temasStr = temas.join(', ') + ` — ${temas.length} tema(s) distintos.`;
    const tLines = doc.splitTextToSize(temasStr, PW-48);
    doc.text(tLines[0]||temasStr.substring(0,90), PL+48, y);
    y += 9;
  });

  // ══════════════════════════════════════════════════════════
  // PÁG 2: ANÁLISE
  // ══════════════════════════════════════════════════════════
  doc.addPage(); _pageBg(); y = 20;

  // Seção 1: Prioridade
  sectionHeader(1,'PRIORIDADE TEMÁTICA — ÍNDICE DE INCIDÊNCIA');
  y += 4;
  const prioRows = Object.entries(prioGroups).map(([k,n]) => [k, n, pct(n,totalQ)]);
  doc.autoTable({ startY:y,
    head:[['Prioridade','Número de Questões','% da prova']],
    body: prioRows,
    styles:{ fontSize:9, cellPadding:4, textColor:TEXT },
    headStyles:{ fillColor:DARK, textColor:WH, fontStyle:'bold' },
    alternateRowStyles:{ fillColor:CARD },
    columnStyles:{ 0:{fontStyle:'bold'}, 1:{halign:'center'}, 2:{halign:'center'} },
    margin:{left:PL,right:PR}, theme:'grid'
  });
  y = doc.lastAutoTable.finalY + 14;

  // Seção 2: Cobertura temática por área
  checkY(40);
  sectionHeader(2,'COBERTURA TEMÁTICA POR ÁREA');
  y += 4;
  const covBody = areas.map(area => {
    const temas = [...new Set(ordQ.filter(q=>q.grande_area===area).map(q=>q.tema).filter(Boolean))];
    return [area, temas.join(', ') + ` — ${temas.length} temas distintos.`];
  });
  doc.autoTable({ startY:y,
    head:[['Grande Área','Temas abordados']],
    body: covBody,
    styles:{ fontSize:8.5, cellPadding:4, textColor:TEXT, overflow:'linebreak' },
    headStyles:{ fillColor:DARK, textColor:WH, fontStyle:'bold' },
    alternateRowStyles:{ fillColor:CARD },
    columnStyles:{ 0:{fontStyle:'bold', cellWidth:46}, 1:{cellWidth:PW-46} },
    margin:{left:PL,right:PR}, theme:'grid'
  });
  y = doc.lastAutoTable.finalY + 14;

  // Seção 3: Dificuldade
  checkY(50);
  sectionHeader(3,'NÍVEL DE DIFICULDADE');
  y += 3;
  doc.setFont('helvetica','normal'); doc.setFontSize(8.5); doc.setTextColor(...SOFT);
  const avgGeral = mean(ordQ.map(avgAcerto));
  const difQs = { facil: ordQ.filter(q=>q.dificuldade==='facil'), media: ordQ.filter(q=>q.dificuldade==='media'), dificil: ordQ.filter(q=>q.dificuldade==='dificil') };
  const difText = `O simulado apresenta calibração intencional: ${difQs.facil.length} questões fáceis (${pct(difQs.facil.length,totalQ)}), ${difQs.media.length} médias (${pct(difQs.media.length,totalQ)}) e ${difQs.dificil.length} difíceis (${pct(difQs.dificil.length,totalQ)}). % de acerto médio geral: ${avgGeral}.`;
  const dtLines = doc.splitTextToSize(difText, PW);
  doc.text(dtLines, PL, y); y += dtLines.length*5+5;

  const difRows = ['facil','media','dificil'].map(d => {
    const dQs = difQs[d];
    return [difToLabel[d], dQs.length, pct(dQs.length,totalQ), mean(dQs.map(avgAcerto))];
  });
  difRows.push(['Média geral','','', avgGeral]);
  doc.autoTable({ startY:y,
    head:[['Dificuldade','Questões','%','% Acerto Médio']],
    body: difRows,
    styles:{ fontSize:9, cellPadding:4, textColor:TEXT },
    headStyles:{ fillColor:DARK, textColor:WH, fontStyle:'bold' },
    alternateRowStyles:{ fillColor:CARD },
    columnStyles:{ 1:{halign:'center'}, 2:{halign:'center'}, 3:{halign:'center',fontStyle:'bold'} },
    didParseCell(d){ if(d.row.index===difRows.length-1){ d.cell.styles.fillColor=REDBG; d.cell.styles.textColor=RED; d.cell.styles.fontStyle='bold'; } },
    margin:{left:PL,right:PR}, theme:'grid'
  });
  y = doc.lastAutoTable.finalY + 10;

  // Distribuição por área (dificuldade)
  checkY(30);
  doc.setFont('helvetica','bold'); doc.setFontSize(8.5); doc.setTextColor(...SOFT);
  doc.text('Distribuição por área:', PL, y); y += 5;
  const areaDifRows = areas.map(area => {
    const aQs = ordQ.filter(q=>q.grande_area===area);
    return [
      area,
      aQs.filter(q=>q.dificuldade==='facil').length,
      aQs.filter(q=>q.dificuldade==='media').length,
      aQs.filter(q=>q.dificuldade==='dificil').length,
      mean(aQs.map(avgAcerto))
    ];
  });
  doc.autoTable({ startY:y,
    head:[['Grande Área','Fácil','Média','Difícil','% Acerto médio']],
    body: areaDifRows,
    styles:{ fontSize:8.5, cellPadding:3.5, textColor:TEXT },
    headStyles:{ fillColor:BORD, textColor:DARK, fontStyle:'bold' },
    alternateRowStyles:{ fillColor:CARD },
    columnStyles:{ 1:{halign:'center'}, 2:{halign:'center'}, 3:{halign:'center'}, 4:{halign:'center',fontStyle:'bold'} },
    margin:{left:PL,right:PR}, theme:'grid'
  });
  y = doc.lastAutoTable.finalY + 6;

  // ══════════════════════════════════════════════════════════
  // PÁG 3+: VISÃO GERAL DO SIMULADO
  // ══════════════════════════════════════════════════════════
  doc.addPage(); _pageBg(); y = 20;
  sectionHeader(4,'VISÃO GERAL DO SIMULADO');
  y += 4;
  const overviewRows = ordQ.map((q,i) => [
    i+1,
    q.grande_area||'—',
    q.tema||'—',
    prioToLabel[q.prioridade]||'—',
    q.taxa_acerto ? q.taxa_acerto+'%' : '—'
  ]);
  doc.autoTable({ startY:y,
    head:[['Nº','Grande Área','Tema','Incidência do tema','% Acerto']],
    body: overviewRows,
    styles:{ fontSize:7.5, cellPadding:2.5, textColor:TEXT, overflow:'linebreak' },
    headStyles:{ fillColor:DARK, textColor:WH, fontStyle:'bold', fontSize:8 },
    alternateRowStyles:{ fillColor:CARD },
    columnStyles:{
      0:{ halign:'center', cellWidth:11 },
      1:{ cellWidth:42 },
      2:{ cellWidth:76 },
      3:{ halign:'center', cellWidth:26 },
      4:{ halign:'center', cellWidth:19 }
    },
    margin:{left:PL,right:PR}, theme:'grid'
  });

  // Rodapé em todas as páginas
  const nPages = doc.getNumberOfPages();
  for (let p = 1; p <= nPages; p++) { doc.setPage(p); pageFooter(p, nPages); }

  const fname = `Relatorio_${sim.titulo.replace(/[^a-zA-Z0-9]/g,'_').replace(/_+/g,'_')}_${new Date().toISOString().slice(0,10)}.pdf`;
  doc.save(fname);
};

// ── Exportar planilha XLSX (script para subir simulado) ──────────
window.bqExportXLSX = async function(simId) {
  const sim = _sims.find(s => s.id === simId);
  if (!sim) { alert('Simulado não encontrado.'); return; }

  const { data: qs } = await _sb.from('simulados_questoes').select('*').eq('simulado_id', simId);
  const qById = {}; (qs||[]).forEach(q => { qById[q.id] = q; });

  let comp = parseArr(sim.composicao_final);
  // Fallback: se vazio, usa todas aprovadas interleaved e salva
  if (!comp.length) {
    const aprovadas = (qs||[]).filter(q => q.status === 'aprovada');
    if (!aprovadas.length) { alert('Nenhuma questão aprovada neste simulado.'); return; }
    comp = _interleaveByArea(aprovadas.map(q => q.id));
    await _sb.from('simulados_banco').update({ composicao_final: comp }).eq('id', simId);
    const s = _sims.find(x => x.id === simId);
    if (s) s.composicao_final = comp;
  }

  const orderedQs = comp.map(id => qById[id]).filter(Boolean);

  // Load ExcelJS
  if (typeof window.ExcelJS === 'undefined') {
    await _loadScript('https://cdn.jsdelivr.net/npm/exceljs@4.4.0/dist/exceljs.min.js');
  }
  if (!window.ExcelJS) { alert('Erro ao carregar biblioteca de planilha.'); return; }

  const wb = new ExcelJS.Workbook();
  const ws = wb.addWorksheet('questoes-simulado');

  const FONT = { name: 'Aptos Narrow', size: 10 };

  // Cabeçalho — apenas texto, fonte Aptos Narrow 10
  const hdr = ws.addRow(['Número da Questão (#)', 'Código/Id Questão']);
  hdr.eachCell(cell => { cell.font = FONT; });

  // Linhas: apenas as que têm código preenchido
  orderedQs.forEach((q, i) => {
    const cod = q ? (q.codigo_questao || '') : '';
    if (!cod) return; // pula questão sem código
    const row = ws.addRow([i + 1, cod]);
    row.eachCell(cell => { cell.font = FONT; });
  });

  // Download
  const buffer = await wb.xlsx.writeBuffer();
  const blob   = new Blob([buffer], { type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
  const url    = URL.createObjectURL(blob);
  const a      = document.createElement('a');
  a.href       = url;
  a.download   = `Script_${sim.titulo.replace(/[^a-zA-Z0-9]/g,'_').replace(/_+/g,'_')}_${new Date().toISOString().slice(0,10)}.xlsx`;
  document.body.appendChild(a); a.click();
  document.body.removeChild(a); URL.revokeObjectURL(url);
};

