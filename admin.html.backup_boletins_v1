// Check codigo_questao reuse — consulta o banco diretamente
window._bqCodBlocked = false;
window._bqCodNeedsConfirm = false;
window._bqCheckCodigo = async function(cod, editingId, currentSimId) {
  const warn = $b('bqCodWarning');
  window._bqCodBlocked = false;
  window._bqCodNeedsConfirm = false;
  if (!warn || !cod.trim()) { if (warn) warn.style.display = 'none'; return; }
  warn.innerHTML = '<span style="color:var(--text-muted)">Verificando...</span>';
  warn.style.display = 'block';
  try {
    const { data: matches } = await _sb.from('simulados_questoes')
      .select('id,simulado_id,instituicao_questao,tipo_prova,ano_prova')
      .eq('codigo_questao', cod.trim());
    const found = (matches||[]).filter(q => q.id !== editingId);
    // Duplicata no MESMO simulado = pedir confirmação (não bloqueia)
    const sameSimDupe = found.filter(q => q.simulado_id === currentSimId);
    if (sameSimDupe.length) {
      warn.innerHTML = '<span style="color:var(--amber)">⚠️ Questão com este código já existe neste simulado. Será solicitada confirmação ao salvar.</span>';
      window._bqCodNeedsConfirm = true;
      return;
    }
    // Duplicata em OUTROS simulados = aviso informativo
    const otherDupes = found.filter(q => q.simulado_id !== currentSimId);
    if (otherDupes.length) {
      const simDetails = [...new Set(otherDupes.map(q => {
        const s = _sims.find(x => x.id === q.simulado_id);
        return s ? s.titulo : '(outro simulado)';
      }))];
      const provaDetails = [...new Set(otherDupes.map(q => [q.instituicao_questao,q.tipo_prova,q.ano_prova].filter(Boolean).join(' ')).filter(Boolean))];
      warn.innerHTML = '<span style="color:var(--amber)">⚠️ Código encontrado em outros simulados:</span><br>'
        + simDetails.map(t => `<span style="color:var(--amber);font-size:0.72rem;margin-left:8px">• ${t}</span>`).join('<br>')
        + (provaDetails[0] ? `<br><span style="color:var(--text-muted);font-size:0.7rem;margin-left:8px">Prova: ${provaDetails.join(', ')}</span>` : '');
      return;
    }
    warn.innerHTML = '<span style="color:var(--green)">✅ Código disponível</span>';
  } catch(e) {
    warn.innerHTML = '<span style="color:var(--text-muted)">Não foi possível verificar</span>';
  }
};

// Modal de confirmação de questão duplicada (Promise-based)
window._bqConfirmDuplicate = function(cod) {
  return new Promise(resolve => {
    const ov = document.createElement('div');
    ov.style.cssText = 'position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center';
    ov.innerHTML = `<div style="background:var(--bg-card,#181b23);border:1px solid var(--border,#2a2f3e);border-radius:20px;padding:32px;width:min(90%,420px);box-shadow:0 24px 80px rgba(0,0,0,0.5)">
      <div style="font-size:1.1rem;font-weight:700;margin-bottom:12px">⚠️ Código duplicado</div>
      <p style="font-size:0.88rem;color:var(--text-soft);margin-bottom:24px;line-height:1.5">Já existe uma questão com o código <strong>${cod}</strong> neste simulado. Deseja cadastrar mesmo assim?</p>
      <div style="display:flex;gap:12px">
        <button id="_bqDupCancel" style="flex:1;padding:12px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-soft);font-size:0.9rem;font-weight:600;cursor:pointer">Cancelar</button>
        <button id="_bqDupConfirm" style="flex:1;padding:12px;border-radius:10px;border:none;background:var(--amber,#f59e0b);color:#fff;font-size:0.9rem;font-weight:700;cursor:pointer">Prosseguir</button>
      </div>
    </div>`;
    document.body.appendChild(ov);
    ov.querySelector('#_bqDupCancel').onclick = () => { ov.remove(); resolve(false); };
    ov.querySelector('#_bqDupConfirm').onclick = () => { ov.remove(); resolve(true); };
    ov.onclick = (e) => { if (e.target === ov) { ov.remove(); resolve(false); } };
  });
};

window.bqSaveQ = async function(simId) {
  const enunc = ($b('bqQEnunc')?.value||'').trim();
  const gab   = $b('bqQGab')?.value;
  const tema  = ($b('bqQTema')?.value||'').trim();
  const instQ = ($b('bqQInstQ')?.value||'').trim();
  const ano   = ($b('bqQAno')?.value||'').trim();
  const cod   = ($b('bqQCod')?.value||'').trim();
  if (window._bqCodNeedsConfirm) {
    const proceed = await window._bqConfirmDuplicate(cod);
    if (!proceed) return;
  }
  if (!enunc) { alert('Preencha o enunciado.'); return; }
  if (!gab)   { alert('Selecione o gabarito.'); return; }
  if (!tema)  { alert('Informe o tema da questão.'); return; }
  if (!instQ) { alert('Informe a instituição da questão.'); return; }
  if (!ano)   { alert('Informe o ano da prova.'); return; }
  const payload = {
    simulado_id: simId, instituicao: _curInst, submetido_por: _curEmail,
    codigo_questao: cod,
    grande_area: $b('bqQArea')?.value,
    enunciado: enunc,
    gabarito: gab,
    dificuldade: $b('bqQDif')?.value || 'media',
    taxa_acerto: parseFloat($b('bqQTaxa')?.value) || 0,
    tema: tema,
    instituicao_questao: instQ,
    tipo_prova: $b('bqQTipo')?.value || 'R1',
    ano_prova: ano,
    prioridade: $b('bqQPrio')?.value || 'verde',
    status: 'pendente'
  };
  let error;
  if (_editingQId) {
    ({ error } = await _sb.from('simulados_questoes').update(payload).eq('id', _editingQId));
  } else {
    ({ error } = await _sb.from('simulados_questoes').insert(payload));
  }
  if (error) { alert('Erro ao salvar: ' + error.message); return; }
  window.bqCloseModal();
  await bqInit();
};

