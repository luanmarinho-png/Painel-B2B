function _showRegAccess(state, data) {
  ['regAccessPlaceholder','regAccessLoading','regAccessList','regAccessEmpty','regAccessActions']
    .forEach(id => { document.getElementById(id).style.display = 'none'; });
  if (state === 'placeholder') {
    document.getElementById('regAccessPlaceholder').style.display = '';
  } else if (state === 'loading') {
    document.getElementById('regAccessLoading').style.display = '';
  } else if (state === 'list') {
    const el = document.getElementById('regAccessList');
    el.innerHTML = (data || []).map(u => {
      const badge = u.ativo
        ? '<span class="badge-active">Ativo</span>'
        : '<span class="badge-inactive">Inativo</span>';
      const nome = u.nome ? '<span class="access-user-name">' + u.nome + '</span>' : '';
      return '<div class="access-user-row"><span class="access-user-email">' + u.email + '</span>' + nome + badge + '</div>';
    }).join('');
    el.style.display = '';
    document.getElementById('regAccessActions').style.display = '';
  } else if (state === 'empty') {
    document.getElementById('regAccessEmpty').style.display = '';
    document.getElementById('regAccessActions').style.display = '';
  }
}

async function _queryRegAccessUsers(slug) {
  _showRegAccess('loading');
  try {
    const sb = getSupabaseClient();
    const { data, error } = await sb
      .from('usuarios_autorizados')
      .select('email, nome, ativo')
      .eq('instituicao', slug)
      .order('criado_em', { ascending: false });
    if (error) throw error;
    _showRegAccess(data && data.length > 0 ? 'list' : 'empty', data || []);
  } catch(e) {
    console.warn('Erro ao consultar usuários da IES:', e.message);
    _showRegAccess('placeholder');
  }
}

