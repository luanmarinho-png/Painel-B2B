            <button class="btn-primary" style="padding:6px 12px;font-size:0.73rem;${pdfDisabled?'opacity:0.4;pointer-events:none':''}" onclick="window._simOpenPdfModal('${i.slug}')" ${pdfDisabled?'disabled title="Cadastre Tendências primeiro"':''}>📄 Gerar PDF</button>
          </div>
        </div>
      </div>`;
    }).join('');
  }

  // Render on load + expose for refresh
  setTimeout(renderSimStatusGrid, 100);
