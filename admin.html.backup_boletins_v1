      <div class="field" style="margin-bottom:16px">
        <label style="display:block;font-size:0.75rem;font-weight:700;color:var(--text-soft);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em">Mensagem <span style="color:var(--accent)">*</span></label>
        <textarea id="avisoMensagem" rows="4" placeholder="Escreva o conteúdo do aviso aqui..." style="width:100%;box-sizing:border-box;padding:10px 14px;border-radius:10px;border:1.5px solid var(--border);background:var(--bg-elevated);color:var(--text);font-size:0.88rem;outline:none;resize:vertical;font-family:inherit"></textarea>
      </div>
      <!-- Duração -->
      <div class="field" style="margin-bottom:16px">
        <label style="display:block;font-size:0.75rem;font-weight:700;color:var(--text-soft);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em">Expirar em</label>
        <select id="avisoDuracao" style="width:100%;padding:10px 14px;border-radius:10px;border:1.5px solid var(--border);background:var(--bg-elevated);color:var(--text);font-size:0.88rem;outline:none">
          <option value="1">1 dia</option>
          <option value="3" selected>3 dias</option>
          <option value="7">7 dias (1 semana)</option>
          <option value="14">14 dias (2 semanas)</option>
          <option value="30">30 dias (1 mês)</option>
        </select>
      </div>
      <!-- Preview -->
      <div id="avisoPreview" style="display:none;border-radius:12px;overflow:hidden;border:1px solid var(--border-subtle);margin-bottom:16px">
        <div id="avisoPreviewTop" style="padding:14px 18px;background:linear-gradient(135deg,#ca8a04,#eab308)">
          <div style="font-size:1.1rem;margin-bottom:4px">📢</div>
          <div id="avisoPreviewTitulo" style="font-size:0.95rem;font-weight:800;color:#fff"></div>
        </div>
        <div id="avisoPreviewMensagem" style="padding:14px 18px;font-size:0.85rem;color:var(--text);line-height:1.6;white-space:pre-wrap;background:var(--bg-elevated)"></div>
      </div>
      <!-- Error -->
      <div id="avisoError" style="font-size:0.82rem;color:var(--accent);min-height:18px;margin-bottom:10px;text-align:center"></div>
      <!-- Botões -->
      <div style="display:flex;gap:10px">
        <button onclick="window._toggleAvisoPreview()" style="padding:11px 18px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-soft);font-size:0.85rem;font-weight:600;cursor:pointer;white-space:nowrap">👁 Preview</button>
        <button onclick="document.getElementById('avisoModal').style.display='none'" style="flex:1;padding:12px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-soft);font-size:0.9rem;font-weight:600;cursor:pointer">Cancelar</button>
        <button id="avisoSendBtn" onclick="window._saveAviso()" style="flex:2;padding:12px;border-radius:10px;border:none;background:linear-gradient(135deg,#ca8a04,#eab308);color:#fff;font-size:0.9rem;font-weight:700;cursor:pointer;box-shadow:0 6px 18px rgba(234,179,8,0.28)">📢 Enviar</button>
      </div>
    </div>
  </div>
</div>

<script>
// ── Sistema de Avisos às Coordenações ────────────────────────────
window._avisoTargetSlug = '';

window._openAvisoModal = function(slug) {
  window._avisoTargetSlug = slug;
  const inst = (window._instData || []).find(i => i.slug === slug);
  const nome = inst ? (inst.nome || slug.toUpperCase()) : slug.toUpperCase();

  // Ajustar header com cor da IES
  const themeHex = inst && inst.theme_hex ? inst.theme_hex : '#eab308';
  const header = document.getElementById('avisoModalHeader');
  if (header) header.style.background = `linear-gradient(135deg,${themeHex}cc,${themeHex})`;

  document.getElementById('avisoModalTitle').textContent = `Enviar Aviso — ${nome}`;
  document.getElementById('avisoTitulo').value = '';
  document.getElementById('avisoMensagem').value = '';
  document.getElementById('avisoTarget').value = 'this';
  document.getElementById('avisoDuracao').value = '3';
  document.getElementById('avisoError').textContent = '';
  document.getElementById('avisoPreview').style.display = 'none';

  const modal = document.getElementById('avisoModal');
  modal.style.display = 'flex';
  modal.onclick = (e) => { if (e.target === modal) modal.style.display = 'none'; };
  setTimeout(() => document.getElementById('avisoTitulo').focus(), 120);
};

window._toggleAvisoPreview = function() {
  const prev = document.getElementById('avisoPreview');
  const titulo = document.getElementById('avisoTitulo').value.trim();
  const msg = document.getElementById('avisoMensagem').value.trim();
  if (prev.style.display === 'none') {
    document.getElementById('avisoPreviewTitulo').textContent = titulo || '(sem título)';
    document.getElementById('avisoPreviewMensagem').textContent = msg || '(sem mensagem)';
    const inst = (window._instData || []).find(i => i.slug === window._avisoTargetSlug);
    const hex = inst && inst.theme_hex ? inst.theme_hex : '#eab308';
    document.getElementById('avisoPreviewTop').style.background = `linear-gradient(135deg,${hex}cc,${hex})`;
    prev.style.display = 'block';
  } else {
    prev.style.display = 'none';
  }
};

window._saveAviso = async function() {
  const btn = document.getElementById('avisoSendBtn');
  const errEl = document.getElementById('avisoError');
  const titulo = document.getElementById('avisoTitulo').value.trim();
  const mensagem = document.getElementById('avisoMensagem').value.trim();
  const targetMode = document.getElementById('avisoTarget').value;
  const dias = parseInt(document.getElementById('avisoDuracao').value, 10);

  errEl.textContent = '';
  if (!titulo) { errEl.textContent = 'Preencha o título do aviso.'; return; }
  if (!mensagem) { errEl.textContent = 'Preencha a mensagem do aviso.'; return; }

  const iesSlug = targetMode === 'all' ? 'all' : window._avisoTargetSlug;
  const expiraEm = new Date();
  expiraEm.setDate(expiraEm.getDate() + dias);

  btn.disabled = true; btn.textContent = 'Enviando...';
  try {
    const sb = getSupabaseClient();
    const { data: { user } } = await sb.auth.getUser();
    const { error } = await sb.from('avisos').insert({
      ies_slug: iesSlug,
      titulo,
      mensagem,
      expira_em: expiraEm.toISOString(),
      criado_por: user?.email || 'admin',
      ativo: true,
    });
    if (error) throw new Error(error.message);
    document.getElementById('avisoModal').style.display = 'none';
    const instNome = (window._instData || []).find(i => i.slug === window._avisoTargetSlug)?.nome || window._avisoTargetSlug;
    const dest = targetMode === 'all' ? 'todas as IES' : instNome;
    showToast(`✅ Aviso enviado para ${dest}! Aparecerá no próximo acesso das coordenações.`, 'success');
  } catch(e) {
    errEl.textContent = e.message;
    showToast('Erro ao enviar aviso: ' + e.message, 'error');
  } finally {
    btn.disabled = false; btn.textContent = '📢 Enviar';
  }
};
</script>

</body>
</html>
