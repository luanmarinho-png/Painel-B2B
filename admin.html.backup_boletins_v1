  };

  window._updateMultiBtn = function() {
    const hasFiles = window._periodSlots.some(s => s.file);
    $("btnProcess").disabled = !(hasFiles && $("updateInst").value);
  };

  // Initialize with 1 slot on load
  setTimeout(() => { window._generatePeriodSlots(); }, 0);

  // ── Importar planilha de exclusão ──────────────────────────────
  window._loadExclusionFile = function(file) {
    if (!file) return;
    const info = document.getElementById('exclusionFileInfo');
    info.textContent = 'Carregando...';
    const reader = new FileReader();
    reader.onload = function(e) {
      try {
        let names = [];
        if (file.name.endsWith('.csv')) {
          const lines = e.target.result.split(/\r?\n/).filter(l => l.trim());
          // Skip header if first line looks like a header
          const start = /nome|name|aluno/i.test(lines[0]) ? 1 : 0;
          for (let i = start; i < lines.length; i++) {
            const cols = lines[i].split(/[,;\t]/);
            const name = (cols[0] || '').trim().replace(/^["']|["']$/g, '');
            if (name) names.push(name);
          }
        } else {
          const wb = XLSX.read(e.target.result, { type: 'array' });
          const ws = wb.Sheets[wb.SheetNames[0]];
          const json = XLSX.utils.sheet_to_json(ws, { defval: '' });
          const firstKey = Object.keys(json[0] || {})[0];
          json.forEach(row => {
            const val = String(firstKey ? row[firstKey] : '').trim();
            if (val) names.push(val);
          });
        }
        // Append to textarea (below existing manual entries)
        const ta = document.getElementById('exclusionList');
        const existing = ta.value.trim();
        ta.value = (existing ? existing + '\n' : '') + names.join('\n');
        info.textContent = `✅ ${names.length} nome(s) importados de ${file.name}`;
      } catch(err) {
        info.textContent = '❌ Erro: ' + err.message;
      }
    };
    if (file.name.endsWith('.csv')) reader.readAsText(file);
    else reader.readAsArrayBuffer(file);
  };

  function setupUploadZone(zoneId, fileInputId, defaultIcon, onFile) {
    const zone=$(zoneId), input=$(fileInputId);
    if (!zone || !input) return;
    ["dragenter","dragover"].forEach(e=>zone.addEventListener(e,ev=>{ev.preventDefault();zone.classList.add("dragover");}));
    ["dragleave","drop"].forEach(e=>zone.addEventListener(e,ev=>{ev.preventDefault();zone.classList.remove("dragover");}));
    zone.addEventListener("drop",ev=>{ if(ev.dataTransfer.files[0]) handleFile(ev.dataTransfer.files[0],zone,defaultIcon,onFile); });
    input.addEventListener("change",()=>{ if(input.files[0]) handleFile(input.files[0],zone,defaultIcon,onFile); });
  }
  function handleFile(file,zone,defaultIcon,cb) {
    zone.classList.add("has-file");
    zone.querySelector(".upload-zone-icon").textContent="✅";
    zone.querySelector(".upload-zone-title").textContent=file.name;
    zone.querySelector(".upload-zone-hint").textContent=(file.size/1024).toFixed(0)+" KB";
    if(!zone.querySelector(".remove-file")) {
      const rm=document.createElement("span"); rm.className="remove-file"; rm.textContent="Remover";
      rm.addEventListener("click",ev=>{ ev.stopPropagation();ev.preventDefault();
        zone.classList.remove("has-file"); zone.querySelector(".upload-zone-icon").textContent=defaultIcon;
        zone.querySelector(".upload-zone-title").textContent="Arraste ou clique"; zone.querySelector(".upload-zone-hint").textContent="(.xlsx)";
        rm.remove(); cb(null); updateBtn();
      }); zone.appendChild(rm);
    }
    cb(file); updateBtn();
  }

  function updateBtn() {
    // Multi-period aware
    if (window._periodSlots && window._periodSlots.length > 0) {
      const hasFiles = window._periodSlots.some(s => s.file);
      $("btnProcess").disabled = !(hasFiles && $("updateInst").value);
    } else {
      $("btnProcess").disabled = !(segFiles.length > 0 && $("updateInst").value);
    }
  }

  // ── Dupla checagem de datas (funções globais, acessíveis de todos os blocos) ──
  // Converte YYYY-MM-DD (input[type=date]) → DD/MM/YYYY — sanitiza o ano para 4 dígitos
  window.isoToDmy = function(iso) {
    if (!iso) return null;
    const [y, m, d] = iso.split("-");
    const year = String(y).replace(/\D/g,"").slice(-4); // garante 4 dígitos
    return `${d}/${m}/${year}`;
  };
  // Retorna {start, end} com os extremos de todos os períodos
  window.extractExcelDates = function(periods) {
    const parseDMY = s => { if(!s) return null; const [d,m,y]=s.split("/"); return new Date(+y,+m-1,+d); };
    let minD = null, maxD = null, minS = null, maxS = null;
    periods.forEach(p => {
      const ds = parseDMY(p.dateStart), de = parseDMY(p.dateEnd);
      if (ds && (!minD || ds < minD)) { minD = ds; minS = p.dateStart; }
      if (de && (!maxD || de > maxD)) { maxD = de; maxS = p.dateEnd; }
    });
    return { start: minS, end: maxS };
  };
  // Mostra modal de conflito — retorna Promise<'form'|'excel'>
  window.showDateModal = function(formStart, formEnd, excelStart, excelEnd) {
    return new Promise(resolve => {
      $("dateModalFormDates").textContent = `${formStart} a ${formEnd}`;
      $("dateModalExcelDates").textContent = `${excelStart} a ${excelEnd}`;
      $("dateModalOverlay").classList.remove("hidden");
      const btnForm = $("dateModalBtnForm");
      const btnExcel = $("dateModalBtnExcel");
      function cleanup() { $("dateModalOverlay").classList.add("hidden"); btnForm.removeEventListener("click", onForm); btnExcel.removeEventListener("click", onExcel); }
      function onForm()  { cleanup(); resolve("form"); }
      function onExcel() { cleanup(); resolve("excel"); }
      btnForm.addEventListener("click", onForm);
      btnExcel.addEventListener("click", onExcel);
    });
  };
  // Funde todos os períodos em um único com as datas especificadas (deduplicando alunos)
  window.mergePeriods = function(periods, start, end) {
    const [ds, ms] = start.split("/");
    const [de, me] = end.split("/");
    const label = `${ds}/${ms} a ${de}/${me}`;
    const merged = { periodo: label, dateStart: start, dateEnd: end, alunos: [] };
    const seen = new Set();
    const normN = s => (s||"").trim().toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"").replace(/\s+/g," ");
    periods.forEach(p => p.alunos.forEach(a => {
      const key = normN(a.nome);
      if (!seen.has(key)) { seen.add(key); merged.alunos.push(a); }
    }));
    return [merged];
  };
  // Aplica escolha de datas — sempre funde em um período
  window.applyChosenDates = function(periods, choice, formStart, formEnd, excelStart, excelEnd) {
    return mergePeriods(periods, choice === "form" ? formStart : excelStart, choice === "form" ? formEnd : excelEnd);
  };

  // ── Multi-file upload para planilhas B2B ──
  function renderSegChips() {
    const list = $("segFileList");
    list.innerHTML = "";
    if (segFiles.length === 0) { list.style.display = "none"; return; }
    list.style.display = "flex";
    segFiles.forEach((f, i) => {
      const chip = document.createElement("div");
      chip.className = "file-chip";
      chip.innerHTML = `<span title="${f.name}">📊 ${f.name}</span><span class="file-chip-remove" data-i="${i}">✕</span>`;
      chip.querySelector(".file-chip-remove").addEventListener("click", () => {
        segFiles.splice(i, 1);
        renderSegChips();
        updateSegZone();
        updateBtn();
