  function setupSimUpload(zoneId, fileInputId, onFile) {
    const zone=$(zoneId), input=$(fileInputId);
    if(!zone||!input) return;
    ["dragenter","dragover"].forEach(e=>zone.addEventListener(e,ev=>{ev.preventDefault();zone.classList.add("dragover");}));
    ["dragleave","drop"].forEach(e=>zone.addEventListener(e,ev=>{ev.preventDefault();zone.classList.remove("dragover");}));
    zone.addEventListener("drop", ev => {
      const f=ev.dataTransfer.files[0]; if(f){onFile(f);updateZoneUI(zone,f);}
    });
    input.addEventListener("change", () => {
      const f=input.files[0]; if(f){onFile(f);updateZoneUI(zone,f);} input.value="";
    });
    zone.addEventListener("click", (e) => { if (e.target !== input) input.click(); });
  }

  function updateZoneUI(zone, file) {
    const t=zone.querySelector(".upload-zone-title"), h=zone.querySelector(".upload-zone-hint");
    if(t) t.textContent=file.name;
