<script>
(() => {
  const $=(id)=>document.getElementById(id);
  const P = window.MedCofParser;
  let selectedColor="neutro";
  let regSegFiles=[], regLogoFile=null, regSimTendFile=null, regSimPersFile=null;

  document.querySelectorAll(".color-opt").forEach(o=>{
    o.addEventListener("click",()=>{
      document.querySelectorAll(".color-opt").forEach(x=>x.classList.remove("selected"));
      o.classList.add("selected"); selectedColor=o.dataset.color;
    });
  });

  $("regName").addEventListener("input",()=>{
    const n=$("regName").value.trim();
    if(n&&!$("regSlug").dataset.manual) $("regSlug").value=n.toLowerCase().replace(/\s+/g,"-").replace(/[^a-z0-9-]/g,"");
    if(n&&!$("regInitials").dataset.manual) $("regInitials").value=n.toUpperCase().slice(0,2);
  });
  $("regSlug").addEventListener("input",()=>{$("regSlug").dataset.manual="1";});
  $("regInitials").addEventListener("input",()=>{$("regInitials").dataset.manual="1";});

  // Upload zones for register tab
  function setupRegUpload(zoneId, fileInputId, icon, cb) {
    const zone=$(zoneId), input=$(fileInputId);
    if(!zone||!input) return;
    ["dragenter","dragover"].forEach(e=>zone.addEventListener(e,ev=>{ev.preventDefault();zone.classList.add("dragover");}));
    ["dragleave","drop"].forEach(e=>zone.addEventListener(e,ev=>{ev.preventDefault();zone.classList.remove("dragover");}));
    zone.addEventListener("drop",ev=>{ const f=ev.dataTransfer.files[0]; if(f) applyFile(f,zone,icon,cb); });
    input.addEventListener("change",()=>{ if(input.files[0]) applyFile(input.files[0],zone,icon,cb); });
  }
  function applyFile(file,zone,defIcon,cb) {
    zone.classList.add("has-file"); zone.querySelector(".upload-zone-icon").textContent="✅";
    zone.querySelector(".upload-zone-title").textContent=file.name;
    zone.querySelector(".upload-zone-hint").textContent=(file.size/1024).toFixed(0)+" KB";
    if(!zone.querySelector(".remove-file")) {
      const rm=document.createElement("span"); rm.className="remove-file"; rm.textContent="Remover";
      rm.addEventListener("click",ev=>{ev.stopPropagation();ev.preventDefault();
        zone.classList.remove("has-file"); zone.querySelector(".upload-zone-icon").textContent=defIcon;
        zone.querySelector(".upload-zone-title").textContent="Arraste ou clique"; zone.querySelector(".upload-zone-hint").textContent="(.xlsx)";
        rm.remove(); cb(null);
      }); zone.appendChild(rm);
    }
    cb(file);
  }
  // ── Multi-file upload para B2B na aba Cadastrar IES ──
  function renderRegSegChips() {
    const list = $("regSegFileList");
    list.innerHTML = "";
    if (regSegFiles.length === 0) { list.style.display = "none"; return; }
    list.style.display = "flex";
    regSegFiles.forEach((f, i) => {
      const chip = document.createElement("div");
      chip.className = "file-chip";
      chip.innerHTML = `<span title="${f.name}">📊 ${f.name}</span><span class="file-chip-remove" data-i="${i}">✕</span>`;
      chip.querySelector(".file-chip-remove").addEventListener("click", () => {
        regSegFiles.splice(i, 1);
        renderRegSegChips();
        updateRegSegZone();
      });
      list.appendChild(chip);
    });
  }
  function updateRegSegZone() {
    const zone = $("regUploadSeg");
    const icon = zone.querySelector(".upload-zone-icon");
    const title = zone.querySelector(".upload-zone-title");
    const hint = zone.querySelector(".upload-zone-hint");
    if (regSegFiles.length === 0) {
      zone.classList.remove("has-file");
      icon.textContent = "📊";
      title.textContent = "Planilhas B2B (primeiro período)";
      hint.textContent = "Arraste um ou mais arquivos, ou clique para selecionar (.xlsx) — arquivos serão mesclados automaticamente";
    } else {
      zone.classList.add("has-file");
      icon.textContent = "✅";
      title.textContent = `${regSegFiles.length} arquivo${regSegFiles.length > 1 ? "s" : ""} selecionado${regSegFiles.length > 1 ? "s" : ""}`;
      hint.textContent = regSegFiles.map(f => (f.size/1024).toFixed(0) + " KB").join(" + ");
    }
  }
  function addRegSegFiles(newFiles) {
    const existing = new Set(regSegFiles.map(f => f.name + f.size));
    Array.from(newFiles).forEach(f => { if (!existing.has(f.name + f.size)) regSegFiles.push(f); });
    renderRegSegChips();
    updateRegSegZone();
  }
  const regSegZone = $("regUploadSeg"), regSegInput = $("regFileSeg");
  ["dragenter","dragover"].forEach(e => regSegZone.addEventListener(e, ev => { ev.preventDefault(); regSegZone.classList.add("dragover"); }));
  ["dragleave","drop"].forEach(e => regSegZone.addEventListener(e, ev => { ev.preventDefault(); regSegZone.classList.remove("dragover"); }));
  regSegZone.addEventListener("drop", ev => { if (ev.dataTransfer.files.length) addRegSegFiles(ev.dataTransfer.files); });
  regSegInput.addEventListener("change", () => { if (regSegInput.files.length) addRegSegFiles(regSegInput.files); regSegInput.value = ""; });
  regSegZone.addEventListener("click", (e) => { if (e.target !== regSegInput) regSegInput.click(); });
  setupRegUpload("regUploadLogo","regFileLogo","🏛️",f=>{regLogoFile=f;});
  setupRegUpload("regUploadSimTend","regFileSimTend","📈",f=>{
    regSimTendFile=f;
    $("regSimTendFields").style.display = f ? "block" : "none";
  });
  setupRegUpload("regUploadSimPers","regFileSimPers","🎯",f=>{regSimPersFile=f;});

  const THEME_MAP = {
    neutro:{class:"theme-neutro",stripe:"inst-stripe-neutro"},
    amarelo:{class:"theme-facene",stripe:"inst-stripe-facene"},
    azul:{class:"theme-unicet",stripe:"inst-stripe-unicet"},
    verde:{class:"theme-unisc",stripe:"inst-stripe-unisc"},
    roxo:{class:"theme-univassouras",stripe:"inst-stripe-univass"},
    vermelho:{class:"theme-unifeso",stripe:"inst-stripe-unifeso"},
    ciano:{class:"theme-ciano",stripe:"inst-stripe-ciano"},
    rosa:{class:"theme-rosa",stripe:"inst-stripe-rosa"},
    laranja:{class:"theme-laranja",stripe:"inst-stripe-laranja"},
  };

  $("btnGenIES").addEventListener("click", async()=>{
