            <span style="font-size:0.75rem;color:var(--text-muted)">${dataFmt}</span>
            ${prox ? `<span style="font-size:0.7rem;padding:2px 7px;border-radius:5px;background:rgba(234,179,8,0.15);color:#eab308">📅 Próximo: ${prox}</span>` : ''}
          </div>
          <button onclick="window._deletePvAtiv('${a.id}')" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:0.75rem;padding:2px 6px;border-radius:5px;transition:color 0.15s" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">🗑</button>
