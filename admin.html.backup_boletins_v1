window._pvCurrentSlug = '';
window._pvFormOpen = false;

window._openPosVendaModal = async function(slug) {
  window._pvCurrentSlug = slug;
  const inst = (window._instData || []).find(i => i.slug === slug);
  const nome = inst ? (inst.nome || slug.toUpperCase()) : slug.toUpperCase();
  document.getElementById('posVendaTitle').textContent = '🤝 Pós-venda — ' + nome;
  document.getElementById('posVendaSubtitle').textContent = 'Histórico de contatos e atividades com esta IES';
  // Reset form
  document.getElementById('pvTipo').value = 'reuniao';
  document.getElementById('pvData').value = new Date().toISOString().split('T')[0];
  document.getElementById('pvParticipantes').value = '';
  document.getElementById('pvDescricao').value = '';
  document.getElementById('pvProximoContato').value = '';
  document.getElementById('pvSaveError').textContent = '';
  if (window._pvFormOpen) { document.getElementById('pvExtraFields').style.display = 'none'; window._pvFormOpen = false; document.getElementById('pvAddQuickBtn').textContent = '+ Detalhes'; }

  const modal = document.getElementById('posVendaModal');
  modal.style.display = 'flex';
  modal.onclick = (e) => { if (e.target === modal) modal.style.display = 'none'; };
  await window._loadPvAtividades(slug);
};

window._togglePvForm = function() {
  const el = document.getElementById('pvExtraFields');
  const btn = document.getElementById('pvAddQuickBtn');
  window._pvFormOpen = !window._pvFormOpen;
  el.style.display = window._pvFormOpen ? 'grid' : 'none';
  btn.textContent = window._pvFormOpen ? '▲ Menos' : '+ Detalhes';
};

const _PV_TIPO_LABELS = { reuniao:'🤝 Reunião', ligacao:'📞 Ligação', email:'📧 E-mail', visita:'🏢 Visita', outro:'📌 Outro' };
const _PV_TIPO_COLORS = { reuniao:'rgba(34,197,94,0.12)', ligacao:'rgba(59,130,246,0.12)', email:'rgba(168,85,247,0.12)', visita:'rgba(249,115,22,0.12)', outro:'rgba(100,116,139,0.12)' };
const _PV_TIPO_TEXT   = { reuniao:'var(--green)', ligacao:'var(--blue)', email:'#a855f7', visita:'#f97316', outro:'var(--text-muted)' };

window._loadPvAtividades = async function(slug) {
  const listEl = document.getElementById('pvAtivList');
  listEl.innerHTML = '<div style="text-align:center;padding:20px;color:var(--text-muted);font-size:0.82rem">Carregando...</div>';
  try {
    const SUPA_URL = 'https://cvwwucxjrpsfoxarsipr.supabase.co';
    const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImN2d3d1Y3hqcnBzZm94YXJzaXByIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzMDIxMzgsImV4cCI6MjA5MDg3ODEzOH0.GdpReqo9giSC607JQge8HA9CmZWi-2TcVggU4jCwZhI';
    const resp = await fetch(
      `${SUPA_URL}/rest/v1/atividades_contrato?ies_slug=eq.${slug}&order=data.desc,created_at.desc`,
      { headers: { 'apikey': SUPA_KEY, 'Authorization': `Bearer ${SUPA_KEY}` } }
    );
    const items = resp.ok ? await resp.json() : [];
    if (!items.length) {
      listEl.innerHTML = '<div style="text-align:center;padding:24px;color:var(--text-muted);font-size:0.82rem">Nenhuma atividade registrada ainda.</div>';
      return;
    }
    listEl.innerHTML = items.map(a => {
      const tipo = a.tipo || 'outro';
      const label = _PV_TIPO_LABELS[tipo] || tipo;
      const bg = _PV_TIPO_COLORS[tipo] || _PV_TIPO_COLORS.outro;
      const txtColor = _PV_TIPO_TEXT[tipo] || _PV_TIPO_TEXT.outro;
      const dataFmt = a.data ? new Date(a.data + 'T12:00:00').toLocaleDateString('pt-BR', {day:'2-digit',month:'short',year:'numeric'}) : '—';
      const prox = a.proximo_contato ? new Date(a.proximo_contato + 'T12:00:00').toLocaleDateString('pt-BR', {day:'2-digit',month:'short'}) : '';
      return `<div style="background:${bg};border:1px solid rgba(255,255,255,0.05);border-radius:11px;padding:14px 16px;margin-bottom:10px;position:relative">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;flex-wrap:wrap;gap:6px">
