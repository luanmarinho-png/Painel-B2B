        <div><div style="font-size:0.9rem;font-weight:700">${name}</div><div style="font-size:0.73rem;color:var(--text-muted)">${nAlunos} alunos · Média ${media.toFixed(1)}% · ${nAreas} áreas · ${nPeriods} período(s) engajamento</div></div>
      </div>
      <div style="display:flex;gap:14px;align-items:flex-end;margin-bottom:16px">
