            <input type="color" value="${cor}" style="width:24px;height:24px;border:none;padding:0;cursor:pointer;border-radius:4px" onchange="localStorage.setItem('simPdfCor_${i.slug}',this.value)">
            <span style="font-size:0.68rem;color:var(--text-muted)">Cor PDF</span>
