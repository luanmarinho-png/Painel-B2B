      // Admin snippet — build card HTML and script tag separately for injection
      const stripe=theme.stripe||"inst-stripe-unicet";
      const cardHTML=`\n      <!-- ${name} -->\n      <a class="inst-card" target="_blank" href="${slug}/index.html" data-inst="${slug}">\n        <div class="inst-card-stripe ${stripe}"></div>\n        <div class="inst-card-arrow"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></div>\n        <div class="inst-card-header">\n          <div class="inst-card-logo-wrap"><img src="${slug}/${logo}" alt="${name}" onerror="this.outerHTML='<span class=inst-initials>${initials}</span>'"></div>\n          <div><div class="inst-card-name">${name}</div><div class="inst-card-sub">${city}</div></div>\n        </div>\n        <div class="inst-card-meta"><div class="inst-card-meta-item"><strong class="inst-alunos">—</strong> alunos ativos</div><div class="inst-last-update" style="display:none"></div></div>\n        <div class="inst-card-status"><span class="inst-card-status-dot"></span> Ativo</div>\n        <div class="inst-sim-badge inst-sim-loading">—</div>\n        <button class="inst-contrato-btn" onclick="event.preventDefault();event.stopPropagation();window.open('admin-contrato.html?ies='+this.closest('.inst-card').dataset.inst,'_blank')">📋 Dados do Contrato</button>\n      </a>`;
