window.bqSaveEditSim = async function(simId) {
  const titulo = ($b('bqEditTit')?.value||'').trim();
  if (!titulo) { alert('Informe o título.'); return; }
  const ies = [...document.querySelectorAll('input[name="bqEditDestIES"]:checked')].map(c => c.value);
  const pdfIes = ($b('bqEditPdfIES')?.value||'').trim();
  let pdfCor = ($b('bqEditPdfCorHex')?.value||'').trim();
  if (pdfCor && !/^#[0-9a-fA-F]{6}$/.test(pdfCor)) pdfCor = '';
  const { error } = await _sb.from('simulados_banco').update({
    titulo,
    edital_num: ($b('bqEditEdt')?.value||'').trim(),
    instituicoes_destino: ies,
    pdf_instituicao: pdfIes,
    pdf_cor: pdfCor
  }).eq('id', simId);
  if (error) { alert('Erro: ' + error.message); return; }
  window.bqCloseModal();
  await bqInit();
};

function _loadScript(src) {
  return new Promise((res, rej) => {
    const s = document.createElement('script');
    s.src = src; s.onload = res; s.onerror = rej;
    document.head.appendChild(s);
  });
}

})(); // end IIFE
