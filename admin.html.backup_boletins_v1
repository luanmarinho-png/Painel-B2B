  // ── Rank parsing ─────────────────────────────────────────────
  function parseRank(str) {
    str=String(str||"").trim();
    const m=str.match(/(\d+)\s*[\/|]\s*(\d+)/);
    if(m) return {rank:parseInt(m[1]),total:parseInt(m[2])};
    const n=str.match(/(\d+)/);
    return {rank:n?parseInt(n[1]):0,total:0};
  }

  // ── Excel reader ─────────────────────────────────────────────
  function readExcelFile(file) {
    return new Promise((resolve,reject)=>{
      const r=new FileReader();
      r.onload=e=>{ try{resolve(XLSX.read(e.target.result,{type:"binary",cellDates:true}));}catch(err){reject(err);} };
      r.onerror=()=>reject(new Error("Erro ao ler arquivo"));
      r.readAsBinaryString(file);
    });
  }

  function findSheet(wb, hint) {
    for(const n of wb.SheetNames) if(n.toLowerCase().includes(hint.toLowerCase())) return wb.Sheets[n];
    return wb.Sheets[wb.SheetNames[0]];
  }

  function wsToRows(ws) { return XLSX.utils.sheet_to_json(ws,{header:1,defval:"",raw:false}); }

  function findHeaderRow(rows, kws) {
    for(let i=0;i<Math.min(rows.length,20);i++){
      const s=rows[i].join(" ").toLowerCase();
      if(kws.every(k=>s.includes(k.toLowerCase()))) return i;
    }
    for(let i=0;i<Math.min(rows.length,20);i++){
      const s=rows[i].join(" ").toLowerCase();
      if(kws.some(k=>s.includes(k.toLowerCase()))) return i;
    }
    return 0;
  }

  function findCol(hdr, kws) {
    for(const k of kws){ const i=hdr.findIndex(c=>String(c).toLowerCase().includes(k.toLowerCase())); if(i>=0) return i; }
    return -1;
  }

  // ── Title case ───────────────────────────────────────────────
  const _minor=new Set(["de","da","do","das","dos","e","em","a","o","as","os"]);
  function tc(str) {
    if(!str) return "";
    return String(str).toLowerCase().trim().split(/\s+/).map((w,i)=>
      (i!==0&&_minor.has(w))?w:w.charAt(0).toUpperCase()+w.slice(1)
    ).join(" ");
  }

