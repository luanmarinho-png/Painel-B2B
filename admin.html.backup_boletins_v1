  // ── Modal PDF ──────────────────────────────────────────────
  window._simOpenPdfModal = function(slug) {
    const ds = window.INSTITUTION_DATASETS || {};
    const inst = ds[slug]; if(!inst) return;
    const name = inst.institutionName || slug.toUpperCase();
    const cor = localStorage.getItem('simPdfCor_'+slug) || '#B01B1B';
    const logoSrc = inst.institutionLogoSrc || `logo_${slug}.png`;
    const hasTend = inst.resultsData && inst.resultsData.length > 0;
    if(!hasTend) { alert('Cadastre o Simulado Tendências antes de gerar o PDF.'); return; }
    // Compute quick stats
    const nAlunos = inst.resultsData.length;
    const media = inst.benchmark?.institutionScore || 0;
    const nAreas = (inst.areasData||[]).length;
