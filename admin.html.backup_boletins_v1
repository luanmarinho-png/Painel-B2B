          <span>• Análise pedagógica com recomendações</span>
        </div>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button class="btn-secondary" style="padding:10px 18px" onclick="document.getElementById('simPdfModal').style.display='none'">Cancelar</button>
        <button class="btn-primary" style="padding:10px 18px" onclick="window._simGeneratePDF('${slug}')">📄 Gerar e baixar PDF</button>
      </div>`;
