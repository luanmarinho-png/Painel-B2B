    </div>
    <div class="login-footer">Grupo MedCof &copy; 2026 — Uso interno</div>
  </div>
</div>

<!-- ═══════════ DASHBOARD ═══════════ -->
<div class="dashboard" id="dashboard">
  <div class="dash-topbar">
    <div class="dash-topbar-brand">
      <img src="facene/logo-novo-medcof.avif" alt="MedCof" class="dash-topbar-logo" onerror="this.style.display='none'">
      <span class="dash-topbar-title">B2B Control</span>
      <span class="dash-topbar-tag">Admin</span>
    </div>
    <div class="dash-topbar-right">
      <span class="dash-topbar-user" id="topbarUser">—</span>
      <button class="dash-logout-btn" id="logoutBtn">Sair</button>
    </div>
  </div>

  <div class="dash-content">

    <div class="dash-tabs">
      <button class="dash-tab active" data-tab="institutions">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Instituições
      </button>
      <button class="dash-tab" data-tab="update">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Atualizar Dados
      </button>
      <button class="dash-tab" data-tab="register" style="display:none">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        Cadastrar IES
      </button>
      <button class="dash-tab" data-tab="simulados">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Simulados
      </button>
      <button class="dash-tab" data-tab="cadastro-sim">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Cadastro de Simulados
      </button>
      <button class="dash-tab" data-tab="users">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Usuários
      </button>
    </div>

    <!-- ═══════════ TAB 1: INSTITUIÇÕES ═══════════ -->
    <div class="tab-panel active" id="tab-institutions">
      <div class="dash-hero">
        <div class="dash-hero-pill">Operacional</div>
        <h1>Painéis Institucionais</h1>
        <p>Selecione a instituição para acessar o painel de acompanhamento.</p>
      </div>
      <div class="dash-stats" id="dashStats">
        <div class="dash-stat"><div class="dash-stat-number" id="statAlunos">—</div><div class="dash-stat-label">Alunos ativos B2B</div></div>
        <div class="dash-stat"><div class="dash-stat-number" id="statQuestoes">—</div><div class="dash-stat-label">Questões realizadas</div></div>
        <div class="dash-stat"><div class="dash-stat-number" id="statHoras">—</div><div class="dash-stat-label">Horas de estudo</div></div>
        <div class="dash-stat"><div class="dash-stat-number" id="statMedia">—</div><div class="dash-stat-label">Instituições cadastradas</div></div>
      </div>
      <div class="dash-section-title">Instituições parceiras</div>

      <!-- Banner: IES com dados desatualizados há +15 dias -->
      <div id="staleUpdateBanner" style="display:none;margin-bottom:14px;border-radius:12px;overflow:hidden;border:1px solid rgba(239,68,68,0.25)">
        <div style="background:rgba(239,68,68,0.08);padding:12px 16px;display:flex;align-items:flex-start;gap:12px">
          <span style="font-size:1.1rem;flex-shrink:0">🔴</span>
          <div style="flex:1;min-width:0">
            <div style="font-size:0.8rem;font-weight:800;color:#ef4444;margin-bottom:6px">Dados desatualizados há mais de 15 dias</div>
            <div id="staleUpdateList" style="display:flex;flex-wrap:wrap;gap:6px"></div>
          </div>
        </div>
      </div>

      <div class="dash-grid" id="instGrid">
        <div id="instGridLoading" style="color:var(--text-muted);padding:20px;grid-column:1/-1">Carregando instituições...</div>
      </div>
    </div>

    <!-- ═══════════ TAB 2: ATUALIZAR DADOS ═══════════ -->
    <div class="tab-panel" id="tab-update">
      <div class="section-title-row">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Atualizar dados de uma instituição
      </div>
      <p class="section-desc">
        Selecione a instituição e envie a planilha exportada da plataforma.
        As datas do período são lidas automaticamente da planilha. O processamento acontece direto no navegador.
      </p>

      <!-- Instituição -->
      <div class="field" style="max-width:340px;margin-bottom:20px">
        <label for="updateInst">Instituição <span class="req">*</span></label>
        <select id="updateInst"><option value="">Selecione...</option></select>
      </div>

      <!-- Configuração de períodos -->
      <div class="subsection">
        <div class="subsection-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Planilha de engajamento
        </div>
      </div>
      <div class="field-grid" style="margin-bottom:16px">
        <div class="field" style="max-width:200px">
          <label>Quantos períodos? <span class="req">*</span></label>
          <select id="updatePeriodCount" onchange="window._generatePeriodSlots()">
            <option value="1" selected>1 período</option>
            <option value="2">2 períodos</option>
            <option value="3">3 períodos</option>
            <option value="4">4 períodos</option>
            <option value="5">5 períodos</option>
          </select>
        </div>
        <div class="field" style="max-width:200px">
          <label>Tipo de período</label>
          <select id="updatePeriodType">
            <option value="quinzenal">Quinzenal</option>
            <option value="semanal">Semanal</option>
          </select>
        </div>
      </div>

      <!-- Slots de período (gerados dinamicamente) -->
      <div id="periodSlotsContainer"></div>

      <!-- Fallback: upload zone original (oculto, usado pelo JS legacy) -->
      <div style="display:none">
        <div class="upload-zone" id="uploadSeguimento">
          <div class="upload-zone-icon">📊</div>
          <div class="upload-zone-title">Planilhas B2B (quinzena)</div>
          <div class="upload-zone-hint">(.xlsx)</div>
          <input type="file" accept=".xlsx,.xls" id="fileSeguimento" multiple>
        </div>
        <input type="date" id="segDateStart">
        <input type="date" id="segDateEnd">
        <div id="segFileList"></div>
      </div>
      <div class="hint" style="margin-top:6px;margin-bottom:20px">Colunas usadas: Nome · Aulas Assistidas · Questões Realizadas · Questões Acertadas · Flashcards Realizados · Horas por Dia. A turma é atribuída automaticamente pelo sistema.</div>

      <!-- Exclusão -->
      <div class="field" style="margin-top:4px">
        <label for="exclusionList">Lista de exclusão <span class="opt">(opcional — um nome por linha, ou importe planilha)</span></label>
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px">
          <button type="button" onclick="document.getElementById('exclusionFile').click()" style="padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:var(--bg-elevated);color:var(--text-soft);font-size:0.78rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;white-space:nowrap">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Importar planilha de exclusão
          </button>
          <span id="exclusionFileInfo" style="font-size:0.72rem;color:var(--text-muted)"></span>
          <input type="file" id="exclusionFile" accept=".csv,.xlsx,.xls" style="display:none" onchange="window._loadExclusionFile(this.files[0])">
        </div>
        <textarea class="text-area" id="exclusionList" placeholder="Ex:&#10;FULANO DE TAL&#10;CICLANO DA SILVA"></textarea>
      </div>

      <!-- Botão -->
      <div class="btn-row">
        <button class="btn-primary" id="btnProcess" disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
          Processar e gerar arquivo
        </button>
      </div>

      <div class="log-area" id="processLog" style="display:none"></div>

      <div class="preview-card" id="previewCard" style="display:none">
        <div class="preview-title">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          Prévia dos dados processados
        </div>
        <div class="preview-stats" id="previewStats"></div>
        <div class="preview-sheets" id="previewSheets"></div>
        <div class="preview-table-wrap">
          <table class="preview-table" id="previewTable"><thead id="previewThead"></thead><tbody id="previewTbody"></tbody></table>
        </div>
        <div class="btn-row" style="margin-top:24px">
          <button class="btn-deploy" id="btnAutoDeploy">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            🚀 Deploy automático
          </button>
          <button class="btn-secondary" id="btnDownload">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Baixar ZIP (fallback)
          </button>
        </div>
        <div class="deploy-progress" id="deployProgress"></div>
      </div>

      <div class="success-banner" id="successBanner">
        <div class="success-banner-title">Arquivo gerado com sucesso!</div>
        <div class="success-banner-text" id="successText"></div>
      </div>
    </div>

    <!-- ═══════════ TAB 3: CADASTRAR IES ═══════════ -->
    <div class="tab-panel" id="tab-register" style="display:none">
      <div class="section-title-row">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        Cadastrar nova instituição parceira
      </div>
      <p class="section-desc">
        Preencha os dados da IES e envie a planilha exportada da plataforma.
        As datas são lidas automaticamente da planilha. O sistema gera todos os arquivos prontos para deploy.
      </p>

      <!-- Dados institucionais -->
      <div class="subsection-title" style="margin-bottom:16px">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Dados da instituição
      </div>
      <div class="field-grid" style="margin-bottom:20px">
        <div class="field">
          <label for="regName">Nome <span class="req">*</span></label>
          <input type="text" id="regName" placeholder="Ex: FAMENE">
          <div class="hint">Será usado em maiúsculo nos painéis</div>
        </div>
        <div class="field">
          <label for="regSlug">Slug <span class="req">*</span></label>
          <input type="text" id="regSlug" placeholder="Ex: famene">
          <div class="hint">Minúsculo, sem espaços — nome da pasta</div>
        </div>
        <div class="field">
          <label for="regCity">Cidade — UF</label>
          <input type="text" id="regCity" placeholder="Ex: João Pessoa — PB">
        </div>
        <div class="field">
          <label for="regInitials">Sigla</label>
          <input type="text" id="regInitials" placeholder="Ex: FM" maxlength="4">
        </div>
      </div>
      <div class="field" style="margin-bottom:24px">
        <label>Cor tema</label>
        <div class="color-options" id="colorOptions">
          <div class="color-opt selected" data-color="neutro"   style="background:linear-gradient(135deg,#475569,#94a3b8)" title="Neutro (padrão)"></div>
          <div class="color-opt"          data-color="azul"     style="background:linear-gradient(135deg,#0284c7,#38bdf8)" title="Azul"></div>
          <div class="color-opt"          data-color="vermelho" style="background:linear-gradient(135deg,#dc2626,#f87171)" title="Vermelho"></div>
          <div class="color-opt"          data-color="verde"    style="background:linear-gradient(135deg,#059669,#34d399)" title="Verde"></div>
          <div class="color-opt"          data-color="roxo"     style="background:linear-gradient(135deg,#7c3aed,#a78bfa)" title="Roxo"></div>
          <div class="color-opt"          data-color="amarelo"  style="background:linear-gradient(135deg,#a07d08,#c8960c)" title="Amarelo"></div>
          <div class="color-opt"          data-color="ciano"    style="background:linear-gradient(135deg,#0e6080,#0891b2)" title="Ciano"></div>
          <div class="color-opt"          data-color="rosa"     style="background:linear-gradient(135deg,#be185d,#ec4899)" title="Rosa"></div>
          <div class="color-opt"          data-color="laranja"  style="background:linear-gradient(135deg,#c2410c,#f97316)" title="Laranja"></div>
        </div>
      </div>

      <!-- Logo da IES -->
      <div class="field" style="margin-bottom:24px">
        <label>Logo da instituição <span class="opt">(opcional)</span></label>
        <div class="upload-zone" id="regUploadLogo" style="min-height:80px;padding:16px">
          <div class="upload-zone-icon">🏛️</div>
          <div class="upload-zone-title">Logo da IES</div>
          <div class="upload-zone-hint">Arquivo PNG ou SVG com fundo transparente · Arraste ou clique</div>
          <input type="file" accept=".png,.svg,.jpg,.jpeg,.webp" id="regFileLogo">
        </div>
        <div class="hint" style="margin-top:6px">Será salva como <code>logo_{slug}.png</code> na pasta da IES.</div>
      </div>

      <!-- Planilha B2B unificada -->
      <div class="subsection">
        <div class="subsection-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Planilha de engajamento
        </div>
      </div>
      <!-- Datas do período (dupla checagem) -->
      <div class="field-grid" style="margin-bottom:16px">
        <div class="field">
          <label for="regDateStart">Início do período <span class="opt">(verificação)</span></label>
          <input type="date" id="regDateStart">
        </div>
        <div class="field">
          <label for="regDateEnd">Término do período <span class="opt">(verificação)</span></label>
          <input type="date" id="regDateEnd">
        </div>
      </div>

      <div class="field" style="margin-bottom:20px">
        <label>Exportação B2B da plataforma <span class="req">*</span></label>
        <div class="upload-zone" id="regUploadSeg">
          <div class="upload-zone-icon">📊</div>
          <div class="upload-zone-title">Planilhas B2B (primeiro período)</div>
          <div class="upload-zone-hint">Arraste um ou mais arquivos, ou clique para selecionar (.xlsx) — arquivos serão mesclados automaticamente</div>
          <input type="file" accept=".xlsx,.xls" id="regFileSeg" multiple>
        </div>
        <div id="regSegFileList" style="display:none;margin-top:8px;display:flex;flex-wrap:wrap;gap:6px"></div>
        <div class="hint" style="margin-top:6px">Colunas usadas: Nome · Aulas Assistidas · Questões Realizadas · Questões Acertadas · Flashcards Realizados · Horas por Dia. A turma é atribuída automaticamente pelo sistema.</div>
      </div>

      <!-- Acesso da IES -->
      <div class="subsection">
        <div class="subsection-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Acesso da instituição
        </div>
      </div>
      <div class="field" style="margin-bottom:20px">
        <label>Usuários autorizados</label>
        <!-- Estado: aguardando slug -->
        <div id="regAccessPlaceholder">
          <div class="hint">Informe o slug da IES acima para consultar os usuários já cadastrados.</div>
        </div>
        <!-- Estado: carregando -->
        <div id="regAccessLoading" style="display:none">
          <div class="hint" style="color:var(--text-muted)">Consultando Supabase…</div>
        </div>
        <!-- Estado: lista de usuários encontrados -->
        <div id="regAccessList" style="display:none;margin-top:6px"></div>
        <!-- Estado: nenhum usuário -->
        <div id="regAccessEmpty" style="display:none">
          <div class="hint">Nenhum usuário cadastrado para este slug ainda.</div>
        </div>
        <!-- Botão para ir à aba Usuários -->
        <div id="regAccessActions" style="display:none;margin-top:12px">
          <button type="button" class="btn-secondary" id="btnGoToUsers" style="padding:9px 18px;font-size:0.82rem;gap:6px">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Gerenciar usuários desta IES →
          </button>
        </div>
      </div>

      <div class="field" style="margin-bottom:20px">
        <label for="regExclusion">Lista de exclusão <span class="opt">(opcional — um nome por linha)</span></label>
        <textarea class="text-area" id="regExclusion" placeholder="Ex:&#10;FULANO DE TAL&#10;CICLANO DA SILVA"></textarea>
      </div>

      <!-- Botão -->
      <div class="btn-row">
        <button class="btn-primary" id="btnGenIES">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
          Cadastrar e gerar arquivos
        </button>
      </div>

      <div class="log-area" id="regLog" style="display:none"></div>

      <!-- Preview da IES nova -->
