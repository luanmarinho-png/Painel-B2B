      </div>`;
    } else {
      banner.style.display = 'none';
    }
  }

  // ── Ordenar por total de simulados vinculados (decrescente) ───────
  const sorted = [...instWithCounts].sort((a, b) => b.totalLinked - a.totalLinked);

  // ── Aplicar filtro de mês ─────────────────────────────────────────
  const toRender = isMonthFilter ? sorted.filter(ic => ic.hasThisMonth) : sorted;

