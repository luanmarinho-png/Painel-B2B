      list.appendChild(chip);
    });
  }

  function updateSegZone() {
    const zone = $("uploadSeguimento");
    const icon = zone.querySelector(".upload-zone-icon");
    const title = zone.querySelector(".upload-zone-title");
    const hint = zone.querySelector(".upload-zone-hint");
    if (segFiles.length === 0) {
      zone.classList.remove("has-file");
      icon.textContent = "📊";
      title.textContent = "Planilhas B2B (quinzena)";
      hint.textContent = "Arraste um ou mais arquivos, ou clique para selecionar (.xlsx) — arquivos serão mesclados automaticamente";
    } else {
      zone.classList.add("has-file");
