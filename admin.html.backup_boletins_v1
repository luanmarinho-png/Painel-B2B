// ── Helper: badge de código clicável (copiar + info duplicatas) ──
function _buildReuseBadge(q) {
  if (!q.codigo_questao) return '<span style="font-size:0.7rem;color:var(--text-muted)">—</span>';
  // Duplicata = mesmo codigo em OUTRO simulado (não no mesmo)
  const dupes = _qs.filter(x => x.codigo_questao && x.codigo_questao === q.codigo_questao && x.simulado_id !== q.simulado_id);
  const codShort = esc(q.codigo_questao.length > 12 ? q.codigo_questao.substring(0,12)+'…' : q.codigo_questao);
  const fullCode = esc(q.codigo_questao);
  const copyJs = `navigator.clipboard.writeText('${fullCode}').then(()=>{const t=this.querySelector('.bq-copy-ok');if(t){t.style.display='inline';setTimeout(()=>t.style.display='none',1200);}})`;

  if (!dupes.length) {
    return `<span style="cursor:pointer;font-family:monospace;font-size:0.68rem;background:var(--bg-elevated);padding:2px 6px;border-radius:4px;color:var(--text-muted)" onclick="${copyJs}" title="Clique para copiar">${codShort}<span class="bq-copy-ok" style="display:none;color:var(--green);margin-left:4px">ok</span></span>`;
  }
  const simNames = [...new Set(dupes.map(d => { const s = _sims.find(s => s.id === d.simulado_id); return s ? s.titulo : '?'; }))];
  const provaInfo = [...new Set(dupes.map(d => [d.instituicao_questao,d.tipo_prova,d.ano_prova].filter(Boolean).join(' ')))];
  const tooltipItems = simNames.map(n => `<div style="padding:2px 0;font-size:0.72rem">• ${esc(n)}</div>`).join('');
  const provaLine = provaInfo[0] ? `<div style="font-size:0.68rem;color:#9ca3af;margin-top:4px;border-top:1px solid #333;padding-top:4px">Prova: ${esc(provaInfo.join(', '))}</div>` : '';
  return `<span style="position:relative;cursor:pointer" class="bq-reuse-wrap" onclick="${copyJs}">
    <span style="font-family:monospace;font-size:0.68rem;background:var(--bg-elevated);padding:2px 6px;border-radius:4px;color:var(--amber);border:1px solid rgba(245,158,11,0.3)">${codShort} <span style="font-size:0.62rem;font-weight:700;opacity:0.8">em ${simNames.length+1}</span></span>
    <span class="bq-copy-ok" style="display:none;color:var(--green);font-size:0.65rem;margin-left:3px">ok</span>
    <div class="bq-reuse-tooltip"><div style="font-size:0.68rem;color:#9ca3af;margin-bottom:4px">Presente em ${simNames.length+1} simulados:</div><div style="padding:1px 0;font-size:0.72rem;color:var(--green)">• ${esc(_simName(q.simulado_id))} (atual)</div>${tooltipItems}${provaLine}<div style="font-size:0.65rem;color:#6b7280;margin-top:6px;text-align:center">Clique para copiar código</div></div>
  </span>`;
}

// ── Helper: filtro comum de questões ─────────────────────────────
function _filterQs(qs, opts) {
  if (opts.sim)    qs = qs.filter(q => q.simulado_id === opts.sim);
  if (opts.status) qs = qs.filter(q => q.status === opts.status);
  if (opts.area)   qs = qs.filter(q => q.grande_area === opts.area);
  if (opts.dif)    qs = qs.filter(q => q.dificuldade === opts.dif);
  if (opts.texto) {
    const t = opts.texto.toLowerCase();
    qs = qs.filter(q => ((q.enunciado||'')+(q.tema||'')+(q.grande_area||'')+(q.codigo_questao||'')).toLowerCase().includes(t));
  }
  if (opts.dup === 'sim') qs = qs.filter(q => q.codigo_questao && _qs.some(x => x.codigo_questao === q.codigo_questao && x.simulado_id !== q.simulado_id));
  if (opts.dup === 'nao') qs = qs.filter(q => !q.codigo_questao || !_qs.some(x => x.codigo_questao === q.codigo_questao && x.simulado_id !== q.simulado_id));
  return qs;
}

