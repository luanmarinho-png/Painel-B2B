function filterUsers() {
  const search = document.getElementById('userSearch').value.toLowerCase();
  const instFilter = document.getElementById('userFilterInst').value;
  const roleFilter = document.getElementById('userFilterRole').value;

  const filtered = allUsers.filter(u => {
    const matchSearch = !search || (u.email || '').toLowerCase().includes(search) || (u.nome || '').toLowerCase().includes(search);
    const matchInst = !instFilter || (u.instituicao || '') === instFilter;
    const matchRole = !roleFilter || (u.role || 'coordenador') === roleFilter;
    return matchSearch && matchInst && matchRole;
  });

  renderUsers(filtered);
}

