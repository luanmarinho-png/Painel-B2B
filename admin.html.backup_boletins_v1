  };

  // ── GERAÇÃO DO PDF INSTITUCIONAL ───────────────────────────
  window._simGeneratePDF = async function(slug) {
    const ds = window.INSTITUTION_DATASETS || {};
    const inst = ds[slug]; if(!inst || !inst.resultsData?.length) { alert('Sem dados de Tendências.'); return; }
    const name = inst.institutionName || slug.toUpperCase();
    const corHex = ($("simPdfCorHex")?.value||'').trim() || localStorage.getItem('simPdfCor_'+slug) || '#B01B1B';
    if(!/^#[0-9a-fA-F]{6}$/.test(corHex)) { alert('Cor hexadecimal inválida.'); return; }
    localStorage.setItem('simPdfCor_'+slug, corHex);

    // Load jsPDF
    if(typeof window.jspdf==='undefined') {
      const ls = s => new Promise((r,j) => { const e=document.createElement('script');e.src=s;e.onload=r;e.onerror=j;document.head.appendChild(e); });
      await ls('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');
      await ls('https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js');
    }
    const jsPDF = window.jspdf?.jsPDF; if(!jsPDF) { alert('Erro ao carregar biblioteca PDF.'); return; }

    // Parse color
    const hx = s => { const m=s.match(/^#?([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})$/i); return m?[parseInt(m[1],16),parseInt(m[2],16),parseInt(m[3],16)]:[176,27,27]; };
    const ACCENT = hx(corHex);
    const ACCENTBG = [Math.round(255*0.92+ACCENT[0]*0.08), Math.round(255*0.92+ACCENT[1]*0.08), Math.round(255*0.92+ACCENT[2]*0.08)];

    // Colors
    const WH=[255,255,255], BG=[247,248,252], TEXT=[20,22,38], SOFT=[72,77,102], MUTED=[140,145,168];
    const DARK=[26,30,52], CARD=[237,240,250], BORD=[198,203,220], GREEN=[22,128,60];

    // Data
    const results = inst.resultsData || [];
    const bench = inst.benchmark || {};
    const areas = inst.areasData || [];
    const scores = inst.allSimuladoScores || results.map(r=>r.nota).sort((a,b)=>b-a);
    const totalAlunos = results.length;
    const mediaIES = bench.institutionScore || 0;

    // ── CRUZAR ENGAJAMENTO × PROFICIÊNCIA ──
    const allPeriods = inst.allData || [];
    const normN = s => (s||'').trim().toUpperCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,' ');
    // Build engagement map: nome → { questoes, tempo_min, logins, aulas }
    const engMap = {};
    allPeriods.forEach(p => {
      (p.alunos||p.data||[]).forEach(a => {
        const k = normN(a.nome);
        if(!engMap[k]) engMap[k] = { questoes:0, tempo_min:0, logins:0, aulas:0 };
        engMap[k].questoes += a.questoes||0;
        engMap[k].tempo_min += a.tempo_min||0;
        engMap[k].logins += a.logins||0;
        engMap[k].aulas += a.aulas||0;
      });
    });
    // Calculate days in period (rough: count distinct periods × 15 days avg)
    const totalDays = Math.max(allPeriods.length * 15, 1);
    // Classify each student
    const enriched = results.map(r => {
      const eng = engMap[normN(r.nome)] || null;
      const qDia = eng ? eng.questoes / totalDays : 0;
      // Traction band: ≥20 alta, 10-19 moderada, <10 baixa
      const traction = qDia >= 20 ? 'alta' : (qDia >= 10 ? 'moderada' : 'baixa');
      // Result band: ≥60 proficiente, 49-59 quase, <49 urgente
      const band = r.nota >= 60 ? 'proficiente' : (r.nota >= 49 ? 'quase' : 'urgente');
      // Context (from getResultContext logic)
      let flag, flagLabel, recommendation;
      if(r.nota>=60 && traction!=='baixa') { flag='green'; flagLabel='Proficiente com sustentação'; recommendation='Manter cadência e usar como referência positiva da turma.'; }
      else if(r.nota>=60 && traction==='baixa') { flag='grey'; flagLabel='Proficiente com baixo engajamento'; recommendation='Preservar rotina para evitar oscilação de desempenho.'; }
      else if(r.nota>=49 && traction==='alta') { flag='yellow'; flagLabel='Quase proficiente com avanço'; recommendation='Ajustar foco de estudo para converter engajamento em proficiência.'; }
      else if(r.nota>=49 && traction==='baixa') { flag='orange'; flagLabel='Quase proficiente com baixo engajamento'; recommendation='Aumentar constância e frequência antes do próximo ciclo.'; }
      else if(r.nota<49 && traction!=='baixa') { flag='red'; flagLabel='Atenção urgente com esforço'; recommendation='Revisar estratégia, método e qualidade da prática.'; }
      else { flag='black'; flagLabel='Atenção urgente'; recommendation='Contato prioritário e plano semanal de acompanhamento.'; }
      return { ...r, eng, qDia, traction, band, flag, flagLabel, recommendation };
    });

    // Stats for risk map
    const tempoMedio = Object.values(engMap).length ? Object.values(engMap).reduce((s,e)=>s+e.tempo_min,0)/Object.values(engMap).length : 0;
    const greenCount = enriched.filter(e=>e.flag==='green').length;
    const greyCount = enriched.filter(e=>e.flag==='grey').length;
    const yellowCount = enriched.filter(e=>e.flag==='yellow').length;
    const orangeCount = enriched.filter(e=>e.flag==='orange').length;
    const redCount = enriched.filter(e=>e.flag==='red').length;
    const blackCount = enriched.filter(e=>e.flag==='black').length;

    // Distribution bins
    const bins = Array(10).fill(0);
    scores.forEach(s => { const b = Math.min(Math.floor(s/10),9); bins[b]++; });

    // Logo
    let logoDataUrl = null;
    try {
      const img = new Image(); img.crossOrigin='anonymous';
      const logoPath = `${slug}/${inst.institutionLogoSrc||'logo_'+slug+'.png'}`;
      await new Promise((res,rej)=>{img.onload=res;img.onerror=rej;img.src=logoPath;setTimeout(rej,3000);});
      const cv=document.createElement('canvas');cv.width=img.naturalWidth;cv.height=img.naturalHeight;cv.getContext('2d').drawImage(img,0,0);
      logoDataUrl=cv.toDataURL('image/png');
    } catch(e){}

    // ── BUILD PDF ──
    const doc = new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
    const W=210, PL=18, PR=18, PW=W-PL-PR;
    let y, pageNum=0;
    function pageBg(){doc.setFillColor(...BG);doc.rect(0,0,W,297,'F');}
    function newPage(){if(pageNum>0)doc.addPage();pageBg();pageNum++;y=20;}
    function checkY(n=20){if(y+n>275){footer();newPage();}}
    function footer(){doc.setFont('helvetica','normal');doc.setFontSize(7);doc.setTextColor(...MUTED);doc.text(`${name} × MedCof · Relatório de Simulado Tendências · Página ${pageNum}`,W/2,291,{align:'center'});doc.setFillColor(...ACCENT);doc.rect(0,293,W,2,'F');}
    function sectionHdr(num,title){checkY(16);doc.setFillColor(...DARK);doc.rect(PL-2,y-5,PW+4,11,'F');doc.setFont('helvetica','bold');doc.setFontSize(9.5);doc.setTextColor(...WH);doc.text(`${num}. ${title}`,PL+2,y+2);y+=14;}

    // ═══ CAPA ═══
    newPage();
    doc.setFillColor(...DARK);doc.rect(0,0,W,58,'F');
    doc.setFillColor(...ACCENT);doc.rect(0,58,W,3,'F');
    doc.setFont('helvetica','bold');doc.setFontSize(18);doc.setTextColor(...WH);
    doc.text(`RELATÓRIO DE SIMULADO TENDÊNCIAS`,logoDataUrl?PL:W/2,22,{align:logoDataUrl?'left':'center'});
    doc.setFontSize(10);doc.setTextColor(190,200,225);
    doc.text(`${name} | ${totalAlunos} alunos`,logoDataUrl?PL:W/2,34,{align:logoDataUrl?'left':'center'});
    doc.setFontSize(8.5);doc.setTextColor(160,175,200);
    doc.text(`${new Date().toLocaleDateString('pt-BR')} · MedCof B2B · Uso restrito`,logoDataUrl?PL:W/2,43,{align:logoDataUrl?'left':'center'});
    if(logoDataUrl){try{doc.addImage(logoDataUrl,'PNG',W-PR-30,12,30,30);}catch(e){}}

    // Stat boxes
    y=72;
    const mean=arr=>arr.length?(arr.reduce((a,b)=>a+b,0)/arr.length).toFixed(1)+'%':'—';
    const statCards=[
      {label:'Alunos avaliados',val:String(totalAlunos)},
      {label:'Média institucional',val:mediaIES.toFixed(1)+'%'},
      {label:'Ranking Nacional',val:bench.nationalRank?`${bench.nationalRank}º / ${bench.nationalTotal||'?'}`:' — '},
      {label:'Ranking Regional',val:bench.regionalRank?`${bench.regionalRank}º / ${bench.regionalTotal||'?'}`:' — '}
    ];
    const cW=PW/statCards.length;
    statCards.forEach((c,i)=>{
      const cx=PL+i*cW;
      doc.setFillColor(...DARK);doc.roundedRect(cx+2,y,cW-4,28,3,3,'F');
      doc.setFont('helvetica','bold');doc.setFontSize(16);doc.setTextColor(...WH);
      doc.text(c.val,cx+cW/2,y+13,{align:'center'});
      doc.setFontSize(7);doc.setTextColor(...MUTED);
      doc.text(c.label,cx+cW/2,y+22,{align:'center'});
    });
    y+=38;

    // Area coverage bars (cover)
    if(areas.length){
      doc.setFont('helvetica','bold');doc.setFontSize(9);doc.setTextColor(...TEXT);
      doc.text('Cobertura por Área',PL,y);y+=6;
      const sorted=[...areas].sort((a,b)=>b.pct_ies-a.pct_ies);
      sorted.forEach(a=>{
        checkY(10);
        const barW=PW*0.6;const pct=Math.min(a.pct_ies/100,1);
        doc.setFillColor(...CARD);doc.roundedRect(PL,y,barW,7,2,2,'F');
        doc.setFillColor(...ACCENT);doc.roundedRect(PL,y,barW*pct,7,2,2,'F');
        doc.setFont('helvetica','normal');doc.setFontSize(7);doc.setTextColor(...TEXT);
        doc.text(a.label,PL+barW+4,y+5);
        doc.setFont('helvetica','bold');doc.setTextColor(...ACCENT);
        doc.text(a.pct_ies.toFixed(0)+'%',PL+barW*pct-1,y+5,{align:'right'});
        y+=10;
      });
    }
    footer();

    // ═══ PÁG 2: RANKING COM ENGAJAMENTO ═══
    newPage();
    sectionHdr('1','Ranking Geral dos Alunos');
    doc.setFont('helvetica','normal');doc.setFontSize(7.5);doc.setTextColor(...SOFT);
    doc.text('Ranking ordenado por nota. Inclui tempo de uso da plataforma e classificação de engajamento.',PL,y);y+=6;

    const rankRows = enriched.map((e,i) => {
      const tempoH = e.eng ? (e.eng.tempo_min/60).toFixed(0)+'h' : '—';
      const tempoComp = e.eng ? (e.eng.tempo_min > tempoMedio ? '▲' : '▼') : '';
      const trLabel = {alta:'Alto',moderada:'Moderado',baixa:'Baixo'}[e.traction]||'—';
      return [i+1, e.nome||'', e.turma||'—', e.nota?.toFixed(1)+'%', tempoH+' '+tempoComp, e.qDia.toFixed(0)+' q/d', trLabel];
    });

    doc.autoTable({
      startY:y, margin:{left:PL,right:PR},
      head:[['#','Nome','Turma','Nota','Tempo','Q/dia','Eng.']],
      body:rankRows,
      styles:{fontSize:6.5,cellPadding:2,textColor:TEXT,lineColor:BORD,lineWidth:0.2},
      headStyles:{fillColor:DARK,textColor:WH,fontStyle:'bold',fontSize:7},
      alternateRowStyles:{fillColor:CARD},
      columnStyles:{0:{cellWidth:8,halign:'center'},3:{cellWidth:14,halign:'center',fontStyle:'bold'},4:{cellWidth:16,halign:'center'},5:{cellWidth:14,halign:'center'},6:{cellWidth:16,halign:'center'}},
      didParseCell:function(data){
        if(data.section==='body'&&data.column.index===6){
          const v=data.cell.raw;
          if(v==='Alto')data.cell.styles.textColor=[22,128,60];
          else if(v==='Moderado')data.cell.styles.textColor=[59,130,246];
          else data.cell.styles.textColor=[245,158,11];
        }
      },
      didDrawPage:function(){footer();}
    });
    y=doc.lastAutoTable.finalY+8;
    doc.setFont('helvetica','italic');doc.setFontSize(6.5);doc.setTextColor(...MUTED);
    doc.text(`Tempo médio da IES: ${(tempoMedio/60).toFixed(0)}h · ▲ acima da média · ▼ abaixo da média`,PL,y);

    // ═══ PÁG 3: DISTRIBUIÇÃO + ÁREAS ═══
    newPage();
    sectionHdr('2','Distribuição de Notas');
    const faixas=['0–9','10–19','20–29','30–39','40–49','50–59','60–69','70–79','80–89','90–100'];
    const maxBin=Math.max(...bins,1);
    faixas.forEach((f,i)=>{
      checkY(8);
      const barW=PW*0.5;const pct=bins[i]/maxBin;
      const isProf=i>=6;const isQuase=i>=5&&i<6;
      doc.setFillColor(...CARD);doc.roundedRect(PL+30,y,barW,6,2,2,'F');
      doc.setFillColor(...(isProf?GREEN:(isQuase?[245,158,11]:ACCENT)));
      if(pct>0)doc.roundedRect(PL+30,y,Math.max(barW*pct,2),6,2,2,'F');
      doc.setFont('helvetica','normal');doc.setFontSize(7);doc.setTextColor(...SOFT);
      doc.text(f,PL+27,y+4.5,{align:'right'});
      doc.setTextColor(...TEXT);doc.setFont('helvetica','bold');
      doc.text(String(bins[i]),PL+30+barW+4,y+4.5);
      y+=9;
    });
    y+=4;
    // Proficiency summary
    const profCount=enriched.filter(e=>e.band==='proficiente').length;
    const quaseCount=enriched.filter(e=>e.band==='quase').length;
    const urgCount=enriched.filter(e=>e.band==='urgente').length;
    doc.setFont('helvetica','bold');doc.setFontSize(8);doc.setTextColor(...TEXT);
    doc.text(`Proficientes (≥60): ${profCount} (${(profCount/totalAlunos*100).toFixed(0)}%)  ·  Quase (49-59): ${quaseCount} (${(quaseCount/totalAlunos*100).toFixed(0)}%)  ·  Atenção (<49): ${urgCount} (${(urgCount/totalAlunos*100).toFixed(0)}%)`,PL,y);
    y+=12;

    // Áreas detalhadas
    if(areas.length){
      sectionHdr('3','Desempenho por Grande Área');
      const areaRows=areas.map(a=>[a.label,a.pct_ies.toFixed(1)+'%',a.pct_ies>=60?'Acima':'Abaixo']);
      doc.autoTable({
        startY:y,margin:{left:PL,right:PR},
        head:[['Área','% Acerto IES','Posição']],body:areaRows,
        styles:{fontSize:7.5,cellPadding:3,textColor:TEXT,lineColor:BORD,lineWidth:0.2},
        headStyles:{fillColor:DARK,textColor:WH,fontStyle:'bold'},
        alternateRowStyles:{fillColor:CARD},
        columnStyles:{1:{halign:'center',fontStyle:'bold'},2:{halign:'center'}},
        didParseCell:function(d){if(d.section==='body'&&d.column.index===2){d.cell.styles.textColor=d.cell.raw==='Acima'?GREEN:[220,38,38];}},
        didDrawPage:function(){footer();}
      });
      y=doc.lastAutoTable.finalY+10;
    }

    // ═══ PÁG 4: MAPA DE RISCO ═══
    newPage();
    sectionHdr('4','Mapa de Risco — Engajamento × Proficiência');
    doc.setFont('helvetica','normal');doc.setFontSize(7.5);doc.setTextColor(...SOFT);
    doc.text('Cruzamento entre nível de engajamento na plataforma e resultado no simulado.',PL,y);y+=8;

    // 2×2 matrix visual
    const mW=70,mH=28,mx=PL+30;
    // Headers
    doc.setFont('helvetica','bold');doc.setFontSize(7);doc.setTextColor(...SOFT);
    doc.text('ENGAJAMENTO →',mx+mW-5,y-2,{align:'center'});
    doc.text('Baixo',mx+mW/4,y+3,{align:'center'});
    doc.text('Alto/Moderado',mx+mW*3/4,y+3,{align:'center'});y+=7;
    // Row: Proficiente
    doc.setFillColor(220,240,220);doc.rect(mx,y,mW/2,mH,'F');
    doc.setFillColor(200,230,200);doc.rect(mx+mW/2,y,mW/2,mH,'F');
    doc.setFont('helvetica','bold');doc.setFontSize(14);
    doc.setTextColor(100,120,100);doc.text(String(greyCount),mx+mW/4,y+mH/2+2,{align:'center'});
    doc.setTextColor(...GREEN);doc.text(String(greenCount),mx+mW*3/4,y+mH/2+2,{align:'center'});
    doc.setFontSize(6);doc.setTextColor(...SOFT);
    doc.text('Nota ≥ 60',mx-3,y+mH/2+1,{align:'right'});
    y+=mH;
