async function submitCreateUser() {
  const nome = document.getElementById('createNome').value.trim();
  const email = document.getElementById('createEmail').value.trim();
  const role = document.getElementById('createRole').value;
  const instituicao = document.getElementById('createInst').value;
  const senha = document.getElementById('createSenha').value;
  const btn = document.getElementById('createUserBtn');
  const feedback = document.getElementById('createUserFeedback');

  // Validações
  if (!nome) { feedback.style.color='var(--accent)'; feedback.textContent='Informe o nome completo.'; return; }
  if (!email || !email.includes('@')) { feedback.style.color='var(--accent)'; feedback.textContent='Informe um e-mail válido.'; return; }
  if (!instituicao && role === 'coordenador') { feedback.style.color='var(--accent)'; feedback.textContent='Selecione a instituição.'; return; }
  if (!senha || senha.length < 8) { feedback.style.color='var(--accent)'; feedback.textContent='A senha deve ter no mínimo 8 caracteres.'; return; }

  btn.disabled = true;
  btn.textContent = 'Criando...';
  feedback.style.color = 'var(--text-muted)';
  feedback.textContent = 'Criando usuário...';

  try {
    const resp = await fetch('/.netlify/functions/create-user', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nome, email, role, instituicao, senha })
    });

    const result = await resp.json();
    if (!resp.ok) throw new Error(result.error || 'Erro desconhecido');

    feedback.style.color = 'var(--green)';
    feedback.textContent = '✓ ' + result.message;

    // Recarregar lista após criação
    setTimeout(() => {
      closeCreateUserModal();
      loadUsers();
    }, 1800);
  } catch(e) {
    feedback.style.color = 'var(--accent)';
    feedback.textContent = 'Erro: ' + e.message;
  } finally {
    btn.disabled = false;
    btn.textContent = 'Criar usuário';
  }
}

