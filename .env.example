# Copie para .env (não commitado) e configure no Netlify → Site → Environment variables
# Obrigatório: chave que COMEÇA COM sk- (https://platform.openai.com/api-keys)
# NÃO use chave anon do Supabase (eyJ...) — a OpenAI retorna "not from a valid issuer".
OPENAI_API_KEY=sk-...
# A function também aceita openai_api_key (minúsculas) para compatibilidade com .env locais.
# Opcional: outro modelo (padrão gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# SendGrid — envio de e-mail (ex.: boletins individuais via /.netlify/functions/send-boletim-email)
# Chave em https://app.sendgrid.com/settings/api_keys — começa com SG.
# SENDGRID_API_KEY=SG....
# sendgrid_key=SG....   # alias aceito pela function
# Remetente deve estar verificado no SendGrid (Single Sender ou domínio autenticado).
# SENDGRID_FROM_EMAIL=Nao-responda@grupomedcof.com.br
