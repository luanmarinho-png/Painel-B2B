{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard-local",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),u=q.url==='/'?'/index.html':q.url,f=p.join(process.cwd(),decodeURIComponent(u)),m={'html':'text/html','js':'text/javascript','css':'text/css','json':'application/json','png':'image/png','avif':'image/avif','svg':'image/svg+xml'};fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':m[p.extname(f).slice(1)]||'application/octet-stream','Access-Control-Allow-Origin':'*'});r.end(d)}})}).listen(8888,()=>console.log('Serving on 8888'))"],
      "port": 8888
    }
  ]
}
